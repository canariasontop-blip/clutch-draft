        </div><!-- /fmts-grid -->
    </div>

</div>

<script src="/socket.io/socket.io.js"></script>
<script>
window.__CLUTCH__ = { username: '<%= user.username %>' };

function switchTab(name, btn) {
    document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
    document.getElementById('tab-'+name).classList.add('active');
    btn.classList.add('active');
    history.replaceState(null,'','/torneo?tab='+name);
    if (name === 'stats') cargarStats();
}

function cargarStats() {
    const cont = document.getElementById('stats-container');
    const rank  = document.getElementById('stats-ranking');
    if (!cont || cont.dataset.loaded) return;
    cont.dataset.loaded = '1';
    fetch('/api/stats-globales')
        .then(r => r.json())
        .then(d => {
            const card = (icon, label, val, sub) =>
                `<div style="background:var(--card);border:1px solid var(--border);border-radius:14px;padding:20px 22px;">
                    <div style="font-size:1.8rem;margin-bottom:6px;">${icon}</div>
                    <div style="font-size:.68rem;color:#aaa;text-transform:uppercase;letter-spacing:2px;margin-bottom:4px;">${label}</div>
                    <div style="font-size:1.35rem;font-weight:800;color:#fff;">${val}</div>
                    ${sub ? `<div style="font-size:.75rem;color:#aaa;margin-top:4px;">${sub}</div>` : ''}
                </div>`;
            cont.innerHTML =
                card('⚽', 'Goles totales', d.totalGoles, `en ${d.totalPartidos} partidos`) +
                card('🏹', 'Mejor ataque', d.mejorAtaque?.equipo_nombre || '—', d.mejorAtaque ? `${d.mejorAtaque.gf} goles` : '') +
                card('🛡️', 'Mejor defensa', d.mejorDefensa?.equipo_nombre || '—', d.mejorDefensa ? `${d.mejorDefensa.gc} goles recibidos` : '') +
                card('🏆', 'Más victorias', d.masVictorias?.equipo_nombre || '—', d.masVictorias ? `${d.masVictorias.pg} victorias` : '') +
                card('💪', 'Más invicto', d.masInvicto?.equipo_nombre || '—', d.masInvicto ? `${d.masInvicto.pp} derrotas` : '');
            if (d.masGoles?.length) {
                rank.innerHTML = d.masGoles.map((t,i) => {
                    const medals = ['🥇','🥈','🥉','4️⃣','5️⃣'];
                    return `<div style="background:var(--card);border:1px solid var(--border);border-radius:14px;padding:16px 20px;display:flex;align-items:center;gap:14px;">
                        <span style="font-size:1.4rem;">${medals[i]||''}</span>
                        <div>
                            <div style="font-weight:700;">${t.equipo_nombre}</div>
                            <div style="font-size:.8rem;color:#aaa;">${t.gf} goles marcados</div>
                        </div>
                    </div>`;
                }).join('');
            }
        })
        .catch(() => { cont.innerHTML = '<div style="color:#aaa;padding:20px;">Error cargando estadísticas.</div>'; });
}

// Activar tab desde URL
(function(){
    const tab = new URLSearchParams(location.search).get('tab');
    if(tab){
        const btn = document.querySelector(`.tab-btn[onclick*="'${tab}'"]`);
        if(btn) btn.click();
    }
})();

// ── SOCKET: actualizaciones en vivo ──────────────────────────
(function(){
    const socket = io();

    socket.on('init', function() {});

    // Cuando llega un resultado nuevo → recargar la página
    socket.on('resultado', function() {
        setTimeout(() => location.reload(), 400);
    });

    // Cuando se actualiza la clasificación (viene del bot o del admin) → recargar
    socket.on('clasificacion-update', function() {
        setTimeout(() => location.reload(), 400);
    });

    // Torneo generado → recargar para ver partidos
    socket.on('torneo-generado', function() {
        setTimeout(() => location.reload(), 400);
    });

    // Torneo limpiado → recargar
    socket.on('torneo-limpiado', function() {
        setTimeout(() => location.reload(), 400);
    });
})();
</script>
<script src="/js/main.js"></script>

<script>
(function(){
  var burger = document.getElementById('nav-hamburger');
  var links  = document.getElementById('nav-links');
  if(!burger) return;
  burger.addEventListener('click', function(){
    links.classList.toggle('open');
    burger.classList.toggle('open');
  });
  links.querySelectorAll('.nav-link').forEach(function(l){
    l.addEventListener('click', function(){
      links.classList.remove('open');
      burger.classList.remove('open');
    });
  });
})();
</script>
</body>
</html>
