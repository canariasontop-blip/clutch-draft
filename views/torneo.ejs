<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#03030a">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Clutch Draft">
    <link rel="apple-touch-icon" href="/icon-512.png">
    <title>Clutch Draft — Torneo</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Rajdhani:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/mobile.css">
    <style>
        /* ── VIDEO FONDO ── */
        #bg-video-wrap{position:fixed;inset:0;z-index:0;overflow:hidden;}
        #bg-video{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0.18;}
        #bg-overlay{position:absolute;inset:0;background:rgba(3,3,10,0.75);}
        /* ── CONTENIDO SOBRE EL VIDEO ── */
        .container,.page-wrap,.normas-hero,.normas-content,.hof-hero,.hof-content,
        .page-header,.stats-row,.tabs,.tab-content,.section,.controls-grid,
        .teams-tracker,.live-section,.stream-section,.proximos-section,
        .turn-banner,.draft-cerrado,.cap-layout,.spec-layout{position:relative;z-index:1;}
        *{margin:0;padding:0;box-sizing:border-box;}
        :root{--primary:#00ffcc;--accent:#a066ff;--gold:#f0c040;--bg:#03030a;--card:#0b0b14;--border:rgba(255,255,255,0.06);--font-display:'Bebas Neue',sans-serif;--font-body:'Rajdhani',sans-serif;}
        body{font-family:var(--font-body);background:var(--bg);color:#fff;min-height:100vh;}

        /* NAV */

        /* PAGE HEADER */
        .page-header{padding:50px 24px 20px;max-width:1200px;margin:0 auto;position:relative;z-index:1;}
        .page-eyebrow{font-size:0.65rem;color:var(--primary);letter-spacing:5px;text-transform:uppercase;font-weight:700;margin-bottom:6px;}
        .page-title{font-family:var(--font-display);font-size:clamp(2.5rem,6vw,4rem);letter-spacing:2px;margin-bottom:30px;}

        /* TABS */
        .tabs-bar{
            position:relative;z-index:10;
            background:rgba(3,3,10,0.96);border-bottom:1px solid var(--border);
            backdrop-filter:blur(20px);
        }
        .tabs-inner{
            max-width:1200px;margin:0 auto;padding:0 24px;
            display:flex;gap:0;overflow-x:auto;
        }
        .tabs-inner::-webkit-scrollbar{height:0;}
        .tab-btn{
            padding:16px 22px;font-family:var(--font-body);font-weight:700;font-size:0.78rem;
            letter-spacing:2px;text-transform:uppercase;color:#aaa;
            background:transparent;border:none;border-bottom:2px solid transparent;
            cursor:pointer;transition:0.2s;white-space:nowrap;
        }
        .tab-btn:hover{color:#ccc;}
        .tab-btn.active{color:var(--primary);border-bottom-color:var(--primary);}

        /* CONTENT */
        .content{max-width:1200px;margin:0 auto;padding:36px 24px 60px;position:relative;z-index:1;}
        .tab-panel{display:none;position:relative;z-index:1;}
        .tab-panel.active{display:block;}

        /* PANEL TITLE */
        .panel-hdr{font-family:var(--font-display);font-size:1.6rem;letter-spacing:2px;margin-bottom:24px;color:#fff;}

        /* EQUIPOS GRID */
        .equipos-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:14px;}
        .equipo-card{
            background:var(--card);border:1px solid var(--border);border-radius:14px;
            padding:20px;display:flex;flex-direction:column;align-items:center;gap:12px;
            transition:0.3s;
        }
        .equipo-card:hover{border-color:rgba(0,255,204,0.2);transform:translateY(-3px);}
        .escudo-wrap{width:60px;height:60px;border-radius:12px;background:rgba(255,255,255,0.04);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;overflow:hidden;}
        .escudo-wrap img{width:100%;height:100%;object-fit:cover;}
        .escudo-ph{color:#444;font-size:1.4rem;}
        .equipo-nombre{font-weight:700;font-size:0.95rem;text-align:center;}
        .equipo-capitan{font-size:0.7rem;color:#aaa;text-transform:uppercase;letter-spacing:1px;}

        /* TABLA */
        .tabla-wrap{overflow-x:auto;}
        table{width:100%;border-collapse:collapse;}
        thead th{font-size:0.62rem;color:#aaa;text-transform:uppercase;letter-spacing:2px;padding:10px 14px;border-bottom:1px solid var(--border);text-align:left;white-space:nowrap;}
        thead th:not(:first-child){text-align:center;}
        tbody tr{border-bottom:1px solid var(--border);transition:0.15s;}
        tbody tr:hover{background:rgba(255,255,255,0.02);}
        tbody td{padding:13px 14px;font-size:0.88rem;font-weight:600;}
        tbody td:not(:first-child):not(:nth-child(2)){text-align:center;color:#ccc;}
        .pos-cell{font-family:var(--font-display);font-size:1.1rem;width:40px;}
        .pos-cell.top1{color:var(--gold);}
        .pos-cell.top2{color:#c0c0c0;}
        .pos-cell.top3{color:#cd7f32;}
        .pts-cell{color:var(--primary)!important;font-weight:700!important;}
        .equipo-cell{display:flex;align-items:center;gap:10px;}
        .mini-escudo{width:22px;height:22px;border-radius:5px;object-fit:cover;border:1px solid var(--border);}

        /* MATCHES */
        .jornada-group{margin-bottom:36px;}
        .jornada-title{
            font-size:0.65rem;color:var(--primary);letter-spacing:4px;text-transform:uppercase;
            font-weight:700;margin-bottom:14px;display:flex;align-items:center;gap:10px;
        }
        .jornada-title::after{content:'';flex:1;height:1px;background:var(--border);}
        .matches-list{display:flex;flex-direction:column;gap:8px;}
        .match-row{
            display:flex;align-items:center;
            background:var(--card);border:1px solid var(--border);border-radius:12px;
            padding:14px 20px;gap:16px;transition:0.2s;
        }
        .match-row:hover{border-color:rgba(255,255,255,0.1);}
        .match-row.finalizado{opacity:0.75;}
        .match-row.en-curso{border-color:rgba(0,255,204,0.3);background:rgba(0,255,204,0.03);}
        .match-team{flex:1;font-weight:700;font-size:0.9rem;}
        .match-team.right{text-align:right;}
        .match-score{
            font-family:var(--font-display);font-size:1.6rem;letter-spacing:4px;
            color:var(--primary);min-width:80px;text-align:center;
        }
        .match-score.pending{color:#555;font-size:0.9rem;font-family:var(--font-body);font-weight:600;letter-spacing:1px;}
        .match-badge{font-size:0.55rem;font-weight:700;padding:2px 7px;border-radius:4px;text-transform:uppercase;letter-spacing:1px;white-space:nowrap;}
        .badge-fin{background:rgba(0,255,204,0.1);color:var(--primary);}
        .badge-pen{background:rgba(255,255,255,0.04);color:#aaa;}
        .badge-live{background:rgba(255,77,77,0.15);color:#ff4d4d;animation:pulse 1.5s infinite;}
        @keyframes pulse{50%{opacity:0.5;}}

        /* RONDAS / BRACKET */
        .bracket-msg{
            background:rgba(11,11,20,0.92);border:1px solid var(--border);border-radius:14px;
            padding:60px;text-align:center;color:#888;
            backdrop-filter:blur(6px);
        }
        .bracket-msg i{font-size:3rem;margin-bottom:16px;display:block;color:#333;}
        .bracket-msg p{font-size:1rem;}

        /* EMPTY */
        .empty-note{color:#666;font-style:italic;font-size:0.88rem;padding:30px 0;text-align:center;}

        /* ── FORMATOS DE COMPETICIÓN ── */
        .fmts-grid{display:flex;flex-direction:column;gap:14px;}
        .fmt-card{background:var(--card);border:1px solid var(--border);border-radius:14px;overflow:hidden;transition:.2s;}
        .fmt-card:hover{border-color:rgba(255,255,255,.1);}
        .fmt-card summary{list-style:none;}
        .fmt-card summary::-webkit-details-marker{display:none;}
        .fmt-hdr{
            padding:18px 22px;display:flex;align-items:center;gap:14px;
            cursor:pointer;user-select:none;
        }
        details[open] .fmt-hdr{border-bottom:1px solid var(--border);}
        .fmt-ico{width:44px;height:44px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.15rem;flex-shrink:0;}
        .fmt-meta{flex:1;}
        .fmt-name{font-family:var(--font-display);font-size:1.05rem;letter-spacing:2px;}
        .fmt-sub{font-size:.65rem;color:#888;text-transform:uppercase;letter-spacing:2px;margin-top:2px;}
        .fmt-pill{font-size:.58rem;font-weight:700;padding:4px 11px;border-radius:20px;letter-spacing:1px;text-transform:uppercase;flex-shrink:0;}
        .fmt-toggle{color:#555;font-size:.75rem;flex-shrink:0;transition:.2s;}
        details[open] .fmt-toggle{transform:rotate(180deg);color:var(--primary);}
        .fmt-body{padding:18px 22px 22px;display:grid;grid-template-columns:1fr 1fr;gap:14px;}
        .fmt-phase{background:rgba(255,255,255,.025);border:1px solid var(--border);border-radius:10px;padding:14px;}
        .fmt-phase.full{grid-column:1/-1;}
        .fph-ttl{font-size:.58rem;font-weight:700;letter-spacing:3px;text-transform:uppercase;padding-bottom:8px;border-bottom:1px solid var(--border);margin-bottom:10px;}
        .fph-list{list-style:none;margin:0;padding:0;}
        .fph-list li{font-size:.8rem;color:#bbb;padding:5px 0;line-height:1.6;border-bottom:1px solid rgba(255,255,255,.03);display:flex;gap:7px;}
        .fph-list li:last-child{border-bottom:none;padding-bottom:0;}
        .fph-list li .arr{flex-shrink:0;color:var(--primary);}
        .clasi-rows{display:flex;flex-direction:column;gap:4px;margin-top:6px;}
        .clasi-item{font-size:.75rem;padding:6px 10px;border-radius:6px;display:flex;align-items:center;gap:8px;}
        .clasi-item.up{background:rgba(0,255,204,.07);border:1px solid rgba(0,255,204,.15);color:var(--primary);}
        .clasi-item.mid{background:rgba(255,204,0,.06);border:1px solid rgba(255,204,0,.12);color:#ffcc00;}
        .clasi-item.out{background:rgba(255,77,77,.05);border:1px solid rgba(255,77,77,.1);color:#ff4d4d;opacity:.8;}
        .clasi-pos{font-family:var(--font-display);font-size:.95rem;width:56px;flex-shrink:0;}
        .desempate-ol{counter-reset:dc;list-style:none;margin:0;padding:0;display:flex;flex-direction:column;gap:5px;}
        .desempate-ol li{counter-increment:dc;display:flex;align-items:center;gap:10px;padding:8px 12px;background:rgba(255,255,255,.02);border:1px solid var(--border);border-radius:7px;font-size:.82rem;color:#ccc;}
        .desempate-ol li::before{content:counter(dc);font-family:var(--font-display);font-size:1.1rem;color:var(--primary);width:22px;text-align:center;flex-shrink:0;}
        .fmt-desempate{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:22px;}
        .fmt-desempate-hdr{display:flex;align-items:center;gap:12px;margin-bottom:18px;}
        .fmt-desempate-ico{width:40px;height:40px;border-radius:10px;background:rgba(240,192,64,.1);color:var(--gold);display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0;}
        .fmt-desempate-ttl{font-family:var(--font-display);font-size:1rem;letter-spacing:2px;}
        .fmt-desempate-sub{font-size:.65rem;color:#888;text-transform:uppercase;letter-spacing:2px;margin-top:2px;}

        @media(max-width:768px){
            .page-header{padding:80px 14px 0;}
            .tabs-inner{padding:0 14px;overflow-x:auto;}
            .tab-btn{padding:14px 12px;font-size:0.68rem;white-space:nowrap;flex-shrink:0;}
            .content{padding:24px 14px 40px;}
            .equipos-grid{grid-template-columns:repeat(auto-fill,minmax(150px,1fr));}
            .match-team{font-size:0.78rem;}
            .match-score{font-size:1.2rem;min-width:60px;}
            .fmt-body{grid-template-columns:1fr;}
            .fmt-phase.full{grid-column:auto;}
            .controls-grid{grid-template-columns:1fr;}
            .controls-grid.two{grid-template-columns:1fr;}
            .controls-grid.three{grid-template-columns:1fr;}
        }
        @media(max-width:480px){
            .equipos-grid{grid-template-columns:repeat(2,1fr);}
        }
        </style>
    <link rel="stylesheet" href="/css/nav.css">
</head>
<body>

<div id="bg-video-wrap">
    <video id="bg-video" autoplay muted loop playsinline>
        <source src="/video/wallpaper_para_ruta-torneo.mp4" type="video/mp4">
    </video>
    <div id="bg-overlay"></div>
</div>

<nav>
    <div class="nav-logo">CLUTCH</div>
    <button class="nav-hamburger" id="nav-hamburger" aria-label="Menú">
        <span></span><span></span><span></span>
    </button>
    <div class="nav-links" id="nav-links">
        <a href="/hub" class="nav-link">Hub</a>
        <a href="/draft" class="nav-link">Draft</a>
        <a href="/torneo" class="nav-link active">Torneo</a>
        <a href="/historial" class="nav-link">Historial</a>
        <a href="/directo" class="nav-link">Directo</a>
        <a href="/normas" class="nav-link">Normas</a>
        <a href="/ganadores" class="nav-link">Ganadores</a>
        <a href="/inscripciones" class="nav-link">Inscripciones</a>
        <% if (user.esAdmin) { %><a href="/admin" class="nav-link admin-lnk">Admin</a><% } %>
    </div>
    <div class="nav-user">
        <img src="<%= user.avatar %>" class="nav-avatar" alt="">
        <span class="nav-username"><%= user.username %></span>
        <a href="/logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i></a>
    </div>
</nav>

<div class="page-header">
    <div class="page-eyebrow">Clutch Draft · Temporada 2025</div>
    <div class="page-title">TORNEO</div>
</div>

<!-- TABS BAR -->
<div class="tabs-bar">
    <div class="tabs-inner">
        <button class="tab-btn active" onclick="switchTab('equipos',this)"><i class="fas fa-shield-alt"></i> Equipos</button>
        <button class="tab-btn" onclick="switchTab('clasificacion',this)"><i class="fas fa-list-ol"></i> Clasificación</button>
        <button class="tab-btn" onclick="switchTab('resultados',this)"><i class="fas fa-futbol"></i> Resultados</button>
        <button class="tab-btn" onclick="switchTab('emparejamientos',this)"><i class="fas fa-calendar-alt"></i> Emparejamientos</button>
        <button class="tab-btn" onclick="switchTab('rondas',this)"><i class="fas fa-sitemap"></i> Rondas Finales</button>
        <button class="tab-btn" onclick="switchTab('stats',this)"><i class="fas fa-chart-bar"></i> Estadísticas</button>
        <button class="tab-btn" onclick="switchTab('formatos',this)"><i class="fas fa-trophy"></i> Formatos</button>
    </div>
</div>

<div class="content">

    <!-- ── EQUIPOS ── -->
    <div id="tab-equipos" class="tab-panel active">
        <div class="panel-hdr">EQUIPOS PARTICIPANTES</div>
        <% if (equipos.length > 0) { %>
        <div class="equipos-grid">
            <% equipos.forEach(eq => { %>
            <div class="equipo-card">
                <div class="escudo-wrap">
                    <% if (eq.logo_url) { %>
                        <img src="<%= eq.logo_url %>" alt="">
                    <% } else { %>
                        <i class="fas fa-shield-alt escudo-ph"></i>
                    <% } %>
                </div>
                <div class="equipo-nombre"><%= eq.nombre_equipo || eq.capitan_username %></div>
                <div class="equipo-capitan">Cap. <%= eq.capitan_username %></div>
            </div>
            <% }) %>
        </div>
        <% } else { %>
        <div class="empty-note">No hay equipos registrados aún.</div>
        <% } %>
    </div>

    <!-- ── CLASIFICACIÓN ── -->
    <div id="tab-clasificacion" class="tab-panel">
        <div class="panel-hdr">TABLA DE CLASIFICACIÓN</div>
        <% if (tabla.length > 0) { %>
        <div class="tabla-wrap">
            <table>
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Equipo</th>
                        <th>PJ</th><th>PG</th><th>PE</th><th>PP</th>
                        <th>GF</th><th>GC</th><th>DG</th><th>Pts</th>
                    </tr>
                </thead>
                <tbody>
                    <% tabla.forEach((eq, i) => {
                        const posClass = i===0?'top1':i===1?'top2':i===2?'top3':'';
                        const eqData = equiposMap[eq.capitan_id];
                    %>
                    <tr>
                        <td class="pos-cell <%= posClass %>">#<%= i+1 %></td>
                        <td>
                            <a href="/jugador/<%= eq.capitan_id %>" style="text-decoration:none;color:inherit;">
                            <div class="equipo-cell">
                                <% if (eqData?.logo_url) { %>
                                    <img src="<%= eqData.logo_url %>" class="mini-escudo" alt="">
                                <% } %>
                                <%= eq.display_nombre || eq.equipo_nombre %>
                            </div>
                            </a>
                        </td>
                        <td><%= eq.pj %></td>
                        <td><%= eq.pg %></td>
                        <td><%= eq.pe %></td>
                        <td><%= eq.pp %></td>
                        <td><%= eq.gf %></td>
                        <td><%= eq.gc %></td>
                        <td><%= eq.gf - eq.gc %></td>
                        <td class="pts-cell"><%= eq.puntos %></td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
        <% } else { %>
        <div class="empty-note">La clasificación estará disponible cuando comiencen los partidos.</div>
        <% } %>
    </div>

    <!-- ── RESULTADOS ── -->
    <div id="tab-resultados" class="tab-panel">
        <div class="panel-hdr">RESULTADOS</div>
        <%
            const fasLabelsRes = { playoffs: '🎯 Play-offs', cuartos: '🏆 Cuartos de Final', semis: '⚔️ Semifinales', final: '🏆 Gran Final' };
            const finalizados  = matches.filter(m => m.estado === 'finalizado' && m.equipo2 !== 'BYE');
            const jornadasFin  = [...new Set(finalizados.map(m => m.jornada))].sort((a,b) => b-a);
            function labelJornadaRes(j) {
                if (!totalRondasLiga || j <= totalRondasLiga) return 'Jornada ' + j;
                const offset = j - totalRondasLiga;
                const fase   = fasesTorneo[offset] || fasesTorneo[fasesTorneo.length - 1] || 'final';
                return fasLabelsRes[fase] || fase.toUpperCase();
            }
        %>
        <% if (jornadasFin.length > 0) { %>
            <% jornadasFin.forEach(j => { %>
            <div class="jornada-group">
                <div class="jornada-title"><%= labelJornadaRes(j) %></div>
                <div class="matches-list">
                    <% finalizados.filter(m=>m.jornada===j).forEach(m => { %>
                    <div class="match-row finalizado">
                        <div class="match-team"><%= m.equipo1 %></div>
                        <div class="match-score"><%= m.goles1 %> - <%= m.goles2 %></div>
                        <div class="match-team right"><%= m.equipo2 %></div>
                        <span class="match-badge badge-fin">FIN</span>
                    </div>
                    <% }) %>
                </div>
            </div>
            <% }) %>
        <% } else { %>
        <div class="empty-note">No hay resultados todavía.</div>
        <% } %>
    </div>

    <!-- ── EMPAREJAMIENTOS ── -->
    <div id="tab-emparejamientos" class="tab-panel">
        <%
            const _fasLabelsEmp = { playoffs: '🎯 Play-offs', cuartos: '🏆 Cuartos de Final', semis: '⚔️ Semifinales', final: '🏆 Gran Final' };
            function labelJornadaEmp(j) {
                if (!totalRondasLiga || j <= totalRondasLiga) return 'Jornada ' + j;
                const offset = j - totalRondasLiga - 1;
                const fase   = fasesTorneo[offset + 1] || fasesTorneo[fasesTorneo.length - 1] || 'final';
                return _fasLabelsEmp[fase] || fase.charAt(0).toUpperCase() + fase.slice(1);
            }
            function esKOEmp(j) { return totalRondasLiga > 0 && j > totalRondasLiga; }
            const pendientes  = matches.filter(m => m.estado === 'pendiente');
            const enCurso     = matches.filter(m => m.estado === 'en_curso');
            const jornadasPen = [...new Set([...pendientes, ...enCurso].map(m => m.jornada))].sort((a,b) => a-b);
            const hdrLabel    = jornadasPen.length > 0 ? labelJornadaEmp(jornadasPen[0]) : ('J' + jornadaActual);
        %>
        <div class="panel-hdr">EMPAREJAMIENTOS — <%= hdrLabel %></div>
        <% if (enCurso.length > 0) { %>
        <div class="jornada-group">
            <div class="jornada-title" style="color:#ff4d4d;">🔴 En curso ahora</div>
            <div class="matches-list">
                <% enCurso.forEach(m => { %>
                <div class="match-row en-curso">
                    <div class="match-team"><%= m.equipo1 %></div>
                    <div class="match-score pending">VS</div>
                    <div class="match-team right"><%= m.equipo2 %></div>
                    <span class="match-badge badge-live">LIVE</span>
                </div>
                <% }) %>
            </div>
        </div>
        <% } %>
        <% if (jornadasPen.length > 0) { %>
            <% jornadasPen.forEach(j => {
                const esKO    = esKOEmp(j);
                const jLabel  = labelJornadaEmp(j);
                const jColor  = esKO ? (jLabel.includes('Final') && !jLabel.includes('Cuartos') && !jLabel.includes('Semi') ? 'var(--gold)' : 'var(--primary)') : 'inherit';
            %>
            <div class="jornada-group">
                <div class="jornada-title" style="color:<%= jColor %>"><%= jLabel %></div>
                <div class="matches-list">
                    <% pendientes.filter(m=>m.jornada===j).forEach(m => { %>
                    <div class="match-row">
                        <div class="match-team"><%= m.equipo1 %></div>
                        <div class="match-score pending">VS</div>
                        <div class="match-team right"><%= m.equipo2 %></div>
                        <span class="match-badge badge-pen">Pendiente</span>
                    </div>
                    <% }) %>
                </div>
            </div>
            <% }) %>
        <% } %>
        <% if (pendientes.length === 0 && enCurso.length === 0) { %>
        <div class="empty-note">No hay emparejamientos pendientes.</div>
        <% } %>
    </div>

    <!-- ── RONDAS FINALES ── -->
    <div id="tab-rondas" class="tab-panel">
        <div class="panel-hdr">RONDAS FINALES</div>
        <%
            const fasLabels = { playoffs: '🎯 PLAY-OFFS', cuartos: '🏆 CUARTOS DE FINAL', semis: '⚔️ SEMIFINALES', final: '🏆 GRAN FINAL' };
            const knockoutMatches = totalRondasLiga > 0
                ? matches.filter(m => m.jornada > totalRondasLiga)
                : [];
            const jornadasKO = [...new Set(knockoutMatches.map(m => m.jornada))].sort((a,b) => a-b);
            const soloLiga   = fasesTorneo.length === 1 || fasesTorneo[0] === 'liga' && fasesTorneo.length <= 1;
            const ligaTerminada = totalRondasLiga > 0 && matches.filter(m => m.jornada <= totalRondasLiga).every(m => m.estado === 'finalizado') && matches.filter(m => m.jornada <= totalRondasLiga).length > 0;
        %>
        <% if (knockoutMatches.length > 0) { %>
            <% jornadasKO.forEach(j => {
                const offset = j - totalRondasLiga;
                const fase   = fasesTorneo[offset] || 'final';
                const label  = fasLabels[fase] || fase.toUpperCase();
            %>
            <div class="jornada-group">
                <div class="jornada-title" style="color:<%= fase === 'final' ? 'var(--gold)' : 'var(--primary)' %>;">
                    <%= label %>
                </div>
                <div class="matches-list">
                    <% knockoutMatches.filter(m => m.jornada === j).forEach(m => { %>
                    <div class="match-row <%= m.estado === 'finalizado' ? 'finalizado' : m.estado === 'en_curso' ? 'en-curso' : '' %>">
                        <div class="match-team"><%= m.equipo1 %></div>
                        <% if (m.estado === 'finalizado') { %>
                            <div class="match-score"><%= m.goles1 %> - <%= m.goles2 %></div>
                        <% } else if (m.estado === 'en_curso') { %>
                            <div class="match-score pending">VS</div>
                        <% } else { %>
                            <div class="match-score pending">VS</div>
                        <% } %>
                        <div class="match-team right"><%= m.equipo2 %></div>
                        <span class="match-badge <%= m.estado === 'finalizado' ? 'badge-fin' : m.estado === 'en_curso' ? 'badge-live' : 'badge-pen' %>">
                            <%= m.estado === 'finalizado' ? 'FIN' : m.estado === 'en_curso' ? 'LIVE' : 'Pendiente' %>
                        </span>
                    </div>
                    <% }) %>
                </div>
            </div>
            <% }) %>
        <% } else if (soloLiga && ligaTerminada && tabla.length > 0) { %>
        <div class="bracket-msg" style="border-color:rgba(0,255,204,0.2);">
            <i class="fas fa-trophy" style="color:var(--gold);"></i>
            <p style="color:#ccc; font-size:1.05rem; margin-bottom:12px;">Liga finalizada — sin rondas eliminatorias.</p>
            <p><strong style="color:var(--gold);font-size:1.1rem;">🥇 Campeón: <%= tabla[0]?.equipo_nombre || '—' %></strong></p>
            <% if (tabla[1]) { %><p style="margin-top:6px;color:#aaa;">🥈 Subcampeón: <%= tabla[1].equipo_nombre %></p><% } %>
        </div>
        <% } else if (!soloLiga && ligaTerminada) { %>
        <div class="bracket-msg" style="border-color:rgba(160,102,255,0.25);">
            <i class="fas fa-hourglass-half" style="color:var(--accent);"></i>
            <p style="color:#ccc;">La fase de liga ha terminado.</p>
            <p style="margin-top:8px;font-size:0.85rem;color:#888;">
                Próxima fase: <strong style="color:var(--accent);">
                <%= fasLabels[fasesTorneo[1]] || fasesTorneo[1]?.toUpperCase() || '—' %>
                </strong> — generándose automáticamente...
            </p>
        </div>
        <% } else { %>
        <div class="bracket-msg">
            <i class="fas fa-sitemap"></i>
            <p>Las rondas finales aparecerán aquí cuando concluya la fase de liga.</p>
            <% if (tabla.length > 0) { %>
            <p style="margin-top:8px;font-size:0.8rem;color:#555;">
                Jornada actual: <%= jornadaActual %>
                <% if (!soloLiga) { %> · Fases pendientes: <%= fasesTorneo.slice(1).map(f => fasLabels[f] || f).join(' → ') %><% } %>
            </p>
            <% } %>
        </div>
        <% } %>
    </div>

    <!-- ── ESTADÍSTICAS ── -->
    <div id="tab-stats" class="tab-panel">
        <div class="panel-hdr">ESTADÍSTICAS DEL TORNEO</div>
        <div id="stats-container" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:16px;margin-bottom:32px;">
            <div class="stat-load" style="color:#aaa;font-size:.85rem;grid-column:1/-1;padding:20px 0;">Cargando estadísticas...</div>
        </div>
        <div class="panel-hdr" style="margin-top:8px;">RANKING DE EQUIPOS</div>
        <div id="stats-ranking" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:16px;"></div>
    </div>

    <!-- ── FORMATOS ── -->
    <div id="tab-formatos" class="tab-panel">
        <div class="panel-hdr">FORMATOS DE COMPETICIÓN</div>
        <p style="color:#888;font-size:.82rem;margin-bottom:20px;line-height:1.7;">El formato se determina automáticamente según el número de equipos participantes. Pulsa cada tarjeta para ver todos los detalles.</p>

        <div class="fmts-grid">

            <!-- 4 EQUIPOS -->
            <details class="fmt-card">
                <summary class="fmt-hdr">
                    <div class="fmt-ico" style="background:rgba(160,102,255,.12);color:var(--accent);"><i class="fas fa-bolt"></i></div>
                    <div class="fmt-meta">
                        <div class="fmt-name" style="color:var(--accent);">COPA — ELIMINATORIAS</div>
                        <div class="fmt-sub">Formato para 4 Equipos</div>
                    </div>
                    <span class="fmt-pill" style="background:rgba(160,102,255,.12);color:var(--accent);">4 EQ · 3 JORNADAS · 5 PARTIDOS</span>
                    <i class="fas fa-chevron-down fmt-toggle"></i>
                </summary>
                <div class="fmt-body">
