                            <div class="clasi-item out" style="opacity:.5"><span class="clasi-pos">3º–4º</span> <span>Eliminados en semifinales</span></div>
                        </div>
                    </div>
                </div>
            </details>

            <!-- 6 EQUIPOS -->
            <details class="fmt-card">
                <summary class="fmt-hdr">
                    <div class="fmt-ico" style="background:rgba(240,192,64,.1);color:var(--gold);"><i class="fas fa-cut"></i></div>
                    <div class="fmt-meta">
                        <div class="fmt-name" style="color:var(--gold);">CHAMPIONS — CORTE DIRECTO</div>
                        <div class="fmt-sub">Formato para 6 Equipos</div>
                    </div>
                    <span class="fmt-pill" style="background:rgba(240,192,64,.1);color:var(--gold);">6 EQ · 3–4 JORNADAS</span>
