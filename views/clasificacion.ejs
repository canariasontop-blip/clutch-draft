<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#03030a">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Clutch Draft">
    <link rel="apple-touch-icon" href="/icon-512.png">
    <title>Clutch Draft — Clasificación</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* ── VIDEO FONDO ── */
        #bg-video-wrap{position:fixed;inset:0;z-index:0;overflow:hidden;pointer-events:none;}
        #bg-video{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0.22;}
        #bg-overlay{position:absolute;inset:0;background:rgba(3,3,10,0.70);}
        /* ── LEGIBILIDAD ── */
        :root{ --card:rgba(18,18,30,0.88)!important; --border:rgba(255,255,255,0.10)!important; }
        body{ color:#ddd; }
        h1,h2,h3,h4,h5,h6{ color:#fff!important; }
        p,li,td,th,label,span.norma-text{ color:#ddd!important; }
        .norma-text{ color:#ddd!important; }
        .norma-text strong{ color:#fff!important; }
        /* Dark grays → readable */
        [style*="color:#444"],[style*="color: #444"]{ color:#aaa!important; }
        [style*="color:#555"],[style*="color: #555"]{ color:#bbb!important; }
        [style*="color:#333"],[style*="color: #333"]{ color:#999!important; }
        [style*="color:#666"],[style*="color: #666"]{ color:#bbb!important; }
        [style*="color:#888"],[style*="color: #888"]{ color:#ccc!important; }
        /* Cards with semi-transparent bg */
        .card,.panel,.section,.norma-card,.rule-card,.team-card,
        .match-card,.stat-card,.stat-block,.quick-card,.bottom-sec,
        .normas-content,.aviso-final,.altura-cell,.alert-row,
        .turno-block,.nav-card,.hof-card,.winner-card,.tab-content{
            background:rgba(15,15,28,0.85)!important;
            backdrop-filter:blur(4px);
        }
        /* Inputs and selects */
        input,select,textarea{
            background:rgba(255,255,255,0.06)!important;
            color:#fff!important;
        }
        /* Content above video */
        nav{ z-index:200!important; }
        #nav-links.open{ z-index:199!important; }
        body>*:not(#bg-video-wrap):not(nav){ position:relative; z-index:1; }
        * { margin:0; padding:0; box-sizing:border-box; }
        :root { --primary:#00ffcc; --accent:#a066ff; --bg:#050507; --card:#0f0f14; --border:rgba(255,255,255,0.06); --gold:#ffd700; --silver:#c0c0c0; --bronze:#cd7f32; }
        body { font-family:'Segoe UI',sans-serif; background:var(--bg); color:#fff; min-height:100vh; }
        body::before { content:''; position:fixed; inset:0; background: radial-gradient(ellipse at 50% 0%, rgba(0,255,204,0.04) 0%, transparent 60%); pointer-events:none; }

        .logout { color:#ff4d4d; text-decoration:none; font-size:0.75rem; padding:6px 10px; border-radius:6px; }

        .container { max-width:1200px; margin:0 auto; padding:40px 24px; }

        .page-title { text-align:center; margin-bottom:40px; }
        .page-title h1 { font-size:2.5rem; font-weight:900; letter-spacing:6px; text-transform:uppercase; background:linear-gradient(135deg,#fff,var(--primary)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; margin-bottom:6px; }
        .page-title p { color:#aaa; font-size:0.85rem; letter-spacing:2px; }

        .main-grid { display:grid; grid-template-columns:1fr 380px; gap:24px; align-items:start; }

        /* Tabla clasificación */
        .tabla-card { background:var(--card); border:1px solid var(--border); border-radius:20px; overflow:hidden; }
        .tabla-header { padding:20px 24px; border-bottom:1px solid var(--border); display:flex; align-items:center; justify-content:space-between; }
        .tabla-header h2 { font-size:0.85rem; font-weight:700; text-transform:uppercase; letter-spacing:3px; color:#bbb; }

        table { width:100%; border-collapse:collapse; }
        thead th { padding:12px 16px; text-align:left; font-size:0.65rem; color:#aaa; text-transform:uppercase; letter-spacing:2px; border-bottom:1px solid var(--border); background:rgba(255,255,255,0.01); }
        thead th.center { text-align:center; }
        tbody tr { transition:0.15s; }
        tbody tr:hover { background:rgba(255,255,255,0.02); }
        tbody tr.top1 { background:rgba(255,215,0,0.03); }
        tbody tr.top2 { background:rgba(192,192,192,0.02); }
        tbody tr.top3 { background:rgba(205,127,50,0.02); }
        td { padding:14px 16px; border-bottom:1px solid rgba(255,255,255,0.025); font-size:0.88rem; vertical-align:middle; }
        td.center { text-align:center; color:#bbb; }
        tbody tr:last-child td { border-bottom:none; }

        .pos-cell { font-size:1.1rem; font-weight:900; width:40px; text-align:center; }
        .pos-gold   { color:var(--gold); }
        .pos-silver { color:var(--silver); }
        .pos-bronze { color:var(--bronze); }
        .pos-other  { color:#999; }

        .equipo-cell { font-weight:700; }
        .pts-cell { font-weight:900; font-size:1rem; color:var(--primary); text-align:center; }

        .dif-cell { font-size:0.8rem; font-weight:600; text-align:center; }
        .dif-pos { color:#2ecc71; }
        .dif-neg { color:#ff4d4d; }
        .dif-neu { color:#bbb; }

        /* Jornadas */
        .jornadas-card { background:var(--card); border:1px solid var(--border); border-radius:20px; padding:24px; }
        .card-title { font-size:0.7rem; font-weight:700; color:#aaa; text-transform:uppercase; letter-spacing:3px; margin-bottom:16px; display:flex; align-items:center; gap:8px; }
        .card-title::after { content:''; flex:1; height:1px; background:var(--border); }

        .jornada-group { margin-bottom:20px; }
        .jornada-label { font-size:0.7rem; color:var(--primary); text-transform:uppercase; letter-spacing:2px; font-weight:700; margin-bottom:10px; padding-bottom:6px; border-bottom:1px solid var(--border); }

        .match-row {
            display:flex; align-items:center; gap:10px;
            padding:10px 12px; border-radius:10px;
            background:rgba(255,255,255,0.02); border:1px solid var(--border);
            margin-bottom:8px; font-size:0.85rem;
        }
        .match-equipo { flex:1; font-weight:600; }
        .match-equipo.right { text-align:right; }
        .match-score {
            min-width:50px; text-align:center;
            font-weight:900; font-size:0.95rem;
        }
        .match-score.live { color:var(--primary); }
        .match-score.done { color:#ccc; }
        .match-score.pending { color:#999; }

        .estado-dot {
            width:6px; height:6px; border-radius:50%;
            background:#333;
        }
        .estado-dot.finalizado  { background:#555; }
        .estado-dot.pendiente   { background:#ffcc00; }
        .estado-dot.en_juego    { background:var(--primary); animation:blink 1s infinite; }
        @keyframes blink { 50% { opacity:0; } }

        .no-data { text-align:center; color:#999; font-size:0.9rem; padding:30px; }

        @media (max-width:900px) { .main-grid { grid-template-columns:1fr; } }
        @media (max-width:768px) {
            .page-wrap{padding:80px 14px 40px;}
            table{font-size:0.78rem;}
            th,td{padding:8px 10px;}
        }
    </style>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Rajdhani:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/mobile.css">
    <link rel="stylesheet" href="/css/nav.css">
</head>
<body>
<div id="bg-video-wrap">
    <video id="bg-video" autoplay muted loop playsinline>
        <source src="/video/wallpaper_para_ruta-torneo.mp4" type="video/mp4">
    </video>
    <div id="bg-overlay"></div>
</div>

<nav>
    <div class="nav-logo">CLUTCH</div>
    <button class="nav-hamburger" id="nav-hamburger" aria-label="Menú">
        <span></span><span></span><span></span>
    </button>
    <div class="nav-links" id="nav-links">
        <a href="/hub" class="nav-link">Hub</a>
        <a href="/draft" class="nav-link">Draft</a>
        <a href="/clasificacion" class="nav-link active">Clasificación</a>
        <a href="/torneo" class="nav-link">Torneo</a>
        <a href="/directo" class="nav-link"><i class="fas fa-circle" style="color:#ff4d4d;font-size:0.5rem;"></i> Directo</a>
        <a href="/normas" class="nav-link">Normas</a>
        <a href="/ganadores" class="nav-link">Ganadores</a>
        <a href="/inscripciones" class="nav-link">Inscripciones</a>
        <% if (user.esAdmin) { %><a href="/admin" class="nav-link admin-lnk">Admin</a><% } %>
    </div>
    <div class="nav-user">
        <img src="<%= user.avatar %>" class="nav-avatar" alt="">
        <span class="nav-username"><%= user.username %></span>
        <a href="/logout" class="logout"><i class="fas fa-sign-out-alt"></i></a>
    </div>
</nav>

<div class="container">
    <div class="page-title">
        <h1>Clasificación</h1>
        <p>Jornada actual: <%= jornadaActual %></p>
    </div>

    <div class="main-grid">

        <!-- Tabla -->
        <div class="tabla-card">
            <div class="tabla-header">
                <h2><i class="fas fa-trophy" style="color:var(--gold);margin-right:8px;"></i> Tabla de posiciones</h2>
            </div>
            <% if (tabla.length > 0) { %>
                <table>
                    <thead>
                        <tr>
                            <th class="center">#</th>
                            <th>Equipo</th>
                            <th class="center">PJ</th>
                            <th class="center">PG</th>
                            <th class="center">PE</th>
                            <th class="center">PP</th>
                            <th class="center">GF</th>
                            <th class="center">GC</th>
                            <th class="center">DIF</th>
                            <th class="center">PTS</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% tabla.forEach((eq, i) => { %>
                            <% const dif = eq.gf - eq.gc; %>
                            <tr class="<%= i === 0 ? 'top1' : i === 1 ? 'top2' : i === 2 ? 'top3' : '' %>">
                                <td class="pos-cell <%= i === 0 ? 'pos-gold' : i === 1 ? 'pos-silver' : i === 2 ? 'pos-bronze' : 'pos-other' %>">
                                    <%= i === 0 ? '🥇' : i === 1 ? '🥈' : i === 2 ? '🥉' : i + 1 %>
                                </td>
                                <td class="equipo-cell">
    <div style="display:flex; align-items:center; gap:10px;">
        <%
            const teamData = equiposMap[eq.capitan_id];
            const logoUrl = teamData?.logo_url || null;
        %>
        <% if (logoUrl) { %>
            <img src="<%= logoUrl %>" style="width:28px; height:28px; border-radius:6px; object-fit:cover; border:1px solid rgba(255,255,255,0.1);">
        <% } else { %>
            <div style="width:28px; height:28px; border-radius:6px; background:rgba(0,255,204,0.1); display:flex; align-items:center; justify-content:center; font-size:0.7rem; color:#00ffcc; font-weight:900;">
                <%= eq.equipo_nombre.charAt(0).toUpperCase() %>
            </div>
        <% } %>
        <%= eq.equipo_nombre %>
    </div>
</td>
                                <td class="center"><%= eq.pj %></td>
                                <td class="center"><%= eq.pg %></td>
                                <td class="center"><%= eq.pe %></td>
                                <td class="center"><%= eq.pp %></td>
                                <td class="center"><%= eq.gf %></td>
                                <td class="center"><%= eq.gc %></td>
                                <td class="dif-cell <%= dif > 0 ? 'dif-pos' : dif < 0 ? 'dif-neg' : 'dif-neu' %>">
                                    <%= dif > 0 ? '+' : '' %><%= dif %>
                                </td>
                                <td class="pts-cell"><%= eq.puntos %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            <% } else { %>
                <div class="no-data">
                    <i class="fas fa-clock" style="font-size:2rem;margin-bottom:10px;display:block;"></i>
                    La clasificación estará disponible cuando comiencen los partidos.
                </div>
            <% } %>
        </div>

        <!-- Resultados por jornada -->
        <div class="jornadas-card">
            <div class="card-title"><i class="fas fa-calendar-alt"></i> Resultados</div>

            <% if (matches.length > 0) { %>
                <%
                    // Agrupar por jornada
                    const byJornada = {};
                    matches.forEach(m => {
                        if (!byJornada[m.jornada]) byJornada[m.jornada] = [];
                        byJornada[m.jornada].push(m);
                    });
                    const jornadas = Object.keys(byJornada).sort((a,b) => b - a);
                %>
                <% jornadas.forEach(j => { %>
                    <div class="jornada-group">
                        <div class="jornada-label">Jornada <%= j %></div>
                        <% byJornada[j].forEach(m => { %>
                            <div class="match-row">
                                <span class="match-equipo"><%= m.equipo1 %></span>
                                <span class="match-score <%= m.estado === 'finalizado' ? 'done' : m.estado === 'en_juego' ? 'live' : 'pending' %>">
                                    <% if (m.goles1 !== null) { %>
                                        <%= m.goles1 %> - <%= m.goles2 %>
                                    <% } else { %>
                                        vs
                                    <% } %>
                                </span>
                                <span class="match-equipo right"><%= m.equipo2 %></span>
                                <div class="estado-dot <%= m.estado %>"></div>
                                <% if (m.canal_discord) { %>
                                    <a href="https://discord.com/channels/<%= guildId %>/<%= m.canal_discord %>"
                                       target="_blank"
                                       title="Ir al canal del partido"
                                       style="color:#5865F2; font-size:0.75rem; text-decoration:none; white-space:nowrap;">
                                        <i class="fab fa-discord"></i>
                                    </a>
                                <% } %>
                            </div>
                        <% }) %>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="no-data">No hay partidos programados aún.</div>
            <% } %>
        </div>

    </div>
</div>

<script src="/socket.io/socket.io.js"></script>
<script>
    const socket = io();
    socket.on('resultado', () => setTimeout(() => location.reload(), 500));
</script>

<script>
(function(){
  var burger = document.getElementById('nav-hamburger');
  var links  = document.getElementById('nav-links');
  if(!burger) return;
  burger.addEventListener('click', function(){
    links.classList.toggle('open');
    burger.classList.toggle('open');
  });
  links.querySelectorAll('.nav-link').forEach(function(l){
    l.addEventListener('click', function(){
      links.classList.remove('open');
      burger.classList.remove('open');
    });
  });
})();
</script>
</body>
</html>
