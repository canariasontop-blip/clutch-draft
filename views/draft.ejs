/* ══════════ SOCKET LIVE ══════════ */
(function(){
    // Reutilizar el socket de main.js
    const socket = window.__clutchSocket__;
    if(!socket) return;

    // Al conectar/reconectar: servidor envía estado real (timer incluido)
    socket.on('init',function(data){
        if(window.__updateTimer__&&data?.timer!==undefined) window.__updateTimer__(data.timer);
        if(data?.turno) _actualizarTurnoBanner(data.turno);
        if(data?.estado) window.__CLUTCH__.estado = data.estado;
    });

    // Timer 100% servidor — sin intervalo local aquí
    socket.on('timer_tick',function(data){
        if(window.__updateTimer__&&data?.segundos!==undefined) window.__updateTimer__(data.segundos);
    });

    socket.on('jugador_fichado',function(data){
        if(!data?.equipo||!data?.jugador) return;
        const jug = data.jugador;

        // ── Actualizar rivalData ──
        if(!_rivalData[data.equipo]) _rivalData[data.equipo]=[];
        if(!_rivalData[data.equipo].some(j=>j.discord_id===jug.discord_id))
            _rivalData[data.equipo].push(jug);

        // ── Si es MI equipo: actualizar mi plantilla (vista capitán) ──
        if(data.equipo === window.__CLUTCH__.username && window.__CLUTCH__.esCapitan){
            if(!MIS_JUGADORES.some(j=>j.discord_id===jug.discord_id)){
                MIS_JUGADORES.push(jug);
                renderMainField();
                renderContactos(MIS_JUGADORES);
                const total=MIS_JUGADORES.length;
                const pv=document.getElementById('squad-progress-val');
                const pf=document.getElementById('picks-progress-fill');
                if(pv) pv.textContent=total+'/11';
                if(pf) pf.style.width=Math.round((total/11)*100)+'%';
                for(let i=0;i<11;i++){const s=document.getElementById('pslot-'+i);if(s)s.classList.toggle('filled',i<total);}
            }
        }

        // ── Actualizar vista espectador (team-card) en tiempo real ──
        (function actualizarVistaBechamel(){
            // team-card en spec-wrap (espectadores sin equipo)
            const teamCard=document.querySelector(`.team-card[data-capitan="${data.equipo}"]`);
            if(teamCard){
                const picksList=teamCard.querySelector('.tc-picks');
                if(picksList){
                    // Quitar mensaje "Sin picks" si existe
                    const emptyEl=picksList.querySelector('.tc-empty');
                    if(emptyEl) emptyEl.remove();
                    // Añadir pick si no está ya
                    if(!picksList.querySelector(`[data-discord-id="${jug.discord_id}"]`)){
                        const div=document.createElement('div');
                        div.className='tc-pick';
                        div.dataset.discordId=jug.discord_id;
                        div.innerHTML=`<img src="${jug.foto||'https://cdn.discordapp.com/embed/avatars/0.png'}" class="tc-pick-foto" alt=""><span class="tc-pick-nombre">${jug.eafc_id||jug.nombre}</span><span class="pos-badge-sm pos-${jug.posicion}">${jug.posicion}</span>`;
                        picksList.appendChild(div);
                    }
                }
                // Turno badge
                document.querySelectorAll('.team-card .tc-turno').forEach(b=>b.remove());
            }
            // Eliminar de spec free-list
            const specRow=document.querySelector(`#free-list .spec-row[data-discord-id="${jug.discord_id}"]`);
            if(specRow) specRow.remove();
            // Actualizar orden items turno (spec order list)
            document.querySelectorAll('.order-item').forEach(item=>{
                item.classList.remove('activo');item.classList.add('otro');
                const arrow=item.querySelector('i.fa-caret-right');if(arrow) arrow.style.display='none';
            });
            if(data.turno){
                const nextItem=document.querySelector(`.order-item[data-capitan="${data.turno}"]`);
                if(nextItem){nextItem.classList.add('activo');nextItem.classList.remove('otro');const a=nextItem.querySelector('i.fa-caret-right');if(a)a.style.display='';}
                // Actualizar turno badge en team-card espectador
                document.querySelectorAll('.team-card').forEach(c=>{
                    c.classList.remove('turno-activo');
                    const tb=c.querySelector('.tc-turno');if(tb)tb.remove();
                });
                const nextCard=document.querySelector(`.team-card[data-capitan="${data.turno}"]`);
                if(nextCard){
                    nextCard.classList.add('turno-activo');
                    const head=nextCard.querySelector('.tc-head');
                    if(head&&!head.querySelector('.tc-turno')){const span=document.createElement('span');span.className='tc-turno';span.textContent='TURNO';head.appendChild(span);}
                }
            }
        })();

        // ── Eliminar de __JUGADORES_DISPONIBLES__ (fuente de verdad del dropdown) ──
        window.__JUGADORES_DISPONIBLES__ = (window.__JUGADORES_DISPONIBLES__||[]).filter(x=>x.discord_id!==jug.discord_id);

        // ── Eliminar de libres grid ──
        const lc=document.querySelector(`#libres-grid .libre-card[data-nombre="${jug.nombre.toLowerCase()}"]`);
        if(lc){lc.remove();filtrarLibresGrid();}

        // ── Contador disponibles ──
        const cnt=document.getElementById('count');
        if(cnt) cnt.textContent=window.__JUGADORES_DISPONIBLES__.length;

        // ── Actualizar timer y turno desde el propio evento (sin esperar turno_actualizado) ──
        if(data.timer!==undefined&&window.__updateTimer__) window.__updateTimer__(data.timer);
        if(data.turno){ _actualizarTurnoBanner(data.turno); window.__CLUTCH__.turno=data.turno; }

        // ── Notif tab rivales ──
        const rivView=document.getElementById('view-rivales');
        if(!rivView?.classList.contains('active')){
            const nd=document.getElementById('tab-rivals-notif');
            if(nd){nd.classList.add('show');setTimeout(()=>nd.classList.remove('show'),3500);}
        }
        // Picks count en tarjeta mini
        const cntEl=document.getElementById('rival-picks-'+data.equipo);
        if(cntEl) cntEl.textContent=_rivalData[data.equipo].length+'/11';

        // Re-render mini
        if(rivView?.classList.contains('active')){
            const rf=RIVAL_FORMATIONS.find(t=>t.capitan===data.equipo);
            renderRivalMiniField(data.equipo, rf?.formacion||'3-1-4-2');
            if(_rivalDetalleAbierto===data.equipo) abrirDetalleRival(data.equipo);
        }
    });

    // Pick deshecho: devolver jugador a disponibles
    socket.on('pick_deshecho',function(data){
        if(!data?.equipo||!data?.jugador) return;
        const jug = data.jugador;
        // Quitar de rivalData
        if(_rivalData[data.equipo]) _rivalData[data.equipo]=_rivalData[data.equipo].filter(j=>j.discord_id!==jug.discord_id);
        // Si es mi equipo, quitar de MIS_JUGADORES
        if(data.equipo===window.__CLUTCH__.username&&window.__CLUTCH__.esCapitan){
            const idx=MIS_JUGADORES.findIndex(j=>j.discord_id===jug.discord_id);
            if(idx>-1){ MIS_JUGADORES.splice(idx,1); renderMainField(); }
        }
        // Devolver a disponibles
        if(jug.discord_id&&!window.__JUGADORES_DISPONIBLES__.some(x=>x.discord_id===jug.discord_id)){
            window.__JUGADORES_DISPONIBLES__.push(jug);
        }
        const cnt=document.getElementById('count');
        if(cnt) cnt.textContent=window.__JUGADORES_DISPONIBLES__.length;
        // Actualizar vista espectador: quitar de tc-picks, devolver a free-list
        (function deshacerVistaBechamel(){
            const teamCard=document.querySelector(`.team-card[data-capitan="${data.equipo}"]`);
            if(teamCard){
                const pickEl=teamCard.querySelector(`.tc-pick[data-discord-id="${jug.discord_id}"]`);
                if(pickEl) pickEl.remove();
                const picksList=teamCard.querySelector('.tc-picks');
                if(picksList&&!picksList.querySelector('.tc-pick')&&!picksList.querySelector('.tc-empty')){
                    const empty=document.createElement('div');empty.className='tc-empty';empty.textContent='Sin picks';picksList.appendChild(empty);
                }
            }
            const freeList=document.getElementById('free-list');
            if(freeList&&jug.discord_id&&!freeList.querySelector(`[data-discord-id="${jug.discord_id}"]`)){
                const div=document.createElement('div');
                div.className='spec-row';div.dataset.pos=jug.posicion;div.dataset.discordId=jug.discord_id;
                div.innerHTML=`<img src="${jug.foto||'https://cdn.discordapp.com/embed/avatars/0.png'}" class="spec-foto" alt=""><span class="spec-name">${jug.eafc_id||jug.nombre}</span><span class="pos-badge-sm pos-${jug.posicion}">${jug.posicion}</span>`;
                freeList.appendChild(div);
            }
        })();
        // Re-render rivales
        const rivView=document.getElementById('view-rivales');
        if(rivView?.classList.contains('active')){
            const rf=RIVAL_FORMATIONS.find(t=>t.capitan===data.equipo);
            renderRivalMiniField(data.equipo, rf?.formacion||'3-1-4-2');
        }
    });

    socket.on('turno_actualizado',function(data){
        if(!data?.turno) return;
        _actualizarTurnoBanner(data.turno);
        window.__CLUTCH__.turno=data.turno;
        // Actualizar turno bar en detalle
        const turnoBar=document.getElementById('rdp-turno-bar');
        if(turnoBar&&_rivalDetalleAbierto) turnoBar.classList.toggle('visible', data.turno===_rivalDetalleAbierto);
        // Actualizar vista espectador: team-card turno-activo y order-item
        document.querySelectorAll('.team-card').forEach(c=>{
            c.classList.remove('turno-activo');
            const tb=c.querySelector('.tc-turno');if(tb) tb.remove();
        });
        const nextCard=document.querySelector(`.team-card[data-capitan="${data.turno}"]`);
        if(nextCard){
            nextCard.classList.add('turno-activo');
            const head=nextCard.querySelector('.tc-head');
            if(head&&!head.querySelector('.tc-turno')){const span=document.createElement('span');span.className='tc-turno';span.textContent='TURNO';head.appendChild(span);}
        }
        document.querySelectorAll('.order-item').forEach(item=>{
            const esTurno=item.dataset.capitan===data.turno;
            item.classList.toggle('activo',esTurno);item.classList.toggle('otro',!esTurno);
            const arrow=item.querySelector('i.fa-caret-right');if(arrow) arrow.style.display=esTurno?'':'none';
        });
    });

    // Jugador añadido manualmente — aparece en lista de libres sin recargar
    socket.on('jugador_añadido', function(data) {
        if (!data?.discord_id || !data?.nombre || !data?.posicion) return;
        // Evitar duplicados
        if (document.querySelector(`#libres-grid .libre-card[data-discord-id="${data.discord_id}"]`)) return;
        // Añadir a __JUGADORES_DISPONIBLES__
        window.__JUGADORES_DISPONIBLES__ = window.__JUGADORES_DISPONIBLES__ || [];
        if (!window.__JUGADORES_DISPONIBLES__.find(x => x.discord_id === data.discord_id)) {
            window.__JUGADORES_DISPONIBLES__.push({ discord_id: data.discord_id, nombre: data.nombre, eafc_id: data.eafc_id || '', posicion: data.posicion, foto: '' });
        }
        // Añadir card al grid
        const grid = document.getElementById('libres-grid');
        if (grid) {
            const display = data.eafc_id || data.nombre;
            const card = document.createElement('div');
            card.className = 'libre-card not-my-turn';
            card.dataset.pos     = data.posicion;
            card.dataset.nombre  = display.toLowerCase();
            card.dataset.discordId = data.discord_id;
            card.innerHTML = `<img src="https://cdn.discordapp.com/embed/avatars/0.png" class="libre-foto" alt="">
                <div class="libre-info">
                    <div class="libre-nombre">${display}</div>
                    <span class="libre-pos-badge pos-${data.posicion}">${data.posicion}</span>
                </div>`;
            grid.appendChild(card);
            filtrarLibresGrid();
        }
        // Actualizar contador
        const countEl = document.getElementById('count');
        if (countEl) countEl.textContent = (window.__JUGADORES_DISPONIBLES__ || []).length;
    });

    socket.on('draft-cerrado',function(){
        window.__CLUTCH__.estado='cerrado';
        const pill=document.getElementById('turn-banner');
        if(pill) pill.style.display='none';
        const cerradoPill=document.querySelector('.draft-cerrado-pill');
        if(!cerradoPill){
            const el=document.createElement('div');
            el.className='draft-cerrado-pill';
            el.innerHTML='<i class="fas fa-lock" style="margin-right:6px;"></i>Draft cerrado — Todos los equipos formados';
            document.body.appendChild(el);
        }
    });

    function _actualizarTurnoBanner(turno){
        document.querySelectorAll('.rival-card').forEach(c=>c.classList.remove('turno-activo'));
        const active=document.getElementById('rival-card-'+turno);
        if(active) active.classList.add('turno-activo');
        document.querySelectorAll('.rival-turno-badge').forEach(b=>b.remove());
        if(active){
            const head=active.querySelector('.rival-card-head');
            if(head){const badge=document.createElement('span');badge.className='rival-turno-badge';badge.textContent='⚡ TURNO';head.appendChild(badge);}
        }
        const tnEl=document.getElementById('turn-nombre');
        const pill=document.getElementById('turn-banner');
        const badge=document.getElementById('mi-turno-badge');
        if(tnEl) tnEl.textContent=turno;
        // Los capitanes no pueden fichar — no hay badge "TU TURNO" funcional
        if(pill){ pill.classList.remove('mi-turno'); }
        if(badge) badge.style.display='none';
        window.__CLUTCH__.turno=turno;
    }
})();

/* ══════════ HAMBURGER MOBILE ══════════ */
(function(){
    const burger=document.getElementById('nav-hamburger');
    const links=document.getElementById('nav-links');
    if(!burger) return;
    burger.addEventListener('click',()=>{links.classList.toggle('open');burger.classList.toggle('open');});
    links.querySelectorAll('.nav-link').forEach(l=>l.addEventListener('click',()=>{links.classList.remove('open');burger.classList.remove('open');}));
})();
</script>
</body>
</html>
