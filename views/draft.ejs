function agregarJugador(j){
    if(_slotSeleccionado){
        const positions=FORMATIONS[_formacion]||[];
        let idx=0;
        for(const p of positions){if(p.pos===_slotSeleccionado.pos){if(p===_slotSeleccionado){j._slotIdx=idx;j._slotPos=p.pos;break;}idx++;}}
    }
    MIS_JUGADORES.push(j);
    window.__JUGADORES_DISPONIBLES__=window.__JUGADORES_DISPONIBLES__.filter(x=>x.discord_id!==j.discord_id);
    _slotSeleccionado=null; _posFilter=null;
    renderMainField();
    // Contador picks
    const total=MIS_JUGADORES.length;
    const pct=Math.round((total/11)*100);
    const pv=document.getElementById('squad-progress-val');
    const pf=document.getElementById('picks-progress-fill');
    if(pv) pv.textContent=total+'/11';
    if(pf) pf.style.width=pct+'%';
    // Slots visuales
    for(let i=0;i<11;i++){const s=document.getElementById('pslot-'+i);if(s)s.classList.toggle('filled',i<total);}
    // Disponibles
    const countEl=document.getElementById('count');
    if(countEl) countEl.textContent=window.__JUGADORES_DISPONIBLES__.length;
    // Eliminar de libres grid
    const libreCard=document.querySelector(`#libres-grid .libre-card[data-nombre="${j.nombre.toLowerCase()}"]`);
    if(libreCard){libreCard.remove();filtrarLibresGrid();}
}

