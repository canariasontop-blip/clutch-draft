    if(!nombre) return;
    const res=await fetch('/equipo/renombrar',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({nombre_equipo:nombre})});
    if(res.ok){
        const m=document.getElementById('msg-renombrar');m.style.display='block';setTimeout(()=>m.style.display='none',3000);
        const dn=document.getElementById('team-display-name');if(dn)dn.textContent=nombre;
    }
}
async function subirEscudo(input){
    if(!input.files?.[0]) return;
    const m=document.getElementById('msg-escudo');
    m.textContent='⏳ Subiendo...';m.style.display='block';m.style.color='#aaa';
    try{
        const fd=new FormData();fd.append('escudo',input.files[0]);
        const res=await fetch('/equipo/escudo',{method:'POST',body:fd});
        const data=await res.json();
        if(res.ok && data.logo_url){
            const el=document.getElementById('team-escudo-img');
            const url=data.logo_url+'?t='+Date.now();
            if(el.tagName==='IMG'){el.src=url;}
            else{const img=document.createElement('img');img.src=url;img.className='team-escudo';img.id='team-escudo-img';el.replaceWith(img);}
            m.textContent='✅ Actualizado';m.style.color='#00ffcc';
        } else {
            m.textContent='❌ '+(data.error||'Error al subir');m.style.color='#ff4d4d';
        }
    } catch(e){
        m.textContent='❌ Error de conexión';m.style.color='#ff4d4d';
    }
    setTimeout(()=>m.style.display='none',3000);
    input.value='';
}

