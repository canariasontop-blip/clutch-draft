        {pos:'DFC', x:78, y:64, lbl:'Central'},
        {pos:'POR', x:50, y:83, lbl:'Portero'},
    ],
};
const POS_COLORS={DC:'#00ffcc',MC:'#a066ff',CARR:'#ffcc00',DFC:'#ff4d4d',POR:'#3399ff',MCD:'#ff9900',CAM:'#a066ff',EXT:'#ffcc00'};
const POS_CLASS={DC:'fd-dc',MC:'fd-mc',CARR:'fd-carr',DFC:'fd-dfc',POR:'fd-por',MCD:'fd-mcd',CAM:'fd-cam',EXT:'fd-ext'};
const POS_MAP={DC:'DC',MC:'MC',CARR:'CARR',DFC:'DFC',POR:'POR',MCD:'MC',CAM:'MC',EXT:'CARR'};

// TOTY gradient palette por posición
const TOTY_GRADS = {
    DC:  ['#003a2e','#00c99a','#002a20'],  // verde esmeralda
    MC:  ['#1a0035','#8a44ff','#100025'],  // violeta profundo
    CARR:['#2a1a00','#d4900a','#1a1000'],  // dorado oscuro
    DFC: ['#2a0008','#cc2240','#1a0005'],  // rojo profundo
    POR: ['#001a3a','#1a6dcc','#001025'],  // azul profundo
    MCD: ['#1f0e00','#c06800','#130900'],
};

let _formacion='<%= miEquipo?.formacion||"3-1-4-2" %>';
let _posFilter=null, _pickJugador=null, _slotSeleccionado=null;

const FUT_PATH='M7,0 L47,0 Q54,0 54,7 L54,50 Q54,57 49,61 L30,64 Q27,65.5 24,64 L5,61 Q0,57 0,50 L0,7 Q0,0 7,0 Z';

// Decorative path para efecto TOTY (franja diagonal)
const TOTY_STRIPE_PATH='M0,14 L54,30 L54,24 L0,8 Z';
const TOTY_DOT_PATH='M27,60 m-4,0 a4,4 0 1,0 8,0 a4,4 0 1,0 -8,0';

function fieldToImg(fx, fy) {
    const t = fy / 100;
    const topLeft=28,topRight=72,botLeft=5,botRight=95,topY=14,botY=95;
    const leftEdge  = topLeft  + t*(botLeft  - topLeft);
    const rightEdge = topRight + t*(botRight - topRight);
    return {x: leftEdge + (fx/100)*(rightEdge - leftEdge), y: topY + t*(botY - topY)};
}

/* ══════════ TIMER ══════════ */
(function initTimer(){
    const timerEl = document.getElementById('timer');
    if(!timerEl) return;

    let seconds = 0;

    function updateDisplay(){
        if(seconds < 0) seconds = 0;
        const m = Math.floor(seconds/60), s = seconds % 60;
        timerEl.textContent = m > 0 ? m+':'+(s<10?'0':'')+s : String(seconds);
        timerEl.style.opacity = '1';
        if(seconds <= 10){ timerEl.classList.add('danger'); timerEl.classList.remove('warning'); }
        else if(seconds <= 30){ timerEl.classList.add('warning'); timerEl.classList.remove('danger'); }
        else{ timerEl.classList.remove('warning','danger'); }
    }

    // Timer 100% servidor — sin intervalo local, evita desincronización
    window.__updateTimer__ = function(s){
        seconds = parseInt(s) || 0;
        updateDisplay();
    };
})();

/* ══════════ CAMPO PRINCIPAL (TOTY cards) ══════════ */
function renderMainField(){
    const container=document.getElementById('main-field-pos');
    if(!container) return;
    container.innerHTML='';
    const positions=FORMATIONS[_formacion]||[];
    const slotMap={},sinSlot={};
    MIS_JUGADORES.forEach(j=>{
        const pos=j._slotPos||j.posicion;
        if(j._slotIdx!==undefined){slotMap[pos+'-'+j._slotIdx]=j;}
        else{if(!sinSlot[pos])sinSlot[pos]=[];sinSlot[pos].push(j);}
    });
    const cuentaPos={};
    positions.forEach((p,i)=>{
        if(!cuentaPos[p.pos])cuentaPos[p.pos]=0;
        const idx=cuentaPos[p.pos]++;
        const key=p.pos+'-'+idx;
        if(!slotMap[key]&&sinSlot[p.pos]?.length) slotMap[key]=sinSlot[p.pos].shift();
        const jug=slotMap[key];
        const {x:imgX,y:imgY}=fieldToImg(p.x,p.y);
        const scaleMin=0.55,scaleMax=1.0;
        const cardW = 7.0 * (scaleMin+(p.y/100)*(scaleMax-scaleMin));
        const dot=document.createElement('div');
        dot.className=`field-dot ${POS_CLASS[p.pos]||''}`;
        dot.style.cssText=`position:absolute;left:${imgX}%;top:${imgY}%;width:${cardW}%;aspect-ratio:54/66;transform:translate(-50%,-50%);transition:transform 0.18s,filter 0.18s;z-index:${10+Math.round(p.y/10)};cursor:${jug?'default':'pointer'};`;

        const uid=`fc${i}_${Math.random().toString(36).slice(2,6)}`;
        const color=POS_COLORS[p.pos]||'#fff';
        const grad=TOTY_GRADS[p.pos]||TOTY_GRADS.MC;
        const photo=jug
            ?`<img src="${jug.foto||'https://cdn.discordapp.com/embed/avatars/0.png'}" alt="">`
            :`<div class="dot-ph-icon"><i class="fas fa-user"></i></div>`;

        // SVG TOTY: fondo degradado oscuro + acento de color + franja diagonal + brillo superior
        dot.innerHTML=`
<svg class="dot-svg" viewBox="0 0 54 66" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="bg${uid}" x1="0" y1="0" x2="0.3" y2="1">
      <stop offset="0%" stop-color="${grad[0]}"/>
