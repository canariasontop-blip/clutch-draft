            { pos:'CARR', x:12,  y:55, label:'Carrilero Izq' },
            { pos:'DFC',  x:30,  y:60, label:'Defensa Central' },
            { pos:'DFC',  x:50,  y:63, label:'Defensa Central' },
            { pos:'DFC',  x:70,  y:60, label:'Defensa Central' },
            { pos:'CARR', x:88,  y:55, label:'Carrilero Der' },
            { pos:'POR',  x:50,  y:82, label:'Portero' },
        ],
    };

    const POS_COLORS = {
        DC:'#00ffcc', MC:'#a066ff', CARR:'#ffcc00',
        DFC:'#ff4d4d', POR:'#3399ff', MCD:'#ff9900', CAM:'#a066ff', EXT:'#ffcc00'
    };

    const POS_CLASS = {
        DC:'fd-dc', MC:'fd-mc', CARR:'fd-carr',
        DFC:'fd-dfc', POR:'fd-por', MCD:'fd-mcd', CAM:'fd-cam', EXT:'fd-ext'
    };

    let _modalJugadorId   = null;
    let _modalJugadorNom  = null;
    let _modalJugadorFoto = null;
    let _modalJugadorPos  = null; // posición real del jugador
    let _posSeleccionada  = null; // slot del campo seleccionado
    let _formacionActual  = '4-3-3';

    function abrirModalPosicion(jugadorId, jugadorNombre, jugadorFoto, jugadorPosicion) {
        _modalJugadorId   = jugadorId;
        _modalJugadorNom  = jugadorNombre;
        _modalJugadorFoto = jugadorFoto || 'https://cdn.discordapp.com/embed/avatars/0.png';
        _modalJugadorPos  = jugadorPosicion;
        _posSeleccionada  = null;

        // Construir tabs
        const tabsEl = document.getElementById('formation-tabs');
        tabsEl.innerHTML = '';
        Object.keys(FORMATIONS).forEach(f => {
            const btn = document.createElement('button');
            btn.className = 'formation-tab' + (f === _formacionActual ? ' active' : '');
            btn.textContent = f;
            btn.onclick = () => cambiarFormacion(f, btn);
            tabsEl.appendChild(btn);
        });

        renderField(_formacionActual);
        document.getElementById('pos-modal-overlay').classList.add('visible');
        resetFieldInfo();
    }

    function cerrarModalPosicion() {
        document.getElementById('pos-modal-overlay').classList.remove('visible');
        _modalJugadorId = null;
        _posSeleccionada = null;
    }

    function cambiarFormacion(f, btn) {
        _formacionActual = f;
        _posSeleccionada = null;
        document.querySelectorAll('.formation-tab').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        renderField(f);
        resetFieldInfo();
    }

    function renderField(formacion) {
        const positions = FORMATIONS[formacion] || [];
        const container = document.getElementById('field-positions');
        container.innerHTML = '';

        positions.forEach((p, i) => {
            const dot = document.createElement('div');
            dot.className = `field-dot ${POS_CLASS[p.pos] || ''}`;
            dot.style.left = p.x + '%';
            dot.style.top  = p.y + '%';
            dot.textContent = p.pos;
            dot.dataset.index = i;
            dot.dataset.pos   = p.pos;
            dot.dataset.label = p.label;
            dot.onclick = () => seleccionarSlot(i, p);
            container.appendChild(dot);
        });
    }

    function seleccionarSlot(index, posData) {
        // Deseleccionar anterior
        document.querySelectorAll('.field-dot').forEach(d => d.classList.remove('selected'));
        const dot = document.querySelector(`.field-dot[data-index="${index}"]`);
        if (dot) dot.classList.add('selected');

        _posSeleccionada = posData;

        // Mostrar info panel
        document.getElementById('field-placeholder').style.display = 'none';
        document.getElementById('field-pos-detail').style.display  = 'block';

        const color = POS_COLORS[posData.pos] || '#fff';
        document.getElementById('fpd-pos-name').textContent  = posData.pos;
        document.getElementById('fpd-pos-name').style.color  = color;
        document.getElementById('fpd-pos-label').textContent = posData.label;

        // Jugador seleccionado para fichar
        const listEl = document.getElementById('fpd-jugadores-list');
        listEl.innerHTML = `
            <div class="fpd-jugador-sel">
                <img src="${_modalJugadorFoto}" alt="">
                <div>
                    <div class="fpd-jugador-nombre">${_modalJugadorNom}</div>
                    <div class="fpd-jugador-pos">${_modalJugadorPos}</div>
                </div>
            </div>`;

        document.getElementById('btn-confirmar-pick').disabled = false;
    }

    function resetFieldInfo() {
        document.getElementById('field-placeholder').style.display = 'block';
        document.getElementById('field-pos-detail').style.display  = 'none';
        document.getElementById('btn-confirmar-pick').disabled = true;
    }

    async function confirmarPickConPosicion() {
        if (!_modalJugadorId) return;
        cerrarModalPosicion();
        // Llama a la función fichar original
        await fichar(_modalJugadorId, _modalJugadorNom);
    }

    // Override fichar para que abra el modal de posición
    const _ficharOriginal = window.fichar;
    window.ficharConModal = function(jugadorId, jugadorNombre, jugadorFoto, jugadorPosicion) {
        abrirModalPosicion(jugadorId, jugadorNombre, jugadorFoto, jugadorPosicion);
    };

    // Cerrar modal al clicar fondo
    document.getElementById('pos-modal-overlay').addEventListener('click', function(e) {
        if (e.target === this) cerrarModalPosicion();
    });

    window.__CLUTCH__ = {
        username:  '<%= user.username %>',
        esCapitan: <%= user.esCapitan ? "true" : "false" %>,
        turno:     '<%= turnoActual %>',
        estado:    '<%= draftEstado %>',
        timer:     <%= tiempoRestante %>,
    };

    async function renombrarEquipo() {
        const nombre = document.getElementById('inputNombreEquipo').value.trim();
        if (!nombre) return;

        const res = await fetch('/equipo/renombrar', {
            method:  'POST',
            headers: { 'Content-Type': 'application/json' },
            body:    JSON.stringify({ nombre_equipo: nombre })
        });

        if (res.ok) {
            const msg = document.getElementById('msg-renombrar');
            msg.style.display = 'block';
            setTimeout(() => msg.style.display = 'none', 3000);
        async function subirEscudo(input) {
    if (!input.files || !input.files[0]) return;

    const formData = new FormData();
    formData.append('escudo', input.files[0]);

    const res = await fetch('/equipo/escudo', {
        method: 'POST',
        body: formData
    });

    if (res.ok) {
        const data = await res.json();
        const msg = document.getElementById('msg-escudo');
        msg.style.display = 'block';
        setTimeout(() => {
            msg.style.display = 'none';
            location.reload();
        }, 1500);
    }
}
        }
    }
</script>
<script src="/js/main.js"></script>
</body>
</html>