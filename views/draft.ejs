        {pos:'DFC', x:50, y:64, lbl:'Central'},
        {pos:'DFC', x:78, y:64, lbl:'Central'},
        {pos:'POR', x:50, y:83, lbl:'Portero'},
    ],
    '3-1-4-2':[
        {pos:'DC',  x:33, y:8,  lbl:'Delantero'},
        {pos:'DC',  x:67, y:8,  lbl:'Delantero'},
        {pos:'CARR',x:14, y:30, lbl:'Carrilero Izq'},
        {pos:'MC',  x:37, y:30, lbl:'Mediocampista'},
        {pos:'MC',  x:63, y:30, lbl:'Mediocampista'},
        {pos:'CARR',x:86, y:30, lbl:'Carrilero Der'},
