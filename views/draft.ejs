function abrirPosDropdown(pos,slotData,dotEl,evt){
    _posFilter=pos; _slotSeleccionado=slotData;
    document.querySelectorAll('#main-field-pos .field-dot').forEach(d=>d.classList.remove('active-filter'));
    dotEl.classList.add('active-filter');
    const posReal=POS_MAP[pos]||pos;
    const disp=(window.__JUGADORES_DISPONIBLES__||[]).filter(j=>j.posicion===posReal);
    const color=POS_COLORS[pos]||'#fff';
    const esMiTurno=window.__CLUTCH__.estado==='abierto'&&window.__CLUTCH__.turno===window.__CLUTCH__.username;
    document.getElementById('pdd-title').innerHTML=`<span style="color:${color};">${pos}</span> &nbsp;·&nbsp; ${disp.length} disponible${disp.length!==1?'s':''}`;
    const list=document.getElementById('pdd-list');
    list.innerHTML='';
    if(disp.length===0){list.innerHTML=`<div class="pdd-empty">No hay ${pos} disponibles</div>`;}
    else{
        disp.forEach(j=>{
            const row=document.createElement('div');
            row.className='pdd-row';
            row.innerHTML=`<img src="${j.foto||'https://cdn.discordapp.com/embed/avatars/0.png'}" class="pdd-foto" alt=""><span class="pdd-name">${j.eafc_id||j.nombre}</span><span class="pdd-pos pos-${j.posicion}">${j.posicion}</span>${esMiTurno?'<span class="pdd-pick">⚡ Fichar</span>':''}`;
            if(esMiTurno) row.onclick=()=>{cerrarPosDropdown();ficharEnSlot(j.discord_id,j.nombre,j.foto||'',j.posicion);};
            list.appendChild(row);
        });
    }
    const dd=document.getElementById('pos-dropdown');
    const rect=dotEl.getBoundingClientRect();
    const ddW=240,ddH=Math.min(disp.length*48+60,360);
    let left=rect.right+10,top=rect.top;
    if(left+ddW>window.innerWidth-10) left=rect.left-ddW-10;
    if(top+ddH>window.innerHeight-10) top=window.innerHeight-ddH-10;
    if(top<60) top=60;
    dd.style.left=left+'px'; dd.style.top=top+'px';
    dd.classList.add('open');
}
function cerrarPosDropdown(){
    document.getElementById('pos-dropdown').classList.remove('open');
    document.querySelectorAll('#main-field-pos .field-dot').forEach(d=>d.classList.remove('active-filter'));
    _posFilter=null;
}
document.addEventListener('click',e=>{
    const dd=document.getElementById('pos-dropdown');
