<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#03030a">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Clutch Draft">
    <link rel="apple-touch-icon" href="/icon-512.png">
    <title>Clutch Draft — Draft</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="/css/mobile.css?v=6">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Rajdhani:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        *{margin:0;padding:0;box-sizing:border-box;}
        :root{
            --primary:#00ffcc;--accent:#a066ff;--gold:#f0c040;--danger:#ff4d4d;
            --bg:#03030a;--card:rgba(12,12,22,0.93);--border:rgba(255,255,255,0.07);
            --font-display:'Bebas Neue',sans-serif;--font-body:'Rajdhani',sans-serif;
            --subnav-h:44px;--nav-h:52px;
        }
        html,body{height:100%;overflow:hidden;}
        body{font-family:var(--font-body);background:var(--bg);color:#fff;}

        /* VIDEO FONDO */
        #bg-video-wrap{position:fixed;inset:0;z-index:0;overflow:hidden;pointer-events:none;}
        #bg-video{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0.22;}
        #bg-overlay{position:absolute;inset:0;background:rgba(3,3,10,0.70);}

        /* ───────── NAV PRINCIPAL ───────── */

        /* ───────── DRAFT SUB-NAV ───────── */
        .draft-subnav{
            position:fixed;top:var(--nav-h);left:0;right:0;z-index:290;
            height:var(--subnav-h);
            background:rgba(4,4,13,0.97);
            border-bottom:1px solid rgba(255,255,255,0.09);
            backdrop-filter:blur(28px);
            display:flex;align-items:stretch;
            padding:0 24px;gap:0;
        }
        .draft-tab{
            display:flex;align-items:center;gap:8px;
            padding:0 20px;
            font-size:0.68rem;font-weight:700;text-transform:uppercase;letter-spacing:1.8px;
            color:#3a3a55;cursor:pointer;border:none;background:none;
            font-family:var(--font-body);
            transition:color 0.2s;
            border-bottom:2px solid transparent;
            position:relative;white-space:nowrap;
            margin-bottom:-1px;
        }
        .draft-tab i{font-size:0.72rem;}
        .draft-tab:hover{color:#777;}
        .draft-tab.active{color:var(--primary);border-bottom-color:var(--primary);}
        .draft-tab.tab-rivales.active{color:var(--accent);border-bottom-color:var(--accent);}
        .draft-tab.tab-libres.active{color:var(--gold);border-bottom-color:var(--gold);}
        .tab-notif{width:7px;height:7px;border-radius:50%;background:#ff4d4d;position:absolute;top:10px;right:10px;display:none;}
        .tab-notif.show{display:block;animation:notifPulse 1s ease 0s 3;}
        @keyframes notifPulse{0%,100%{transform:scale(1)}50%{transform:scale(1.7)}}
        .subnav-live{display:flex;align-items:center;gap:6px;margin-left:auto;padding:0 4px;font-size:0.52rem;color:#ff4d4d;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;}
        .live-dot{width:5px;height:5px;border-radius:50%;background:#ff4d4d;flex-shrink:0;animation:blink2 1s infinite;}
        @keyframes blink2{50%{opacity:0.15}}

        /* ───────── TURN BANNER ───────── */
        .turn-pill{
            position:fixed;top:calc(var(--nav-h) + var(--subnav-h) + 10px);
            left:50%;transform:translateX(-50%);z-index:250;
            background:rgba(5,5,18,0.97);border:2px solid rgba(255,255,255,0.12);border-radius:22px;
            padding:12px 30px;display:flex;align-items:center;gap:22px;
            backdrop-filter:blur(28px);transition:0.4s;white-space:nowrap;
            box-shadow:0 10px 50px rgba(0,0,0,0.85);
        }
        .turn-pill.mi-turno{border-color:rgba(0,255,204,0.7);background:rgba(0,30,20,0.98);animation:pillGlow 2s infinite;box-shadow:0 0 60px rgba(0,255,204,0.25),0 10px 50px rgba(0,0,0,0.85);}
        @keyframes pillGlow{0%,100%{box-shadow:0 0 30px rgba(0,255,204,0.15),0 10px 50px rgba(0,0,0,0.85)}50%{box-shadow:0 0 70px rgba(0,255,204,0.45),0 10px 50px rgba(0,0,0,0.85)}}
        .turn-pill-info{display:flex;flex-direction:column;gap:3px;}
        .turn-pill-label{font-size:0.65rem;color:#666;text-transform:uppercase;letter-spacing:2.5px;line-height:1;}
        .turn-pill-name{color:var(--primary);font-size:1.15rem;font-weight:800;line-height:1;margin-top:3px;letter-spacing:0.5px;}
        .turn-pill-badge{background:rgba(0,255,204,0.2);color:var(--primary);padding:7px 18px;border-radius:999px;font-size:0.95rem;font-weight:800;letter-spacing:1px;border:2px solid rgba(0,255,204,0.45);animation:pillGlow 1.5s infinite;}
        .timer-divider{width:2px;height:56px;background:rgba(255,255,255,0.1);border-radius:2px;flex-shrink:0;}
        .timer-block{display:flex;flex-direction:column;align-items:center;gap:2px;}
        .timer-block-lbl{font-size:0.6rem;color:#555;text-transform:uppercase;letter-spacing:2px;font-weight:700;}
        .turn-pill-timer{font-family:'Bebas Neue',sans-serif;font-size:4.5rem;font-weight:900;color:#fff;min-width:90px;text-align:center;line-height:1;letter-spacing:4px;text-shadow:0 0 30px rgba(255,255,255,0.25);}
        .turn-pill-timer.warning{color:#ffcc00;text-shadow:0 0 36px rgba(255,204,0,0.6);}
        .turn-pill-timer.danger{color:#ff4d4d;text-shadow:0 0 36px rgba(255,77,77,0.7);animation:blink 0.5s infinite;}
        @keyframes blink{50%{opacity:0.2}}
        .draft-cerrado-pill{position:fixed;top:calc(var(--nav-h) + var(--subnav-h) + 10px);left:50%;transform:translateX(-50%);z-index:250;background:var(--card);border:1px solid var(--border);border-radius:999px;padding:7px 22px;font-size:0.8rem;color:#555;backdrop-filter:blur(20px);white-space:nowrap;}

        /* ───────── VIEWS CONTAINER ───────── */
        .draft-view{
            display:none;
            position:fixed;
            top:calc(var(--nav-h) + var(--subnav-h));
            left:0;right:0;bottom:0;
            z-index:1;
        }
        .draft-view.active{display:block;}

        /* ═══════════════════════════════════════
           VISTA MI EQUIPO
        ═══════════════════════════════════════ */
        #view-miequipo .field-wrap{position:absolute;inset:0;overflow:hidden;}
        #view-miequipo .field-inner{
            position:absolute;inset:0;
            background-image:url('/img/campo_de_futbol_libre.png');
            background-size:100% 100%;background-position:center;background-repeat:no-repeat;
        }
        #view-miequipo .field-positions{position:absolute;inset:0;width:100%;height:100%;overflow:visible;}

        /* Panel izquierdo Mi Equipo — más ancho y escudo grande */
        .overlay-left{
            position:absolute;top:12px;left:14px;z-index:200;
            display:flex;flex-direction:column;align-items:center;gap:8px;
            width:170px;
        }

        /* Tarjeta escudo — grande y llamativa */
        .team-hero{
            width:100%;background:rgba(8,8,20,0.92);
            border:1px solid rgba(0,255,204,0.2);border-radius:18px;
            padding:18px 14px 14px;
            backdrop-filter:blur(24px);
            box-shadow:0 0 40px rgba(0,255,204,0.08),0 12px 40px rgba(0,0,0,0.7);
            display:flex;flex-direction:column;align-items:center;gap:10px;
        }
        .team-escudo{
            width:110px;height:110px;border-radius:16px;object-fit:cover;
            border:3px solid var(--primary);
            box-shadow:0 0 32px rgba(0,255,204,0.35),0 6px 24px rgba(0,0,0,0.8);
        }
        .team-escudo-ph{
            width:110px;height:110px;border-radius:16px;
            background:rgba(0,255,204,0.04);border:2px dashed rgba(0,255,204,0.2);
            display:flex;align-items:center;justify-content:center;
            color:rgba(0,255,204,0.3);font-size:2.6rem;
        }
        .team-hero-name{
            font-family:var(--font-display);font-size:1.25rem;letter-spacing:2px;
            text-align:center;color:#fff;line-height:1.1;word-break:break-word;
            text-shadow:0 0 20px rgba(0,255,204,0.2);
        }
        .team-hero-sub{font-size:0.5rem;color:#444;text-transform:uppercase;letter-spacing:2px;}

        /* Contador picks — muy visible */
        .picks-counter{
            width:100%;
            background:linear-gradient(135deg,rgba(0,255,204,0.15),rgba(160,102,255,0.10));
            border:1px solid rgba(0,255,204,0.35);border-radius:14px;
            padding:14px 16px;backdrop-filter:blur(20px);
            box-shadow:0 4px 24px rgba(0,0,0,0.5),0 0 24px rgba(0,255,204,0.08);
        }
        .picks-counter-row{display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;}
        .picks-counter-lbl{font-size:0.65rem;color:#aaa;text-transform:uppercase;letter-spacing:2px;font-weight:700;}
        .picks-counter-val{
            font-family:var(--font-display);font-size:2rem;letter-spacing:2px;
            background:linear-gradient(135deg,var(--primary),var(--accent));
            -webkit-background-clip:text;-webkit-text-fill-color:transparent;
            line-height:1;
        }
        .picks-progress-bar{width:100%;height:8px;background:rgba(255,255,255,0.08);border-radius:4px;overflow:hidden;}
        .picks-progress-fill{height:100%;background:linear-gradient(90deg,var(--primary),var(--accent));border-radius:4px;transition:width 0.5s ease;}
        .picks-slots{display:flex;gap:4px;margin-top:10px;flex-wrap:wrap;}
        .picks-slot{
            width:14px;height:14px;border-radius:4px;
            border:1px solid rgba(255,255,255,0.15);
            background:rgba(255,255,255,0.05);
            transition:0.3s;
        }
        .picks-slot.filled{background:var(--primary);border-color:var(--primary);box-shadow:0 0 8px rgba(0,255,204,0.6);}

        /* Acciones equipo */
        .team-actions{display:flex;flex-direction:column;gap:7px;width:100%;}
        .team-action-row{display:flex;gap:5px;}
        .team-input-sm{flex:1;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.12);color:#fff;padding:8px 10px;border-radius:9px;font-size:0.82rem;font-family:var(--font-body);outline:none;min-width:0;}
        .team-input-sm:focus{border-color:rgba(0,255,204,0.4);}
        .team-btn-sm{background:var(--primary);color:#000;border:none;padding:8px 12px;border-radius:9px;font-weight:800;font-size:0.78rem;cursor:pointer;font-family:var(--font-body);white-space:nowrap;flex-shrink:0;letter-spacing:0.5px;}
        .team-btn-sm:hover{background:#fff;}
        .team-upload-sm{display:block;width:100%;text-align:center;background:rgba(255,255,255,0.05);border:1px dashed rgba(255,255,255,0.15);border-radius:9px;padding:9px 0;font-size:0.8rem;color:#777;cursor:pointer;transition:0.2s;letter-spacing:0.3px;}
        .team-upload-sm:hover{border-color:rgba(0,255,204,0.3);color:#ccc;}
        .team-msg-sm{font-size:0.72rem;color:var(--primary);display:none;text-align:center;font-weight:700;}

        /* Formación */
        .form-badge{background:rgba(8,8,20,0.9);border:1px solid var(--border);border-radius:14px;padding:12px 14px;width:100%;backdrop-filter:blur(20px);display:flex;flex-direction:column;align-items:center;gap:7px;position:relative;box-shadow:0 4px 20px rgba(0,0,0,0.5);}
        .form-badge-label{font-size:0.65rem;color:#666;text-transform:uppercase;letter-spacing:2px;font-weight:700;}
        .form-badge-val{font-family:var(--font-display);font-size:2rem;color:var(--primary);letter-spacing:3px;line-height:1;}
        .form-badge-btn{background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15);color:#ccc;font-size:0.78rem;font-weight:700;padding:7px 12px;border-radius:8px;cursor:pointer;font-family:var(--font-body);transition:0.2s;width:100%;text-align:center;letter-spacing:0.5px;}
        .form-badge-btn:hover{background:rgba(255,255,255,0.14);color:#fff;}
        .form-picker-drop{position:absolute;left:148px;top:0;background:rgba(8,8,20,0.99);border:1px solid var(--border);border-radius:12px;padding:8px;display:none;flex-direction:column;gap:4px;min-width:130px;backdrop-filter:blur(28px);z-index:400;}
        .form-picker-drop.open{display:flex;}
        .fpick{padding:5px 10px;border-radius:6px;border:1px solid var(--border);background:transparent;color:#666;font-size:0.72rem;font-weight:700;cursor:pointer;transition:0.2s;font-family:var(--font-body);text-align:left;}
        .fpick:hover{color:#fff;border-color:rgba(255,255,255,0.2);}
        .fpick.active{color:var(--primary);border-color:rgba(0,255,204,0.4);background:rgba(0,255,204,0.08);}
        .locked-badge{font-size:0.52rem;color:#ff4d4d;}

        /* Contactos WhatsApp */
        .contacts-badge{background:rgba(8,8,20,0.9);border:1px solid rgba(37,211,102,0.25);border-radius:14px;padding:12px 14px;width:100%;backdrop-filter:blur(20px);box-shadow:0 4px 20px rgba(0,0,0,0.5);}
        .contacts-badge-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;cursor:pointer;user-select:none;}
        .contacts-badge-label{font-size:0.65rem;color:#25d366;text-transform:uppercase;letter-spacing:2px;font-weight:700;}
        .contacts-badge-toggle{font-size:0.7rem;color:#444;transition:transform 0.2s;}
        .contacts-badge-toggle.open{transform:rotate(180deg);}
        .contacts-list{display:flex;flex-direction:column;gap:5px;max-height:220px;overflow-y:auto;}
        .contacts-list::-webkit-scrollbar{width:3px;}
        .contacts-list::-webkit-scrollbar-thumb{background:rgba(37,211,102,0.3);border-radius:3px;}
        .contact-row{display:flex;align-items:center;gap:8px;padding:7px 9px;border-radius:9px;background:rgba(37,211,102,0.04);border:1px solid rgba(37,211,102,0.08);}
        .contact-pos{font-size:0.52rem;font-weight:800;padding:2px 5px;border-radius:4px;flex-shrink:0;}
        .contact-name{flex:1;font-size:0.75rem;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:#ddd;}
        .contact-wa{display:flex;align-items:center;gap:4px;background:rgba(37,211,102,0.15);color:#25d366;border:1px solid rgba(37,211,102,0.3);border-radius:7px;padding:4px 9px;font-size:0.65rem;font-weight:800;text-decoration:none;flex-shrink:0;transition:0.15s;}
        .contact-wa:hover{background:rgba(37,211,102,0.28);color:#fff;}
        .contact-no-phone{font-size:0.6rem;color:#333;flex-shrink:0;}
        .contacts-empty{font-size:0.72rem;color:#333;text-align:center;padding:10px;font-style:italic;}

        /* Disponibles */
        .avail-badge{
            background:rgba(8,8,20,0.9);border:1px solid rgba(255,255,255,0.1);
            border-radius:12px;padding:10px 14px;width:100%;backdrop-filter:blur(20px);
            text-align:center;
        }
        .avail-badge-num{
            font-size:2rem;font-weight:900;font-family:var(--font-display);
            letter-spacing:2px;color:#fff;
            text-shadow:0 0 20px rgba(255,255,255,0.5);
        }
        .avail-badge-lbl{font-size:0.65rem;color:#777;text-transform:uppercase;letter-spacing:1.5px;font-weight:700;}

        /* ─── CARTAS TOTY ─── */
        .field-dot{position:absolute;transform:translate(-50%,-50%);transition:transform 0.18s,filter 0.18s;z-index:10;cursor:pointer;}
        .field-dot.active-filter{animation:cardPulse 1.5s infinite;}
        @keyframes cardPulse{0%,100%{filter:drop-shadow(0 0 7px currentColor);}50%{filter:drop-shadow(0 0 22px currentColor) drop-shadow(0 0 40px currentColor);}}
        .field-dot.occupied{cursor:default;}
        .dot-svg{position:absolute;inset:0;width:100%;height:100%;overflow:visible;filter:drop-shadow(0 6px 18px rgba(0,0,0,1));}
        /* La clase TOTY se aplica desde JS */
        .dot-photo{position:absolute;top:9%;left:50%;transform:translateX(-50%);width:56%;aspect-ratio:1/1;border-radius:50%;overflow:hidden;border:2px solid rgba(255,255,255,0.6);}
        .dot-photo img{width:100%;height:100%;object-fit:cover;}
        .dot-ph-icon{width:100%;height:100%;display:flex;align-items:center;justify-content:center;background:rgba(255,255,255,0.06);color:rgba(255,255,255,0.4);font-size:1em;}
        .dot-poslbl{position:absolute;bottom:15%;left:50%;transform:translateX(-50%);font-size:0.85em;font-weight:900;letter-spacing:1px;color:#fff;text-shadow:0 1px 6px rgba(0,0,0,1);white-space:nowrap;background:rgba(0,0,0,0.72);padding:2px 8px;border-radius:5px;}
        .dot-name{position:absolute;bottom:2%;left:50%;transform:translateX(-50%);font-size:0.55em;font-weight:800;color:#fff;white-space:nowrap;overflow:hidden;max-width:180%;text-overflow:ellipsis;text-align:center;text-shadow:0 1px 6px rgba(0,0,0,1);background:rgba(0,0,0,0.68);padding:2px 6px;border-radius:4px;}
        .fd-dc{color:#00ffcc}.fd-mc{color:#a066ff}.fd-carr{color:#ffcc00}.fd-dfc{color:#ff4d4d}.fd-por{color:#3399ff}.fd-mcd{color:#ff9900}

        /* ═══════════════════════════════════════
           VISTA RIVALES EN VIVO
        ═══════════════════════════════════════ */
        #view-rivales{overflow:hidden;}
        .rivals-page{display:flex;height:100%;overflow:hidden;}

        /* Grid de equipos */
        .rivals-grid-wrap{flex:1;overflow-y:auto;padding:16px 20px 20px;}
        .rivals-grid-wrap::-webkit-scrollbar{width:4px;}
        .rivals-grid-wrap::-webkit-scrollbar-thumb{background:var(--border);border-radius:4px;}
        .rivals-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:10px;}

        /* Tarjeta rival en grid */
        .rival-card{
            background:rgba(10,10,22,0.9);border:1px solid rgba(255,255,255,0.07);
            border-radius:14px;overflow:hidden;transition:border-color 0.2s,box-shadow 0.2s,transform 0.2s;
            backdrop-filter:blur(16px);cursor:pointer;
        }
        .rival-card:hover{border-color:rgba(160,102,255,0.4);box-shadow:0 8px 32px rgba(0,0,0,0.5);transform:translateY(-2px);}
        .rival-card.turno-activo{border-color:rgba(0,255,204,0.5);box-shadow:0 0 24px rgba(0,255,204,0.1);}
        .rival-card-head{display:flex;align-items:center;gap:9px;padding:12px 14px;border-bottom:1px solid rgba(255,255,255,0.04);}
        .rival-logo{width:32px;height:32px;border-radius:7px;object-fit:cover;border:1.5px solid rgba(255,255,255,0.12);flex-shrink:0;}
        .rival-logo-ph{width:32px;height:32px;border-radius:7px;background:rgba(255,255,255,0.04);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:0.76rem;color:#333;flex-shrink:0;}
        .rival-head-info{flex:1;min-width:0;}
        .rival-name{font-size:0.8rem;font-weight:800;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:#fff;}
        .rival-capitan{font-size:0.54rem;color:#444;margin-top:1px;}
        .rival-turno-badge{font-size:0.48rem;background:rgba(0,255,204,0.15);color:var(--primary);padding:2px 6px;border-radius:5px;font-weight:700;flex-shrink:0;white-space:nowrap;}
        .rival-picks-count{font-size:0.6rem;color:#555;font-weight:700;flex-shrink:0;}

        /* mini campo dentro de tarjeta grid */
        .rival-field{padding:7px 5px 9px;background:rgba(0,0,0,0.15);}
        .rival-field-inner{position:relative;width:100%;padding-bottom:62%;background-image:url('/img/campo_de_futbol_libre.png');background-size:100% 100%;background-position:left top;background-color:#2a5c1e;border-radius:7px;overflow:hidden;}
        .rival-pos-grid{position:absolute;inset:0;}
        .rival-dot{position:absolute;transform:translate(-50%,-50%);display:flex;flex-direction:column;align-items:center;gap:1px;}
        .rival-dot-avatar{width:20px;height:20px;border-radius:50%;border:1.5px solid rgba(255,255,255,0.5);overflow:hidden;background:rgba(255,255,255,0.08);display:flex;align-items:center;justify-content:center;font-size:0.4rem;color:rgba(255,255,255,0.3);}
        .rival-dot-avatar img{width:100%;height:100%;object-fit:cover;}
        .rival-dot-pos{font-size:0.3rem;font-weight:900;color:#fff;background:rgba(0,0,0,0.75);padding:0 3px;border-radius:2px;line-height:1.5;white-space:nowrap;}
        .rival-empty-dot{width:15px;height:15px;border-radius:50%;border:1px dashed rgba(255,255,255,0.1);background:rgba(255,255,255,0.02);}
        .rival-card-hint{font-size:0.48rem;color:#333;text-align:center;padding:5px 0 2px;font-style:italic;}

        /* Panel detalle rival — lateral deslizante */
        .rival-detail-panel{
            width:0;flex-shrink:0;overflow:hidden;
            transition:width 0.3s cubic-bezier(0.4,0,0.2,1);
            background:rgba(6,6,18,0.98);border-left:1px solid var(--border);
        }
        .rival-detail-panel.open{width:320px;}
        .rdp-inner{width:320px;height:100%;display:flex;flex-direction:column;overflow:hidden;}
        .rdp-header{
            display:flex;align-items:center;gap:10px;
            padding:16px 18px;border-bottom:1px solid var(--border);flex-shrink:0;
        }
        .rdp-logo{width:40px;height:40px;border-radius:9px;object-fit:cover;border:2px solid rgba(160,102,255,0.4);}
        .rdp-logo-ph{width:40px;height:40px;border-radius:9px;background:rgba(255,255,255,0.04);border:1px dashed var(--border);display:flex;align-items:center;justify-content:center;font-size:1rem;color:#333;}
        .rdp-header-info{flex:1;min-width:0;}
        .rdp-team-name{font-size:0.9rem;font-weight:800;color:#fff;}
        .rdp-capitan{font-size:0.55rem;color:#444;}
        .rdp-close{background:none;border:1px solid var(--border);border-radius:7px;color:#555;cursor:pointer;padding:4px 9px;font-size:0.85rem;transition:0.2s;flex-shrink:0;}
        .rdp-close:hover{color:#fff;}
        .rdp-turno-bar{display:flex;align-items:center;gap:7px;padding:8px 18px;background:rgba(0,255,204,0.06);border-bottom:1px solid rgba(0,255,204,0.1);display:none;}
        .rdp-turno-bar.visible{display:flex;}
        .rdp-turno-dot{width:6px;height:6px;border-radius:50%;background:var(--primary);animation:blink2 1s infinite;}
        .rdp-turno-txt{font-size:0.58rem;color:var(--primary);font-weight:700;text-transform:uppercase;letter-spacing:1px;}
        /* campo grande en detalle */
        .rdp-field-wrap{padding:12px 14px;flex-shrink:0;}
        .rdp-field-inner{position:relative;width:100%;padding-bottom:66%;background-image:url('/img/campo_de_futbol_libre.png');background-size:100% 100%;background-position:left top;background-color:#2a5c1e;border-radius:10px;overflow:hidden;}
        .rdp-pos-grid{position:absolute;inset:0;}
        .rdp-dot{position:absolute;transform:translate(-50%,-50%);display:flex;flex-direction:column;align-items:center;gap:2px;}
        .rdp-dot-avatar{width:28px;height:28px;border-radius:50%;border:2px solid rgba(255,255,255,0.5);overflow:hidden;background:rgba(255,255,255,0.08);}
        .rdp-dot-avatar img{width:100%;height:100%;object-fit:cover;}
        .rdp-empty-dot{width:22px;height:22px;border-radius:50%;border:1px dashed rgba(255,255,255,0.12);background:rgba(255,255,255,0.02);}
        .rdp-dot-pos{font-size:0.38rem;font-weight:900;color:#fff;background:rgba(0,0,0,0.8);padding:0 4px;border-radius:3px;line-height:1.6;white-space:nowrap;}
        /* lista jugadores en detalle */
        .rdp-players{flex:1;overflow-y:auto;padding:8px 14px 16px;display:flex;flex-direction:column;gap:5px;}
        .rdp-players::-webkit-scrollbar{width:3px;}
        .rdp-players::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px;}
        .rdp-player-row{display:flex;align-items:center;gap:9px;padding:8px 10px;border-radius:9px;background:rgba(255,255,255,0.02);border:1px solid rgba(255,255,255,0.04);}
        .rdp-pfoto{width:30px;height:30px;border-radius:50%;object-fit:cover;border:2px solid rgba(255,255,255,0.1);flex-shrink:0;}
        .rdp-pname{flex:1;font-size:0.78rem;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
        .rdp-ppos{font-size:0.56rem;font-weight:800;padding:2px 6px;border-radius:4px;flex-shrink:0;}
        .rdp-empty-msg{color:#333;font-size:0.75rem;text-align:center;padding:20px;font-style:italic;}
        .rdp-picks-header{display:flex;justify-content:space-between;align-items:center;padding:0 14px 6px;}
        .rdp-picks-title{font-size:0.52rem;color:#444;text-transform:uppercase;letter-spacing:2px;font-weight:700;}
        .rdp-picks-count{font-size:0.52rem;color:#555;font-weight:700;}

        /* ═══════════════════════════════════════
           VISTA JUGADORES LIBRES
        ═══════════════════════════════════════ */
        #view-libres{overflow:hidden;}
        .libres-layout{display:flex;flex-direction:column;height:100%;}
        .libres-toolbar{
            display:flex;align-items:center;gap:10px;
            padding:14px 20px 10px;flex-shrink:0;flex-wrap:wrap;
            border-bottom:1px solid var(--border);
            background:rgba(4,4,13,0.7);backdrop-filter:blur(12px);
        }
        .libres-search-wrap{position:relative;flex:1;min-width:180px;}
        .libres-search-wrap i{position:absolute;left:12px;top:50%;transform:translateY(-50%);color:#444;font-size:0.72rem;pointer-events:none;}
        .libres-search{width:100%;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.08);color:#fff;padding:8px 14px 8px 36px;border-radius:10px;font-size:0.78rem;font-family:var(--font-body);outline:none;transition:0.2s;}
        .libres-search:focus{border-color:rgba(0,255,204,0.3);background:rgba(0,255,204,0.03);}
        .pos-filter-pills{display:flex;gap:5px;flex-wrap:wrap;}
        .pos-pill{padding:5px 13px;border-radius:8px;border:1px solid var(--border);background:transparent;color:#3a3a55;font-size:0.64rem;font-weight:700;cursor:pointer;transition:0.2s;text-transform:uppercase;font-family:var(--font-body);}
        .pos-pill:hover{color:#888;border-color:rgba(255,255,255,0.15);}
        .pos-pill.active{color:#fff;border-color:rgba(255,255,255,0.2);background:rgba(255,255,255,0.06);}
        .pos-pill.active.pill-dc{border-color:#00ffcc;color:#00ffcc;background:rgba(0,255,204,0.08);}
        .pos-pill.active.pill-mc{border-color:#a066ff;color:#a066ff;background:rgba(160,102,255,0.08);}
        .pos-pill.active.pill-carr{border-color:#ffcc00;color:#ffcc00;background:rgba(255,204,0,0.08);}
        .pos-pill.active.pill-dfc{border-color:#ff4d4d;color:#ff4d4d;background:rgba(255,77,77,0.08);}
        .pos-pill.active.pill-por{border-color:#3399ff;color:#3399ff;background:rgba(51,153,255,0.08);}
        .libres-count-line{
            padding:10px 20px 8px;
            font-size:0.6rem;color:#3a3a55;font-weight:700;text-transform:uppercase;letter-spacing:1px;
            flex-shrink:0;
            display:flex;align-items:center;gap:6px;
        }
        .libres-count-line span{
            font-family:var(--font-display);font-size:1.1rem;letter-spacing:1px;
            background:linear-gradient(90deg,var(--gold),#ffaa00);
            -webkit-background-clip:text;-webkit-text-fill-color:transparent;
        }
        .libres-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(210px,1fr));gap:7px;padding:0 20px 20px;overflow-y:auto;flex:1;}
        .libres-grid::-webkit-scrollbar{width:4px;}
        .libres-grid::-webkit-scrollbar-thumb{background:var(--border);border-radius:4px;}
        .libre-card{
            background:rgba(10,10,22,0.88);border:1px solid rgba(255,255,255,0.06);
            border-radius:12px;padding:11px 13px;display:flex;align-items:center;gap:12px;
            transition:0.18s;cursor:pointer;backdrop-filter:blur(12px);
        }
        .libre-card:hover{border-color:rgba(0,255,204,0.3);background:rgba(0,255,204,0.04);transform:translateY(-1px);}
        .libre-card.not-my-turn{cursor:default;opacity:0.65;}
        .libre-card.not-my-turn:hover{border-color:rgba(255,255,255,0.06);background:rgba(10,10,22,0.88);transform:none;}
        .libre-foto{width:40px;height:40px;border-radius:50%;object-fit:cover;border:2px solid rgba(255,255,255,0.1);flex-shrink:0;}
        .libre-info{flex:1;min-width:0;}
        .libre-nombre{font-size:0.8rem;font-weight:800;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;color:#fff;}
        .libre-pos-badge{font-size:0.56rem;font-weight:800;padding:2px 7px;border-radius:5px;display:inline-block;margin-top:3px;}
        .libre-fichar-btn{font-size:0.58rem;font-weight:700;color:var(--primary);opacity:0;transition:0.15s;white-space:nowrap;flex-shrink:0;}
        .libre-card:hover .libre-fichar-btn{opacity:1;}
        .libres-empty{text-align:center;padding:48px;color:#2a2a2a;font-size:0.82rem;font-style:italic;grid-column:1/-1;}
        .libres-empty i{display:block;font-size:2rem;margin-bottom:10px;color:#1a1a1a;}

        /* ─── POSICIÓN BADGES ─── */
        .pos-DC{background:rgba(0,255,204,0.15);color:#00ffcc;}
        .pos-MC{background:rgba(160,102,255,0.15);color:#a066ff;}
        .pos-CARR{background:rgba(255,204,0,0.15);color:#ffcc00;}
        .pos-DFC{background:rgba(255,77,77,0.15);color:#ff4d4d;}
        .pos-POR{background:rgba(51,153,255,0.15);color:#3399ff;}
        .pos-badge-sm{font-size:0.58rem;font-weight:800;padding:3px 6px;border-radius:5px;display:inline-block;flex-shrink:0;}

        /* ─── DROPDOWN POSICIÓN (campo) ─── */
        .pos-dropdown{position:fixed;z-index:500;background:rgba(8,8,20,0.99);border:1px solid var(--border);border-radius:16px;padding:0;width:280px;max-height:420px;display:none;flex-direction:column;backdrop-filter:blur(28px);box-shadow:0 24px 70px rgba(0,0,0,0.9);overflow:hidden;}
        .pos-dropdown.open{display:flex;}
        .pdd-header{display:flex;align-items:center;justify-content:space-between;padding:12px 16px 10px;border-bottom:1px solid var(--border);flex-shrink:0;}
        .pdd-title{font-size:0.7rem;font-weight:800;text-transform:uppercase;letter-spacing:2px;}
        .pdd-close{background:rgba(255,255,255,0.06);border:1px solid var(--border);border-radius:6px;color:#555;cursor:pointer;font-size:0.9rem;padding:3px 8px;transition:0.15s;}
        .pdd-close:hover{color:#fff;}
        .pdd-list{overflow-y:auto;padding:7px 9px 9px;display:flex;flex-direction:column;gap:4px;flex:1;}
        .pdd-list::-webkit-scrollbar{width:3px;}
        .pdd-list::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px;}
        .pdd-row{display:flex;align-items:center;gap:10px;padding:9px 10px;border-radius:9px;background:rgba(255,255,255,0.02);border:1px solid transparent;cursor:pointer;transition:0.15s;}
        .pdd-row:hover{border-color:rgba(0,255,204,0.3);background:rgba(0,255,204,0.06);}
        .pdd-foto{width:34px;height:34px;border-radius:50%;object-fit:cover;flex-shrink:0;border:2px solid rgba(255,255,255,0.12);}
        .pdd-name{flex:1;font-size:0.82rem;font-weight:700;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
        .pdd-pos{font-size:0.6rem;font-weight:800;padding:3px 7px;border-radius:5px;flex-shrink:0;}
        .pdd-pick{font-size:0.64rem;color:var(--primary);font-weight:700;opacity:0;transition:0.15s;flex-shrink:0;}
        .pdd-row:hover .pdd-pick{opacity:1;}
        .pdd-empty{color:#444;font-size:0.78rem;text-align:center;padding:22px;font-style:italic;}

        /* ─── MODAL PICK ─── */
        .pos-modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.88);backdrop-filter:blur(10px);z-index:600;align-items:center;justify-content:center;}
        .pos-modal-overlay.visible{display:flex;}
        .pos-modal{background:rgba(10,10,22,0.99);border:1px solid rgba(0,255,204,0.18);border-radius:18px;padding:22px;width:min(96vw,400px);max-height:92vh;overflow-y:auto;box-shadow:0 0 80px rgba(0,255,204,0.08);}
        .pos-modal-hdr{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;}
        .pos-modal-title{font-size:0.6rem;color:var(--primary);text-transform:uppercase;letter-spacing:3px;font-weight:700;}
        .pos-modal-close{background:rgba(255,255,255,0.05);border:1px solid var(--border);border-radius:7px;color:#555;cursor:pointer;padding:4px 9px;font-size:0.82rem;transition:0.2s;}
        .pos-modal-close:hover{color:#fff;}
        .modal-ph{color:#444;font-size:0.76rem;text-align:center;}
        .modal-detail{display:none;}
        .mpd-pos{font-size:1.05rem;font-weight:900;margin-bottom:2px;}
        .mpd-lbl{font-size:0.62rem;color:#555;text-transform:uppercase;letter-spacing:2px;margin-bottom:10px;}
        .mpd-jug{display:flex;align-items:center;gap:8px;padding:9px;border-radius:8px;background:rgba(255,255,255,0.03);border:1px solid var(--border);margin-bottom:10px;}
        .mpd-jug img{width:30px;height:30px;border-radius:50%;object-fit:cover;}
        .mpd-jug-name{font-size:0.8rem;font-weight:700;}
        .mpd-jug-pos{font-size:0.6rem;color:#555;}
        .btn-confirm{width:100%;padding:10px;border-radius:9px;border:none;background:var(--primary);color:#000;font-weight:800;font-size:0.82rem;cursor:pointer;transition:0.2s;font-family:var(--font-body);letter-spacing:1px;}
        .btn-confirm:hover{background:#fff;}
        .btn-confirm:disabled{background:#1a1a1a;color:#333;cursor:not-allowed;}

        /* ─── VISTA ESPECTADOR ─── */
        .spec-wrap{position:fixed;top:calc(var(--nav-h) + var(--subnav-h));left:0;right:0;bottom:0;z-index:10;overflow-y:auto;padding:0 14px 20px;}
        .spec-layout{display:grid;grid-template-columns:1fr 270px;gap:12px;max-width:1200px;margin:0 auto;}
        .teams-tracker{background:var(--card);border:1px solid var(--border);border-radius:16px;padding:16px;backdrop-filter:blur(20px);}
        .teams-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(175px,1fr));gap:8px;}
        .team-card{background:rgba(255,255,255,0.02);border:1px solid var(--border);border-radius:10px;padding:10px;}
        .team-card.turno-activo{border-color:rgba(0,255,204,0.35);background:rgba(0,255,204,0.04);}
        .tc-head{display:flex;align-items:center;gap:6px;margin-bottom:7px;}
        .tc-logo{width:22px;height:22px;border-radius:4px;object-fit:cover;}
        .tc-logo-ph{width:22px;height:22px;border-radius:4px;background:rgba(255,255,255,0.04);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:0.56rem;color:#333;}
        .tc-name{font-size:0.72rem;font-weight:700;flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
        .tc-turno{font-size:0.5rem;background:rgba(0,255,204,0.15);color:var(--primary);padding:2px 4px;border-radius:4px;font-weight:700;}
        .tc-picks{display:flex;flex-direction:column;gap:2px;}
        .tc-pick{display:flex;align-items:center;gap:4px;padding:2px 3px;}
        .tc-pick-foto{width:12px;height:12px;border-radius:50%;object-fit:cover;}
        .tc-pick-nombre{font-size:0.62rem;flex:1;}
        .tc-empty{font-size:0.62rem;color:#2a2a2a;font-style:italic;}
        .spec-right{display:flex;flex-direction:column;gap:10px;position:sticky;top:0;}
        .panel{background:var(--card);border:1px solid var(--border);border-radius:14px;padding:14px;backdrop-filter:blur(20px);}
        .panel-title{font-size:0.56rem;color:#555;text-transform:uppercase;letter-spacing:3px;margin-bottom:10px;display:flex;align-items:center;gap:7px;}
        .panel-title::after{content:'';flex:1;height:1px;background:var(--border);}
        .order-item{display:flex;align-items:center;gap:7px;padding:5px 8px;border-radius:7px;font-size:0.72rem;font-weight:600;transition:0.2s;}
        .order-item.activo{background:rgba(0,255,204,0.08);color:var(--primary);border:1px solid rgba(0,255,204,0.2);}
        .order-item.otro{color:#444;}
        .order-num{font-size:0.55rem;color:#333;width:12px;}
        .spec-free-list{display:flex;flex-direction:column;gap:3px;max-height:260px;overflow-y:auto;}
        .spec-free-list::-webkit-scrollbar{width:3px;}
        .spec-free-list::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px;}
        .spec-row{display:flex;align-items:center;gap:7px;padding:5px 8px;border-radius:7px;background:rgba(255,255,255,0.02);border:1px solid var(--border);}
        .spec-foto{width:18px;height:18px;border-radius:50%;object-fit:cover;flex-shrink:0;}
        .spec-name{flex:1;font-size:0.7rem;font-weight:600;}
        .no-items{color:#333;font-size:0.75rem;text-align:center;padding:24px;font-style:italic;}

        /* ── MOBILE ── */
        @media(max-width:768px){
            :root{--nav-h:54px;--subnav-h:40px;}
            .draft-subnav{overflow-x:auto;gap:4px;padding:0 10px;}
            .subnav-btn{font-size:0.65rem;padding:0 12px;white-space:nowrap;flex-shrink:0;}
            /* Cap layout → columna única */
            .cap-layout{flex-direction:column;}
            /* Libres grid → 1 columna */
            .libres-grid{grid-template-columns:1fr;padding:0 12px 16px;}
            /* Spec layout → columna única */
            .spec-layout{grid-template-columns:1fr;}
            .spec-right{position:static;}
            .teams-grid{grid-template-columns:repeat(auto-fill,minmax(140px,1fr));}
            /* Rivals */
            .rivals-grid{grid-template-columns:repeat(auto-fill,minmax(140px,1fr));}
            /* Turn banner */
            .turn-banner{padding:10px 14px;font-size:0.82rem;}
        }
        @media(max-width:480px){
            .libres-grid{grid-template-columns:1fr;}
            .teams-grid{grid-template-columns:repeat(2,1fr);}
        }
    </style>
    <link rel="stylesheet" href="/css/nav.css">
</head>
<body>

<div id="bg-video-wrap">
    <video id="bg-video" autoplay muted loop playsinline>
        <source src="/video/wallpaper_para_ruta-draft.mp4" type="video/mp4">
    </video>
    <div id="bg-overlay"></div>
</div>

<!-- ───────── NAV PRINCIPAL ───────── -->
<nav>
    <div class="nav-logo">CLUTCH</div>
    <button class="nav-hamburger" id="nav-hamburger" aria-label="Menú"><span></span><span></span><span></span></button>
    <div class="nav-links" id="nav-links">
        <a href="/hub"       class="nav-link">Hub</a>
        <a href="/draft"     class="nav-link active">Draft</a>
        <a href="/torneo"    class="nav-link">Torneo</a>
        <a href="/directo"   class="nav-link"><i class="fas fa-circle" style="color:#ff4d4d;font-size:0.48rem;vertical-align:middle;margin-right:2px;"></i>Directo</a>
        <a href="/normas"    class="nav-link">Normas</a>
        <a href="/ganadores" class="nav-link">Ganadores</a>
        <a href="/inscripciones" class="nav-link">Inscripciones</a>
        <% if (user.esAdmin) { %><a href="/admin" class="nav-link admin-lnk">Admin</a><% } %>
    </div>
    <div class="nav-user">
        <img src="<%= user.avatar %>" class="nav-avatar" alt="">
        <span class="nav-username"><%= user.username %></span>
        <a href="/logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i></a>
    </div>
</nav>

<!-- ───────── DRAFT SUB-NAV ───────── -->
<div class="draft-subnav">
    <button class="draft-tab tab-miequipo active" onclick="switchTab('miequipo',this)">
        <i class="fas fa-shield-alt"></i>Mi Equipo
    </button>
    <button class="draft-tab tab-rivales" onclick="switchTab('rivales',this)">
        <i class="fas fa-users"></i>Rivales en Vivo
        <span class="tab-notif" id="tab-rivals-notif"></span>
    </button>
    <button class="draft-tab tab-libres" onclick="switchTab('libres',this)">
        <i class="fas fa-search"></i>Jugadores Libres
    </button>
    <div class="subnav-live">
        <div class="live-dot"></div>En directo
    </div>
</div>

<%
  const allPicksArr = typeof allPicks !== 'undefined' ? allPicks : [];
  // Los capitanes NO pueden fichar desde draft.ejs — solo desde draft-stream (admin)
  // Esta vista es SOLO de seguimiento para los capitanes
  const esMiTurno = false;
%>

<!-- TURN BANNER -->
<% if (draftEstado === 'abierto') { %>
<div class="turn-pill <%= turnoActual === user.username ? 'mi-turno' : '' %>" id="turn-banner">
    <div class="turn-pill-info">
        <div class="turn-pill-label">Turno</div>
        <div class="turn-pill-name" id="turn-nombre"><%= turnoActual %></div>
    </div>
    <span class="turn-pill-badge" id="mi-turno-badge" style="<%= turnoActual !== user.username ? 'display:none' : '' %>">⚡ TU TURNO</span>
    <div class="timer-divider"></div>
    <div class="timer-block">
        <div class="timer-block-lbl">Tiempo</div>
        <div class="turn-pill-timer" id="timer" style="opacity:0;">—</div>
    </div>
</div>
<% } else { %>
<div class="draft-cerrado-pill"><i class="fas fa-lock" style="margin-right:6px;"></i>Draft cerrado</div>
<% } %>

<% if (user.esCapitan) { %>

<!-- ═══════════════════════════════════
     VISTA: MI EQUIPO
═══════════════════════════════════ -->
<div class="draft-view active" id="view-miequipo">
    <div class="field-wrap">
        <div class="field-inner">
            <div class="field-positions" id="main-field-pos"></div>
        </div>
    </div>
    <!-- Panel izquierdo -->
    <div class="overlay-left">
        <!-- Escudo grande -->
        <div class="team-hero">
            <% if (miEquipo?.logo_url) { %>
                <img src="<%= miEquipo.logo_url %>" class="team-escudo" id="team-escudo-img" alt="">
            <% } else { %>
                <div class="team-escudo-ph" id="team-escudo-img"><i class="fas fa-shield-alt"></i></div>
            <% } %>
            <div class="team-hero-name" id="team-display-name"><%= miEquipo?.nombre_equipo || user.username %></div>
            <div class="team-hero-sub">Tu equipo</div>
        </div>
        <!-- Contador picks visible -->
        <div class="picks-counter">
