<div id="alerta-turno-saltado" style="display:none;position:fixed;top:20px;left:50%;transform:translateX(-50%);z-index:9999;background:#1a0000;border:2px solid #ff4444;border-radius:12px;padding:16px 24px;max-width:420px;width:90%;box-shadow:0 4px 32px rgba(255,68,68,0.4);text-align:center;">
    <div style="font-size:1.4rem;margin-bottom:4px;">⚠️</div>
    <div style="color:#ff4444;font-weight:700;font-size:1rem;margin-bottom:4px;">Turno saltado automáticamente</div>
    <div id="alerta-turno-texto" style="color:#ccc;font-size:0.85rem;margin-bottom:12px;"></div>
    <div style="display:flex;gap:8px;justify-content:center;">
        <a href="/admin" class="btn btn-warning" style="font-size:0.8rem;padding:6px 14px;">Ir al panel</a>
        <button onclick="document.getElementById('alerta-turno-saltado').style.display='none'" class="btn btn-ghost" style="font-size:0.8rem;padding:6px 14px;">Cerrar</button>
    </div>
</div>

<script>
(function(){
    const socket = io();

    function addLog(text, type) {
        const box = document.getElementById('log-box');
        if (!box) return;
        const d = document.createElement('div');
        d.className = 'log-entry' + (type ? ' ' + type : '');
        const now = new Date().toLocaleTimeString('es-ES');
        d.innerHTML = '<span>[' + now + ']</span> ' + text;
        box.prepend(d);
        while (box.children.length > 50) box.removeChild(box.lastChild);
    }

    socket.on('activity', function(msg) { addLog(msg, 'ok'); });

    socket.on('system_warning', function(data) {
        addLog('⚠️ ' + data.msg, 'warn');
        const banner = document.getElementById('sys-warn-banner');
        const txt    = document.getElementById('sys-warn-text');
        if (banner && txt) {
            txt.textContent = data.msg + ' [' + data.ts + ']';
            banner.style.display = 'block';
            setTimeout(function() { banner.style.display = 'none'; }, 60000);
        }
    });

    // Cargar avisos previos al abrir la página
    fetch('/api/admin/system-warnings').then(function(r){ return r.json(); }).then(function(list){
        list.forEach(function(w){ addLog('⚠️ ' + w.msg + ' [' + w.ts + ']', 'warn'); });
    }).catch(function(){});

    socket.on('turno_saltado', function(data) {
        document.getElementById('alerta-turno-texto').textContent =
            'El turno de ' + data.capitan + ' expiró. Usa "Forzar turno" si fue un error y quieres volver a él.';
        const alerta = document.getElementById('alerta-turno-saltado');
        alerta.style.display = 'block';
        setTimeout(function() { alerta.style.display = 'none'; }, 30000);
    });
})();
</script>

<script>
(function(){
  var burger = document.getElementById('nav-hamburger');
  var links  = document.getElementById('nav-links');
  if(!burger) return;
  burger.addEventListener('click', function(){
    links.classList.toggle('open');
    burger.classList.toggle('open');
  });
  links.querySelectorAll('.nav-link').forEach(function(l){
    l.addEventListener('click', function(){
      links.classList.remove('open');
      burger.classList.remove('open');
    });
  });
})();
</script>
<!-- Modal editar jugador -->
<div id="modal-editar-jugador" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:9999;align-items:center;justify-content:center;">
    <div style="background:#0b0b14;border:1px solid rgba(255,255,255,.1);border-radius:16px;padding:28px 28px 24px;width:340px;max-width:95vw;">
        <div style="font-family:'Bebas Neue',sans-serif;font-size:1.4rem;letter-spacing:2px;margin-bottom:18px;color:#00ffcc;">EDITAR JUGADOR</div>
        <form action="/admin/editar-jugador" method="POST">
            <input type="hidden" name="discord_id" id="edit-discord-id">
            <div style="margin-bottom:14px;">
                <label style="font-size:.72rem;color:#aaa;text-transform:uppercase;letter-spacing:1.5px;display:block;margin-bottom:6px;">Nombre</label>
                <input type="text" name="nombre" id="edit-nombre" required
                    style="width:100%;background:#111;border:1px solid #333;color:#fff;border-radius:8px;padding:9px 12px;font-size:.9rem;">
