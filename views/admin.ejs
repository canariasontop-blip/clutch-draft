                    <option value="DC">DC — Delantero</option>
                    <option value="CARR">CARR — Carrilero</option>
                    <option value="MC">MC — Mediocentro</option>
                    <option value="DFC">DFC — Defensa</option>
                    <option value="POR">POR — Portero</option>
                </select>
            </div>
            <div style="display:flex;gap:10px;">
                <button type="submit" class="btn" style="flex:1;background:#00ffcc;color:#000;font-weight:700;">Guardar</button>
                <button type="button" onclick="cerrarEditarJugador()" class="btn btn-ghost" style="flex:1;">Cancelar</button>
            </div>
        </form>
    </div>
</div>
<script>
document.querySelectorAll('.btn-editar-jugador').forEach(function(btn) {
    btn.addEventListener('click', function() {
        document.getElementById('edit-discord-id').value = btn.dataset.id;
        document.getElementById('edit-nombre').value    = btn.dataset.nombre;
        document.getElementById('edit-posicion').value  = btn.dataset.posicion;
        var m = document.getElementById('modal-editar-jugador');
        m.style.display = 'flex';
    });
});
function cerrarEditarJugador() {
    document.getElementById('modal-editar-jugador').style.display = 'none';
}
document.getElementById('modal-editar-jugador').addEventListener('click', function(e) {
    if (e.target === this) cerrarEditarJugador();
});
</script>
</body>
</html>
