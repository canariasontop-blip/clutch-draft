            <div style="display:flex; align-items:center; gap:14px; padding:12px 0;">
                <img src="<%= user.avatar %>" style="width:40px;height:40px;border-radius:50%;border:2px solid var(--primary);">
                <div>
                    <div style="font-weight:700; color:var(--primary); font-size:1rem;"><%= user.username %></div>
                    <div style="font-size:0.72rem; color:#555; margin-top:2px;">Acceso total · Intocable · No puede ser eliminado</div>
                </div>
                <span style="margin-left:auto; font-size:0.65rem; background:rgba(0,255,204,0.1); color:var(--primary); border:1px solid rgba(0,255,204,0.3); padding:4px 10px; border-radius:20px; text-transform:uppercase; letter-spacing:1px;">SUPERADMIN</span>
            </div>
        </div>

    </div>
    <% } %>

</div><!-- /page-content -->
