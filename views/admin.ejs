<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#03030a">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Clutch Draft">
    <link rel="apple-touch-icon" href="/icon-512.png">
    <title>Clutch Draft — Admin</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Rajdhani:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        /* ── VIDEO FONDO ── */
        #bg-video-wrap{position:fixed;inset:0;z-index:0;overflow:hidden;}
        #bg-video{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0.35;}
        #bg-overlay{position:absolute;inset:0;background:rgba(3,3,10,0.55);}
        /* ── CONTENIDO SOBRE EL VIDEO ── */
        nav{position:sticky!important;z-index:200!important;}
        .container,.page-wrap,.normas-hero,.normas-content,.hof-hero,.hof-content,
        .page-wrap,.turn-banner,.draft-cerrado,.cap-layout,.spec-layout,
        .page-header,.stats-row,.tabs,.tab-content,.page-body,
        .section,.controls-grid,.teams-tracker,.live-section,.stream-section,
        .proximos-section{position:relative;z-index:1;}
        /* ── BASE IGUAL QUE HUB ── */
        *{margin:0;padding:0;box-sizing:border-box;}
        :root{
            --primary:#00ffcc;--accent:#a066ff;--gold:#f0c040;--danger:#ff4d4d;
            --bg:#03030a;--card:#0b0b14;--border:rgba(255,255,255,0.06);
            --font-display:'Bebas Neue',sans-serif;--font-body:'Rajdhani',sans-serif;
        }
        html{scroll-behavior:smooth;}
        body{font-family:var(--font-body);background:var(--bg);color:#fff;min-height:100vh;overflow-x:hidden;}

        /* ── VIDEO FONDO ── */
        #bg-video-wrap{position:fixed;inset:0;z-index:0;overflow:hidden;pointer-events:none;}
        #bg-video{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:0.22;}
        #bg-overlay{position:absolute;inset:0;background:rgba(3,3,10,0.70);}

        /* ── NAV (idéntico al hub) ── */
        nav{
            position:fixed;top:0;left:0;right:0;z-index:200;
            display:flex;align-items:center;justify-content:space-between;
            padding:0 36px;height:58px;
            background:rgba(3,3,10,0.85);
            border-bottom:1px solid var(--border);
            backdrop-filter:blur(24px);
        }
        .nav-logo{
            font-family:var(--font-display);font-size:1.5rem;letter-spacing:6px;
            background:linear-gradient(135deg,var(--primary),var(--accent));
            -webkit-background-clip:text;-webkit-text-fill-color:transparent;
        }
        .nav-links{display:flex;gap:2px;align-items:center;}
        .nav-link{
            color:#666;text-decoration:none;font-size:0.78rem;font-weight:700;
            padding:6px 13px;border-radius:6px;transition:0.2s;
            text-transform:uppercase;letter-spacing:1.5px;
        }
        .nav-link:hover,.nav-link.active{color:var(--primary);background:rgba(0,255,204,0.08);}
        .nav-link.admin-lnk{color:var(--accent);}
        .nav-link.admin-lnk:hover,.nav-link.admin-lnk.active{background:rgba(160,102,255,0.1);color:var(--accent);}
        .nav-user{display:flex;align-items:center;gap:10px;}
        .nav-avatar{width:30px;height:30px;border-radius:50%;border:2px solid var(--primary);object-fit:cover;}
        .nav-username{font-size:0.82rem;font-weight:700;color:#ccc;}
        .logout-btn{color:#ff4d4d;text-decoration:none;font-size:0.75rem;padding:5px 9px;border-radius:6px;transition:0.2s;}
        .logout-btn:hover{background:rgba(255,77,77,0.1);}

        /* ── OFFSET NAV FIJO ── */
        .page-content{position:relative;z-index:1;padding-top:58px;}

        /* ── LEGIBILIDAD ── */
        .card,.panel,.section,.stat-card,.bottom-sec,.turn-banner,.draft-cerrado,
        .field-card,.field-side-panel,.teams-tracker,.team-card,.spec-right,.cap-left,
        .log-box-wrap,.norma-card,.aviso-final,.altura-cell,.alert-row{
            background:rgba(15,15,28,0.85)!important;backdrop-filter:blur(4px);
        }
        [style*="color:#444"],[style*="color: #444"]{color:#aaa!important;}
        [style*="color:#555"],[style*="color: #555"]{color:#bbb!important;}
        [style*="color:#333"],[style*="color: #333"]{color:#999!important;}
        [style*="color:#666"],[style*="color: #666"]{color:#bbb!important;}
        [style*="color:#888"],[style*="color: #888"]{color:#ccc!important;}
        [style*="color:#2a2a2a"]{color:#888!important;}

        .container { max-width:1300px; margin:0 auto; padding:32px 24px; }

        /* Título */
        .page-header { margin-bottom:32px; }
        .page-header h1 { font-size:1.6rem; font-weight:900; letter-spacing:3px; color:var(--accent); }
        .page-header p { color:#444; font-size:0.85rem; margin-top:4px; }

        /* Stats row */
        .stats-row { display:grid; grid-template-columns:repeat(5,1fr); gap:12px; margin-bottom:28px; }
        .stat-card { background:var(--card); border:1px solid var(--border); border-radius:14px; padding:18px; text-align:center; }
        .stat-num { font-size:1.8rem; font-weight:900; color:var(--primary); }
        .stat-label { font-size:0.7rem; color:#444; text-transform:uppercase; letter-spacing:2px; margin-top:4px; }

        /* Sections */
        .section { background:var(--card); border:1px solid var(--border); border-radius:18px; padding:24px; margin-bottom:20px; }
        .section.danger { border-left:4px solid var(--danger); }
        .section-title { font-size:0.75rem; font-weight:700; color:#555; text-transform:uppercase; letter-spacing:3px; margin-bottom:20px; display:flex; align-items:center; gap:8px; }
        .section-title i { color:var(--primary); }

        /* Botones */
        .btn { padding:10px 20px; border-radius:9px; border:none; font-weight:700; cursor:pointer; font-size:0.8rem; letter-spacing:1px; text-transform:uppercase; transition:0.2s; display:inline-flex; align-items:center; gap:7px; text-decoration:none; }
        .btn-primary { background:var(--primary); color:#000; }
        .btn-primary:hover { background:#fff; }
        .btn-danger { background:transparent; color:var(--danger); border:1px solid var(--danger); }
        .btn-danger:hover { background:var(--danger); color:#000; }
        .btn-warning { background:#ffcc00; color:#000; }
        .btn-warning:hover { background:#fff; }
        .btn-ghost { background:rgba(255,255,255,0.04); color:#ccc; border:1px solid var(--border); }
        .btn-ghost:hover { background:rgba(255,255,255,0.08); color:#fff; }
        .btn-accent { background:var(--accent); color:#fff; }
        .btn-accent:hover { background:#8a50e0; }

        /* Inputs */
        input[type=text], input[type=number], select {
            background:rgba(255,255,255,0.04);
            border:1px solid var(--border); color:#fff;
            padding:10px 14px; border-radius:9px; outline:none;
            font-size:0.85rem; transition:0.2s;
        }
        input:focus, select:focus { border-color:rgba(0,255,204,0.3); }
        input::placeholder { color:#333; }
        select option { background:#1a1a2e; }

        /* Log */
        .log-box {
            background:#000; padding:14px; border-radius:10px;
            font-family:'Courier New',monospace; color:var(--primary);
            height:160px; overflow-y:auto; font-size:0.8rem;
            border:1px solid #1a1a2e; display:flex; flex-direction:column-reverse;
        }
        .log-entry { border-left:2px solid var(--primary); padding-left:8px; margin-bottom:4px; }
        .log-entry span { color:#333; }
        .log-entry.warn { border-color:#ff4d4d; color:#ff9999; }
        .log-entry.warn span { color:#ff4d4d; }
        .log-entry.ok { border-color:#00ffcc; color:#aaffee; }
        #sys-warn-banner { display:none; background:rgba(255,77,77,0.15); border:1px solid #ff4d4d;
            border-radius:10px; padding:12px 18px; margin-bottom:16px; color:#ff9999; font-size:0.85rem; }
        #sys-warn-banner strong { color:#ff4d4d; }

        /* Tablas */
        table { width:100%; border-collapse:collapse; }
        th { text-align:left; color:#444; padding:10px 14px; border-bottom:1px solid var(--border); font-size:0.7rem; text-transform:uppercase; letter-spacing:2px; }
        td { padding:10px 14px; border-bottom:1px solid rgba(255,255,255,0.03); font-size:0.85rem; vertical-align:middle; }
        tr:last-child td { border-bottom:none; }
        tr:hover td { background:rgba(255,255,255,0.015); }

        /* Grid de controles */
        .controls-grid { display:grid; grid-template-columns:1fr 1fr; gap:12px; }
        .controls-grid.three { grid-template-columns:1fr 1fr 1fr; }
        .form-row { display:flex; gap:10px; align-items:flex-end; flex-wrap:wrap; }
        .form-group { display:flex; flex-direction:column; gap:6px; }
        .form-label { font-size:0.7rem; color:#444; text-transform:uppercase; letter-spacing:2px; }

        /* Tabs */
        .tabs { display:flex; gap:4px; margin-bottom:20px; border-bottom:1px solid var(--border); padding-bottom:0; }
        .tab-btn { padding:10px 20px; background:transparent; border:none; color:#444; font-size:0.8rem; font-weight:600; cursor:pointer; letter-spacing:1px; text-transform:uppercase; border-bottom:2px solid transparent; transition:0.2s; margin-bottom:-1px; }
        .tab-btn.active { color:var(--primary); border-bottom-color:var(--primary); }
        .tab-content { display:none; }
        .tab-content.active { display:block; }

        /* Search */
        .search-row { display:flex; gap:10px; margin-bottom:14px; }
        .search-input { flex:1; }

        .pos-badge { font-size:0.7rem; font-weight:700; padding:3px 8px; border-radius:5px; }
        .pos-DC   { background:rgba(0,255,204,0.15);  color:#00ffcc; }
        .pos-MC   { background:rgba(160,102,255,0.15); color:#a066ff; }
        .pos-CARR { background:rgba(255,204,0,0.15);  color:#ffcc00; }
        .pos-DFC  { background:rgba(255,77,77,0.15);  color:#ff4d4d; }
        .pos-POR  { background:rgba(51,153,255,0.15); color:#3399ff; }

        .estado-badge { font-size:0.7rem; padding:3px 8px; border-radius:5px; font-weight:600; }
        .estado-pendiente   { background:rgba(255,204,0,0.12); color:#ffcc00; }
        .estado-en_juego    { background:rgba(0,255,204,0.12); color:#00ffcc; }
        .estado-finalizado  { background:rgba(255,255,255,0.06); color:#666; }

        @media (max-width:900px) {
            .stats-row { grid-template-columns:repeat(3,1fr); }
            .controls-grid, .controls-grid.three { grid-template-columns:1fr; }
        }
    </style>
    <link rel="stylesheet" href="/css/mobile.css">
</head>
<body>
<div id="bg-video-wrap">
    <video id="bg-video" autoplay muted loop playsinline>
        <source src="/video/wallpaper_para_ruta-directo.mp4" type="video/mp4">
    </video>
    <div id="bg-overlay"></div>
</div>

<div id="bg-video-wrap">
    <video id="bg-video" autoplay muted loop playsinline>
        <source src="/video/wallpaper_para_ruta-directo.mp4" type="video/mp4">
    </video>
    <div id="bg-overlay"></div>
</div>

<div id="bg-video-wrap">
    <video id="bg-video" autoplay muted loop playsinline>
        <source src="/video/wallpaper_para_ruta-directo.mp4" type="video/mp4">
    </video>
    <div id="bg-overlay"></div>
</div>
<nav>
    <div class="nav-logo">CLUTCH</div>
    <button class="nav-hamburger" id="nav-hamburger" aria-label="Menú">
        <span></span><span></span><span></span>
    </button>
    <div class="nav-links" id="nav-links">
        <a href="/hub"       class="nav-link">Hub</a>
        <a href="/draft"     class="nav-link">Draft</a>
        <a href="/torneo"    class="nav-link">Torneo</a>
        <a href="/directo"   class="nav-link"><i class="fas fa-circle" style="color:#ff4d4d;font-size:0.5rem;"></i> Directo</a>
        <a href="/normas"    class="nav-link">Normas</a>
        <a href="/ganadores" class="nav-link">Ganadores</a>
        <a href="/inscripciones" class="nav-link">Inscripciones</a>
        <a href="/admin"     class="nav-link admin-lnk active">Admin</a>
        <a href="/draft-stream" class="nav-link" style="color:#f0c040;" target="_blank">Stream</a>
    </div>
    <div class="nav-user">
        <img src="<%= user.avatar %>" class="nav-avatar" alt="">
        <span class="nav-username"><%= user.username %></span>
        <a href="/logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i></a>
    </div>
</nav>

<div class="page-content">
<div class="container">
    <div class="page-header">
        <h1><i class="fas fa-shield-alt"></i> PANEL DE CONTROL</h1>
        <p>Control total del sistema Clutch Draft</p>
    </div>

    <!-- Banner de avisos del sistema -->
    <div id="sys-warn-banner">
        <strong>⚠️ Aviso del sistema:</strong> <span id="sys-warn-text"></span>
    </div>

    <!-- Stats -->
    <div class="stats-row">
        <div class="stat-card">
            <div class="stat-num" style="color:<%= draftEstado === 'abierto' ? 'var(--primary)' : '#444' %>">
                <%= draftEstado.toUpperCase() %>
            </div>
            <div class="stat-label">Estado</div>
        </div>
        <div class="stat-card">
            <div class="stat-num"><%= turnoActual || '—' %></div>
            <div class="stat-label">Turno actual</div>
        </div>
        <div class="stat-card">
            <div class="stat-num"><%= fichados %>/<%= total %></div>
            <div class="stat-label">Fichados</div>
        </div>
        <div class="stat-card">
            <div class="stat-num"><%= equipos.length %></div>
            <div class="stat-label">Equipos</div>
        </div>
        <div class="stat-card">
            <div class="stat-num"><%= rondaActual %></div>
            <div class="stat-label">Ronda</div>
        </div>
    </div>

    <!-- Tabs -->
    <div class="tabs">
        <button class="tab-btn active" onclick="showTab('draft', this)">Draft</button>
        <button class="tab-btn" onclick="showTab('fase2', this)">Generador de Torneo</button>
        <button class="tab-btn" onclick="showTab('jugadores', this)">Jugadores</button>
        <button class="tab-btn" onclick="showTab('capitanes', this)">Capitanes</button>
        <button class="tab-btn" onclick="showTab('equipos', this)">Equipos</button>
        <button class="tab-btn" onclick="showTab('partidos', this)">Partidos</button>
        <button class="tab-btn" onclick="showTab('sistema', this)">Sistema</button>
        <% if (esSuperAdmin) { %>
        <button class="tab-btn" onclick="showTab('admins', this)">Admins</button>
        <% } %>
    </div>

    <!-- ══ TAB: DRAFT ══ -->
    <div id="tab-draft" class="tab-content active">

        <!-- Actividad -->
        <div class="section" style="margin-bottom:20px;">
            <div class="section-title"><i class="fas fa-terminal"></i> Registro de actividad</div>
            <div class="log-box" id="log-box">
                <div class="log-entry"><span>[sistema]</span> Panel cargado y listo.</div>
            </div>
        </div>

        <!-- Controles del draft -->
        <div class="section">
            <div class="section-title"><i class="fas fa-play"></i> Control del draft</div>
            <div class="controls-grid">
                <div style="display:flex;flex-direction:column;gap:12px;">
                    <% if (draftEstado === 'cerrado') { %>
                        <form action="/admin/abrir-draft" method="POST">
                            <button type="submit" class="btn btn-primary" style="width:100%;">
                                <i class="fas fa-play"></i> ABRIR DRAFT
                            </button>
                        </form>
                    <% } else { %>
                        <form action="/admin/cerrar-draft" method="POST">
                            <button type="submit" class="btn btn-danger" style="width:100%;" onclick="return confirm('¿Cerrar el draft?')">
                                <i class="fas fa-stop"></i> CERRAR DRAFT
                            </button>
                        </form>
                    <% } %>

                    <form action="/admin/saltar-turno" method="POST">
                        <button type="submit" class="btn btn-warning" style="width:100%;" onclick="return confirm('¿Saltar turno?')">
                            <i class="fas fa-forward"></i> SALTAR TURNO
                        </button>
                    </form>

                    <% if (pendingQueue && pendingQueue.length > 0) { %>
                    <div style="background:rgba(255,153,0,0.08);border:1px solid rgba(255,153,0,0.4);border-radius:8px;padding:10px 12px;margin-bottom:8px;font-size:0.8rem;">
                        <strong style="color:#ff9900;">📋 Cola pendiente (<%= pendingQueue.length %>):</strong>
                        <span style="color:#ccc;margin-left:6px;"><%= pendingQueue.join(' → ') %></span>
                        <form action="/admin/limpiar-cola" method="POST" style="display:inline;margin-left:10px;">
                            <button type="submit" class="btn btn-ghost" style="padding:2px 8px;font-size:0.72rem;" onclick="return confirm('¿Vaciar la cola de pendientes?')">✕ Vaciar</button>
                        </form>
                    </div>
                    <% } %>
                    <form action="/admin/forzar-turno" method="POST" onsubmit="return confirm('¿Forzar el turno a este capitán? Los capitanes saltados se añadirán a la cola y recibirán su turno automáticamente.')">
                        <div style="display:flex;gap:6px;align-items:center;margin-bottom:6px;">
                            <select name="capitan" class="form-input" style="flex:1;" required>
                                <option value="">— Elegir capitán —</option>
                                <% equipos.forEach(e => { %>
                                <option value="<%= e.capitan_username %>" <%= turnoActual === e.capitan_username ? 'selected' : '' %>>
                                    <%= e.nombre_equipo || e.capitan_username %><%= turnoActual === e.capitan_username ? ' ← actual' : '' %>
                                </option>
                                <% }) %>
                            </select>
                            <select name="direccion" class="form-input" style="width:110px;flex-shrink:0;">
                                <option value="asc"  <%= direccionSnake === 'asc'  ? 'selected' : '' %>>↑ ASC</option>
                                <option value="desc" <%= direccionSnake === 'desc' ? 'selected' : '' %>>↓ DESC</option>
                            </select>
                            <button type="submit" class="btn btn-warning" style="white-space:nowrap;">
                                <i class="fas fa-hand-pointer"></i> Forzar
                            </button>
                        </div>
                        <div style="background:rgba(255,204,0,0.06);border:1px solid rgba(255,204,0,0.2);border-radius:8px;padding:10px 12px;font-size:0.75rem;line-height:1.7;color:#888;">
                            <strong style="color:#4caf50;">✅ Cola automática:</strong> si saltas capitanes hacia adelante, entran en cola y el sistema les da su turno después.<br>
                            • <strong style="color:#ccc;">Seguro:</strong> el capitán actual está colgado o hay desync en pantalla.<br>
                            • <strong style="color:#ff9900;">Riesgo:</strong> si vuelves atrás a alguien que ya pickeo, <strong>puede pickear dos veces</strong> (eso no se puede evitar automáticamente).<br>
                            • El selector <strong style="color:#ccc;">ASC/DESC</strong> corrige la dirección del snake desde ese punto.
                        </div>
                    </form>

                    <form action="/admin/deshacer-pick" method="POST">
                        <button type="submit" class="btn btn-ghost" style="width:100%;" onclick="return confirm('¿Deshacer el último pick? Si el draft estaba cerrado por completarse, se reabrirá.')">
                            <i class="fas fa-undo"></i> DESHACER ÚLTIMO PICK
                        </button>
                        <p style="color:#333; font-size:0.72rem; margin-top:5px; text-align:center;">
                            También reabre el draft si se cerró automáticamente
                        </p>
                    </form>
                </div>

                <div>
                    <div class="form-group" style="margin-bottom:16px;">
                        <label class="form-label">Tiempo por turno (segundos)</label>
                        <form action="/admin/tiempo-turno" method="POST" class="form-row">
                            <select name="segundos">
                                <option value="60"  <%= tiempoTurno == 60  ? 'selected':'' %>>1 minuto</option>
                                <option value="90"  <%= tiempoTurno == 90  ? 'selected':'' %>>90 segundos</option>
                                <option value="120" <%= tiempoTurno == 120 ? 'selected':'' %>>2 minutos</option>
                                <option value="180" <%= tiempoTurno == 180 ? 'selected':'' %>>3 minutos</option>
                                <option value="300" <%= tiempoTurno == 300 ? 'selected':'' %>>5 minutos</option>
                            </select>
                            <button type="submit" class="btn btn-accent">Aplicar</button>
                        </form>
                    </div>

                    <div style="background:rgba(255,77,77,0.05); border:1px solid rgba(255,77,77,0.2); border-radius:12px; padding:16px;">
                        <div class="form-label" style="color:var(--danger); margin-bottom:10px;">Zona de peligro</div>
                        <form action="/admin/reset-draft" method="POST" onsubmit="return confirm('⚠️ ESTO BORRARÁ TODO EL DRAFT. ¿Continuar?')">
                            <button type="submit" class="btn btn-danger" style="width:100%;">
                                <i class="fas fa-trash-alt"></i> RESETEAR TODO EL DRAFT
                            </button>
                        </form>
                        <div style="margin-top:10px;">
                            <form action="/admin/retroceder-fase" method="POST"
                                  onsubmit="return confirm('¿Volver a INSCRIPCIONES? Se borrarán todos los picks. Los jugadores quedarán libres.')">
                                <input type="hidden" name="fase_destino" value="inscripciones">
                                <button type="submit" class="btn btn-ghost" style="width:100%; margin-top:8px; border-color:rgba(255,204,0,0.3); color:#ffcc00; font-size:0.78rem;">
                                    <i class="fas fa-undo"></i> Retroceder a Inscripciones
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ══ TAB: FASE 2 ══ -->
    <div id="tab-fase2" class="tab-content">

        <!-- Inscripciones -->
        <div class="section" style="margin-bottom:20px;">
            <div class="section-title"><i class="fas fa-door-closed"></i> Inscripciones</div>
            <div class="controls-grid">
                <div style="display:flex;flex-direction:column;gap:10px;">
                    <form action="/admin/cerrar-inscripciones" method="POST"
                          onsubmit="return confirm('¿Cerrar inscripciones ahora?')">
                        <button type="submit" class="btn btn-danger" style="width:100%;">
                            <i class="fas fa-lock"></i> CERRAR INSCRIPCIONES AHORA
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Votación de precio -->
        <div class="section" style="margin-bottom:20px;">
            <div class="section-title"><i class="fas fa-euro-sign"></i> Votación de precio</div>
            <div class="controls-grid">
                <div style="display:flex;flex-direction:column;gap:10px;">
                    <p style="color:#555; font-size:0.82rem; line-height:1.6;">
                        La votación se cierra sola a los <strong style="color:#ffcc00;">20 minutos</strong> del cierre de inscripciones.<br>
                        Si necesitas cerrarla antes (porque todos ya han votado, o para agilizar), usa este botón.<br>
                        El precio ganador se guarda en la DB y se anuncia en Discord.
                    </p>
                    <form action="/admin/cerrar-votacion-precio" method="POST"
                          onsubmit="return confirm('¿Cerrar la votación de precio ahora y anunciar el ganador?')">
                        <button type="submit" class="btn btn-warning" style="width:100%;">
                            <i class="fas fa-gavel"></i> CERRAR VOTACIÓN DE PRECIO AHORA
                        </button>
                    </form>
                </div>
                <div style="background:rgba(255,204,0,0.03); border:1px solid rgba(255,204,0,0.1); border-radius:12px; padding:16px;">
                    <div class="form-label" style="margin-bottom:12px; color:#ffcc00;">¿Qué pasa al cerrar?</div>
                    <div style="display:flex;flex-direction:column;gap:8px; font-size:0.8rem; color:#555; line-height:1.5;">
                        <div><span style="color:#ffcc00;">①</span> Se cuentan votos (10€ / 15€ / 20€)</div>
                        <div><span style="color:#ffcc00;">②</span> Se anuncia el precio ganador en Discord</div>
                        <div><span style="color:#ffcc00;">③</span> Se publica el panel de confirmación de pago</div>
                        <div><span style="color:#ffcc00;">④</span> Los capitanes pulsan "He pagado" → DM al admin</div>
                        <div><span style="color:#ffcc00;">⑤</span> Admin aprueba/rechaza desde el DM de Discord</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Info de pagos -->
        <div class="section">
            <div class="section-title"><i class="fas fa-credit-card"></i> Flujo de pagos</div>
            <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:12px;">
                <div style="background:rgba(255,255,255,0.02); border-radius:10px; padding:16px; border:1px solid var(--border);">
                    <div style="font-size:0.7rem; color:#444; text-transform:uppercase; letter-spacing:2px; margin-bottom:8px;">Capitán</div>
                    <div style="font-size:0.82rem; color:#888; line-height:1.6;">
                        1. Paga por PayPal<br>
                        2. Pulsa "He pagado" en Discord<br>
                        3. Espera confirmación del admin
                    </div>
                </div>
                <div style="background:rgba(255,255,255,0.02); border-radius:10px; padding:16px; border:1px solid var(--border);">
                    <div style="font-size:0.7rem; color:#444; text-transform:uppercase; letter-spacing:2px; margin-bottom:8px;">Admin (tú)</div>
                    <div style="font-size:0.82rem; color:#888; line-height:1.6;">
                        1. Recibes DM en Discord<br>
                        2. Verificas el pago en PayPal<br>
                        3. Pulsas ✅ o ❌ en el DM
                    </div>
                </div>
                <div style="background:rgba(255,255,255,0.02); border-radius:10px; padding:16px; border:1px solid var(--border);">
                    <div style="font-size:0.7rem; color:#444; text-transform:uppercase; letter-spacing:2px; margin-bottom:8px;">Sistema</div>
                    <div style="font-size:0.82rem; color:#888; line-height:1.6;">
                        Al aprobar: rol Capitán automático<br>
                        + entrada en DB teams<br>
                        + notificación al usuario
                    </div>
                </div>
            </div>
        </div>

        <!-- ── RULETA DE CAPITANES (Draft Gratuito) ── -->
        <div class="section" style="margin-bottom:20px; border-color:rgba(160,102,255,0.3);">
            <div class="section-title">
                <i class="fas fa-crown" style="color:#a066ff;"></i>
                <span style="color:#a066ff;">Ruleta de Capitanes</span>
                <% if (draftTipo === 'gratuito') { %>
                    <span style="font-size:0.65rem;background:rgba(160,102,255,0.15);border:1px solid rgba(160,102,255,0.3);color:#a066ff;padding:3px 10px;border-radius:20px;margin-left:10px;text-transform:uppercase;letter-spacing:1px;">Gratuito activo</span>
                <% } else if (draftTipo === 'pago') { %>
                    <span style="font-size:0.65rem;background:rgba(240,192,64,0.15);border:1px solid rgba(240,192,64,0.3);color:#f0c040;padding:3px 10px;border-radius:20px;margin-left:10px;text-transform:uppercase;letter-spacing:1px;">Pago activo</span>
                <% } %>
            </div>

            <!-- Configuración manual -->
            <form action="/admin/config-ruleta-capitanes" method="POST" style="margin-bottom:16px;">
                <div style="display:grid;grid-template-columns:1fr 1fr 1fr auto;gap:8px;align-items:end;">
                    <div>
                        <label class="form-label">Nº equipos</label>
                        <input type="number" name="num_equipos" class="form-input" min="2" max="20"
                               value="<%= numEquiposManual %>" placeholder="Auto">
                    </div>
                    <div>
                        <label class="form-label">Formato</label>
                        <select name="formato" class="form-input">
                            <option value="">— Auto —</option>
                            <option value="liga4"      <%= formatoManual === 'liga4'       ? 'selected' : '' %>>Liga 4 eq.</option>
                            <option value="champions6" <%= formatoManual === 'champions6'  ? 'selected' : '' %>>Champions 6 eq.</option>
                            <option value="champions8" <%= formatoManual === 'champions8'  ? 'selected' : '' %>>Champions 8 eq.</option>
                            <option value="champions10"<%= formatoManual === 'champions10' ? 'selected' : '' %>>Champions 10 eq.</option>
                            <option value="champions12"<%= formatoManual === 'champions12' ? 'selected' : '' %>>Champions 12 eq.</option>
                        </select>
                    </div>
                    <div>
                        <label class="form-label">Caps/equipo</label>
                        <select name="caps_por_equipo" class="form-input">
                            <option value="1" <%= capsPorEquipo == 1 ? 'selected' : '' %>>1 capitán</option>
                            <option value="2" <%= capsPorEquipo == 2 ? 'selected' : '' %>>2 capitanes</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary" style="height:38px;">
                        <i class="fas fa-save"></i> Guardar
                    </button>
                </div>
                <%
                    const formatosEquipos = { liga4:4, champions6:6, champions8:8, champions10:10, champions12:12 };
                    const equiposEsperados = formatoManual ? formatosEquipos[formatoManual] : null;
                    const equiposActuales  = parseInt(numEquiposManual) || 0;
                    const hayAviso = equiposEsperados && equiposActuales && equiposEsperados !== equiposActuales;
                %>
                <% if (hayAviso) { %>
                <div style="margin-top:10px;padding:10px 14px;background:rgba(255,204,0,0.08);border:1px solid rgba(255,204,0,0.3);border-radius:8px;color:#ffcc00;font-size:0.82rem;">
                    ⚠️ El formato <strong><%= formatoManual %></strong> está diseñado para <strong><%= equiposEsperados %></strong> equipos, pero has definido <strong><%= equiposActuales %></strong>. El torneo puede funcionar pero no será el óptimo.
                </div>
                <% } %>
            </form>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                <!-- Candidatos -->
                <div>
                    <div style="font-size:0.7rem;color:#666;text-transform:uppercase;letter-spacing:2px;margin-bottom:10px;">
                        Candidatos (<%= candidatosCapitan.filter(c => !c.confirmado).length %>)
                    </div>
                    <% if (candidatosCapitan.filter(c => !c.confirmado).length === 0) { %>
                        <div style="color:#333;font-size:0.82rem;font-style:italic;">Sin candidatos aún.</div>
                    <% } else { %>
                    <div style="display:flex;flex-direction:column;gap:6px;">
                    <% candidatosCapitan.filter(c => !c.confirmado).forEach(c => { %>
                        <div style="display:flex;align-items:center;gap:8px;padding:8px 12px;background:rgba(160,102,255,0.06);border:1px solid rgba(160,102,255,0.15);border-radius:8px;">
                            <span style="flex:1;font-size:0.82rem;color:#ccc;"><%= c.eafc_id || c.nombre %>
                                <% if (c.forzado) { %><span style="font-size:0.65rem;color:#ffcc00;margin-left:6px;">⭐ forzado</span><% } %>
                            </span>
                            <form action="/admin/quitar-candidato-capitan" method="POST" style="margin:0;">
                                <input type="hidden" name="discord_id" value="<%= c.discord_id %>">
                                <button type="submit" class="btn" style="padding:4px 10px;font-size:0.65rem;background:rgba(255,77,77,0.1);border-color:rgba(255,77,77,0.3);color:#ff4d4d;">✕</button>
                            </form>
                        </div>
                    <% }); %>
                    </div>
                    <% } %>

                    <!-- Forzar candidato -->
                    <div style="margin-top:12px;">
                        <div style="font-size:0.7rem;color:#666;text-transform:uppercase;letter-spacing:2px;margin-bottom:8px;">Añadir candidato manualmente</div>
                        <form action="/admin/forzar-candidato-capitan" method="POST" style="display:flex;gap:8px;">
                            <select name="discord_id" class="form-input" style="flex:1;">
                                <option value="">— Selecciona jugador —</option>
                                <% jugadores.forEach(j => { %>
                                    <% const yaEsCandidato = candidatosCapitan.some(c => c.discord_id === j.discord_id); %>
                                    <option value="<%= j.discord_id %>" <%= yaEsCandidato ? 'disabled' : '' %>>
                                        <%= j.eafc_id || j.nombre %> (<%= j.posicion %>)<%= yaEsCandidato ? ' ✓' : '' %>
                                    </option>
                                <% }); %>
                            </select>
                            <button type="submit" class="btn btn-primary" style="height:38px;white-space:nowrap;">
                                <i class="fas fa-plus"></i> Añadir
                            </button>
                        </form>
                    </div>
                </div>

                <!-- Capitanes confirmados -->
                <div>
                    <%
                        const nConfirmadosAdmin = candidatosCapitan.filter(c => c.confirmado).length;
                        const totalNecAdmin     = numEquiposManual ? parseInt(numEquiposManual) * parseInt(capsPorEquipo) : 0;
                        const faltanAdmin       = totalNecAdmin > 0 ? Math.max(0, totalNecAdmin - nConfirmadosAdmin) : 0;
                    %>
                    <div style="font-size:0.7rem;color:#666;text-transform:uppercase;letter-spacing:2px;margin-bottom:10px;display:flex;align-items:center;gap:10px;">
                        Capitanes confirmados
                        <% if (totalNecAdmin > 0) { %>
                            <span style="font-size:0.72rem;padding:2px 10px;border-radius:20px;
                                background:<%= faltanAdmin === 0 ? 'rgba(0,255,204,0.12)' : 'rgba(255,204,0,0.1)' %>;
                                border:1px solid <%= faltanAdmin === 0 ? 'rgba(0,255,204,0.3)' : 'rgba(255,204,0,0.3)' %>;
                                color:<%= faltanAdmin === 0 ? '#00ffcc' : '#ffcc00' %>;">
                                <%= nConfirmadosAdmin %> / <%= totalNecAdmin %>
                                <%= faltanAdmin > 0 ? ' — faltan ' + faltanAdmin : ' ✓' %>
                            </span>
                        <% } else { %>
                            (<%= nConfirmadosAdmin %>)
                        <% } %>
                    </div>
                    <% if (nConfirmadosAdmin === 0) { %>
                        <div style="color:#333;font-size:0.82rem;font-style:italic;">Ninguno aún — usa la Ruleta para confirmar.</div>
                    <% } else { %>
                    <div style="display:flex;flex-direction:column;gap:6px;">
                    <% candidatosCapitan.filter(c => c.confirmado).forEach((c, i) => { %>
                        <div style="padding:8px 12px;background:rgba(0,255,204,0.05);border:1px solid rgba(0,255,204,0.15);border-radius:8px;font-size:0.82rem;color:#ccc;">
                            <span style="color:var(--primary);font-weight:700;margin-right:8px;">#<%= i+1 %></span>
                            <%= c.eafc_id || c.nombre %>
                        </div>
                    <% }); %>
                    </div>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Torneo -->
        <div class="section" style="margin-bottom:20px;">
            <div class="section-title"><i class="fas fa-trophy"></i> Generador de torneo</div>
            <div class="controls-grid">
                <div style="display:flex;flex-direction:column;gap:10px;">
                    <p style="color:#555; font-size:0.82rem; line-height:1.6;">
                        Genera automáticamente el calendario, los canales privados por partido
                        y anuncia el torneo en Discord.<br>
                        El formato se decide según el nº de equipos registrados.<br>
                        <strong style="color:var(--primary);">Asegúrate de tener los capitanes registrados antes de generar.</strong>
                    </p>
                    <form action="/admin/generar-torneo" method="POST"
                          onsubmit="return confirm('¿Generar el torneo ahora? Se crearán todos los partidos y canales privados en Discord.')">
                        <button type="submit" class="btn btn-primary" style="width:100%;">
                            <i class="fas fa-trophy"></i> GENERAR TORNEO
                        </button>
                    </form>
                    <form action="/admin/actualizar-clasificacion" method="POST">
                        <button type="submit" class="btn btn-ghost" style="width:100%;">
                            <i class="fas fa-sync-alt"></i> Actualizar clasificación en Discord
                        </button>
                    </form>
                    <form action="/admin/recrear-canales-partido" method="POST"
                          onsubmit="return confirm('¿Recrear los canales de partido que faltan en Discord? Solo crea los que no tienen canal asignado.')">
                        <button type="submit" class="btn btn-ghost" style="width:100%;">
                            <i class="fas fa-wrench"></i> Recrear canales de partido faltantes
                        </button>
                    </form>
                </div>
                <div style="background:rgba(0,255,204,0.03); border:1px solid rgba(0,255,204,0.1); border-radius:12px; padding:16px;">
                    <div class="form-label" style="margin-bottom:12px; color:var(--primary);">Formatos por nº de equipos</div>
                    <div style="display:flex;flex-direction:column;gap:6px; font-size:0.8rem; color:#555;">
                        <div><span style="color:var(--primary);">4 eq.</span> → Liga Swiss 3 jornadas (sin playoffs)</div>
                        <div><span style="color:var(--primary);">6 eq.</span> → Liga 4J + Semis + Final (corte top 4)</div>
                        <div><span style="color:var(--primary);">8 eq.</span> → Liga 3J + Cuartos (3-6) + Semis + Final</div>
                        <div><span style="color:var(--primary);">10 eq.</span> → Liga 3J + Cuartos (3-6) + Semis + Final</div>
                        <div><span style="color:var(--primary);">12 eq.</span> → Liga 4J + Play-offs (5-12) + Cuartos + Semis + Final</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- ── CONTROL MANUAL DE FASES ── -->
        <div class="section" style="margin-bottom:20px; border-color:rgba(51,153,255,0.25);">
            <div class="section-title">
                <i class="fas fa-sliders-h" style="color:#3399ff;"></i>
                <span style="color:#3399ff;">Control manual del torneo</span>
            </div>
            <p style="color:#555; font-size:0.82rem; line-height:1.6; margin-bottom:14px;">
                Si hubo un problema al generar una fase automáticamente, puedes forzarla aquí.<br>
                <strong style="color:#3399ff;">Solo usar si la siguiente fase no se generó correctamente.</strong>
            </p>
            <div style="display:flex;flex-direction:column;gap:10px;">
                <form action="/admin/forzar-siguiente-fase" method="POST"
                      onsubmit="return confirm('¿Forzar la generación de la siguiente fase ahora? Asegúrate de que todos los partidos de la fase actual estén finalizados.')">
                    <button type="submit" class="btn" style="width:100%;background:rgba(51,153,255,0.12);border:1px solid rgba(51,153,255,0.3);color:#3399ff;">
                        <i class="fas fa-forward"></i> FORZAR SIGUIENTE FASE
                    </button>
                </form>
                <form action="/admin/set-fase-torneo" method="POST"
                      onsubmit="return confirm('¿Establecer la fase manualmente?')"
                      style="display:flex;gap:8px;flex-wrap:wrap;">
                    <select name="fase" class="form-input" style="flex:1;min-width:120px;">
                        <option value="">— Fase —</option>
                        <option value="liga">liga</option>
                        <option value="playoffs">playoffs</option>
                        <option value="cuartos">cuartos</option>
                        <option value="semis">semis</option>
                        <option value="final">final</option>
                    </select>
                    <input type="number" name="jornada" placeholder="Nº jornada" min="1" max="20"
                           class="form-input" style="width:110px;">
                    <button type="submit" class="btn btn-ghost" style="border-color:rgba(51,153,255,0.3);color:#3399ff;">
                        <i class="fas fa-pencil-alt"></i> Aplicar
                    </button>
                </form>
            </div>
        </div>

        <!-- ── RETROCEDER FASE (nuevo) ── -->
        <div class="section" style="margin-bottom:20px; border-color:rgba(255,204,0,0.2);">
            <div class="section-title">
                <i class="fas fa-undo-alt" style="color:#ffcc00;"></i>
                <span style="color:#ffcc00;">Retroceder a fase anterior</span>
            </div>
            <p style="color:#555; font-size:0.82rem; line-height:1.6; margin-bottom:14px;">
                Si ocurre un error en cualquier fase, puedes volver manualmente a la fase anterior.<br>
                <strong style="color:#ffcc00;">Úsalo solo si es necesario — cada acción puede implicar pérdida parcial de datos.</strong>
            </p>
            <div style="display:flex; flex-direction:column; gap:10px;">
                <form action="/admin/retroceder-fase" method="POST"
                      onsubmit="return confirm('⚠️ ¿Volver a la fase PRE-TORNEO? Se borrarán los partidos y la clasificación. Los jugadores y equipos se mantienen.')">
                    <input type="hidden" name="fase_destino" value="pre-torneo">
                    <button type="submit" class="btn btn-warning" style="width:100%;">
                        <i class="fas fa-undo"></i> VOLVER A PRE-TORNEO <small style="opacity:0.6;">(borra partidos, mantiene equipos)</small>
                    </button>
                </form>
                <form action="/admin/retroceder-fase" method="POST"
                      onsubmit="return confirm('⚠️ ¿Volver al DRAFT? Se reabrirá el draft en el estado actual. Los picks se mantienen.')">
                    <input type="hidden" name="fase_destino" value="draft">
                    <button type="submit" class="btn btn-ghost" style="width:100%; border-color:rgba(255,204,0,0.3); color:#ffcc00;">
                        <i class="fas fa-undo"></i> VOLVER AL DRAFT <small style="opacity:0.6;">(mantiene picks actuales)</small>
                    </button>
                </form>
                <form action="/admin/retroceder-fase" method="POST"
                      onsubmit="return confirm('⚠️ ¿Volver a INSCRIPCIONES? Se borrarán TODOS los picks y los jugadores quedarán libres. Los equipos se mantienen vacíos.')">
                    <input type="hidden" name="fase_destino" value="inscripciones">
                    <button type="submit" class="btn btn-ghost" style="width:100%; border-color:rgba(255,204,0,0.3); color:#ffcc00;">
                        <i class="fas fa-undo"></i> VOLVER A INSCRIPCIONES <small style="opacity:0.6;">(borra todos los picks)</small>
                    </button>
                </form>
            </div>
        </div>

        <!-- Borrar datos de prueba -->
        <div class="section" style="margin-bottom:20px; border-color:rgba(255,153,0,0.3);">
            <div class="section-title">
                <i class="fas fa-robot" style="color:#ff9900;"></i>
                <span style="color:#ff9900;">Datos de prueba (bots)</span>
            </div>
            <div class="controls-grid">
                <div style="display:flex;flex-direction:column;gap:10px;">
                    <p style="color:#555; font-size:0.82rem; line-height:1.6;">
                        Elimina todos los jugadores y equipos generados con el seed de prueba
                        (<code style="color:#ff9900;">BOT_CAP_*</code>, <code style="color:#ff9900;">P_DC_*</code>, <code style="color:#ff9900;">P_MC_*</code>…).
                        Los jugadores y equipos <strong style="color:#888;">reales no se tocan</strong>.
                    </p>
                    <form action="/admin/borrar-bots" method="POST"
                          onsubmit="return confirm('¿Borrar todos los datos de prueba (bots)? Los jugadores y equipos reales no se tocan.')">
                        <button type="submit" class="btn" style="width:100%;background:transparent;color:#ff9900;border:1px solid #ff9900;">
                            <i class="fas fa-robot"></i> BORRAR DATOS DE PRUEBA
                        </button>
                    </form>
                </div>
                <div style="background:rgba(255,153,0,0.03); border:1px solid rgba(255,153,0,0.1); border-radius:12px; padding:16px;">
                    <div class="form-label" style="margin-bottom:12px; color:#ff9900;">Qué se borra</div>
                    <div style="display:flex;flex-direction:column;gap:6px; font-size:0.8rem; color:#555;">
                        <div><span style="color:#ff4d4d;">✗</span> Jugadores bot (<code>P_DC_*</code>, <code>P_MC_*</code>, <code>P_CA_*</code>, <code>P_DF_*</code>, <code>P_PO_*</code>)</div>
                        <div><span style="color:#ff4d4d;">✗</span> Equipos bot (<code>BOT_CAP_*</code>) y su clasificación</div>
                        <div><span style="color:#ff4d4d;">✗</span> Picks asociados a esos equipos</div>
                        <div><span style="color:#2ecc71;">✓</span> Jugadores reales intactos</div>
                        <div><span style="color:#2ecc71;">✓</span> Equipos reales y su clasificación intactos</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Limpieza -->
        <div class="section danger" style="margin-bottom:20px;">
            <div class="section-title">
                <i class="fas fa-exclamation-triangle" style="color:var(--danger);"></i>
                <span style="color:var(--danger);">Limpieza de torneo</span>
            </div>
            <div class="controls-grid">
                <div style="display:flex;flex-direction:column;gap:10px;">
                    <p style="color:#555; font-size:0.82rem; line-height:1.6;">
                        Limpieza completa del torneo: borra canales de Discord, partidos, clasificación,
                        picks y libera a los jugadores de sus equipos.<br>
                        Los <strong style="color:#888;">jugadores registrados se mantienen</strong> para el siguiente torneo (solo se eliminan sus equipos asignados).
                    </p>
                    <form action="/admin/limpiar-torneo" method="POST"
                          onsubmit="return confirm('⚠️ ¿Limpiar el torneo? Se borrarán canales de Discord, partidos, picks y clasificación. Los jugadores quedan libres para el siguiente torneo.')">
                        <button type="submit" class="btn btn-danger" style="width:100%;">
                            <i class="fas fa-trash-alt"></i> LIMPIAR TORNEO
                        </button>
                    </form>
                </div>
                <div style="background:rgba(255,77,77,0.03); border:1px solid rgba(255,77,77,0.1); border-radius:12px; padding:16px;">
                    <div class="form-label" style="margin-bottom:12px; color:var(--danger);">Qué se borra</div>
                    <div style="display:flex;flex-direction:column;gap:6px; font-size:0.8rem; color:#555;">
                        <div><span style="color:var(--danger);">✗</span> Canales privados de partidos (Discord)</div>
                        <div><span style="color:var(--danger);">✗</span> Mensajes: calendario, clasificación, fichajes, equipos-ids</div>
                        <div><span style="color:var(--danger);">✗</span> Tabla de matches y picks en la DB</div>
                        <div><span style="color:var(--danger);">✗</span> Equipos y clasificación</div>
                        <div><span style="color:var(--danger);">✗</span> Asignación de equipo de cada jugador</div>
                        <div><span style="color:#2ecc71;">✓</span> Los jugadores siguen registrados (listos para re-draftear)</div>
                        <div><span style="color:#2ecc71;">✓</span> El historial de ganadores se conserva</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ══ TAB: JUGADORES ══ -->
    <div id="tab-jugadores" class="tab-content">

        <div class="section" style="margin-bottom:20px; border-color:rgba(0,255,204,0.2);">
            <div class="section-title"><i class="fas fa-user-plus"></i> Añadir jugador manualmente</div>
            <p style="color:#666; font-size:0.8rem; margin-bottom:16px;">
                Añade jugadores aunque las inscripciones estén cerradas. Si el Discord ID ya existe, actualiza sus datos.
            </p>
            <form action="/admin/agregar-jugador-manual" method="POST" class="form-row" style="flex-wrap:wrap; gap:12px;">
                <div class="form-group">
                    <label class="form-label">Discord ID <span style="color:#ff4d4d;">*</span></label>
                    <input type="text" name="discord_id" placeholder="123456789012345678" required style="width:210px;">
                </div>
                <div class="form-group">
                    <label class="form-label">Username <span style="color:#ff4d4d;">*</span></label>
                    <input type="text" name="nombre" placeholder="nombre_usuario" required style="width:160px;">
                </div>
                <div class="form-group">
                    <label class="form-label">Posición <span style="color:#ff4d4d;">*</span></label>
                    <select name="posicion" required style="width:100px;">
                        <option value="">—</option>
                        <option value="POR">POR</option>
                        <option value="DFC">DFC</option>
                        <option value="CARR">CARR</option>
                        <option value="MC">MC</option>
                        <option value="DC">DC</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Teléfono</label>
                    <input type="text" name="telefono" placeholder="600000000" style="width:140px;">
                </div>
                <div class="form-group">
                    <label class="form-label">EA FC ID</label>
                    <input type="text" name="eafc_id" placeholder="Nombre#1234" style="width:150px;">
                </div>
                <button type="submit" class="btn btn-primary" style="align-self:flex-end;">
                    <i class="fas fa-user-plus"></i> Añadir jugador
                </button>
            </form>
        </div>

        <div class="section">
            <div class="section-title"><i class="fas fa-users"></i> Jugadores registrados (<%= total %>)</div>
            <div class="search-row">
                <input type="text" class="search-input" placeholder="Buscar jugador..." oninput="filtrarJugadores(this.value)">
            </div>
            <div style="max-height:500px; overflow-y:auto;">
                <table id="tabla-jugadores">
                    <thead>
                        <tr>
                            <th>Jugador</th><th>Posición</th><th>Teléfono</th><th>Equipo</th><th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% jugadores.forEach(j => { %>
                        <tr>
                            <td style="font-weight:600;"><%= j.eafc_id || j.nombre %><% if(j.eafc_id){ %><br><span style="font-size:0.72rem;color:#555;font-weight:400;"><%= j.nombre %></span><% } %></td>
                            <td><span class="pos-badge pos-<%= j.posicion %>"><%= j.posicion %></span></td>
                            <td style="color:#555; font-size:0.8rem;"><%= j.telefono || '—' %></td>
                            <td style="color:<%= j.equipo ? 'var(--primary)' : '#444' %>; font-size:0.85rem;">
                                <%= j.equipo || 'Libre' %>
                            </td>
                            <td>
                                <div style="display:flex; gap:6px;">
                                    <% if (j.equipo) { %>
                                        <form action="/admin/liberar-jugador" method="POST" style="display:inline;">
                                            <input type="hidden" name="discord_id" value="<%= j.discord_id %>">
                                            <button type="submit" class="btn btn-ghost" style="padding:5px 10px; font-size:0.7rem;">Liberar</button>
                                        </form>
                                    <% } %>
                                    <button type="button" class="btn btn-ghost btn-editar-jugador"
                                        style="padding:5px 10px;font-size:0.7rem;border-color:rgba(0,255,204,0.3);color:#00ffcc;"
                                        data-id="<%= j.discord_id %>"
                                        data-nombre="<%= j.nombre %>"
                                        data-posicion="<%= j.posicion %>">
                                        <i class="fas fa-pen"></i>
                                    </button>
                                    <form action="/admin/borrar-jugador" method="POST" style="display:inline;" onsubmit="return confirm('¿Borrar a <%= j.nombre %>?')">
                                        <input type="hidden" name="discord_id" value="<%= j.discord_id %>">
                                        <button type="submit" class="btn btn-danger" style="padding:5px 10px; font-size:0.7rem;">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- ══ TAB: CAPITANES ══ -->
    <div id="tab-capitanes" class="tab-content">
        <div class="section" style="margin-bottom:20px;">
            <div class="section-title"><i class="fas fa-crown"></i> Registrar capitán</div>
            <form action="/admin/registrar-capitan" method="POST" class="form-row">
                <div class="form-group">
                    <label class="form-label">Discord ID</label>
                    <input type="text" name="capitan_id" placeholder="123456789012345678" required style="width:220px;">
                </div>
                <div class="form-group">
                    <label class="form-label">Username exacto</label>
                    <input type="text" name="capitan_username" placeholder="username" required style="width:180px;">
                </div>
                <button type="submit" class="btn btn-primary" style="align-self:flex-end;">
                    <i class="fas fa-plus"></i> Añadir
                </button>
            </form>
        </div>

        <div class="section">
            <div class="section-title"><i class="fas fa-list"></i> Capitanes registrados (<%= equipos.length %>)</div>
            <table>
                <thead>
                    <tr><th>#</th><th>Capitán</th><th>Jugadores fichados</th><th>Acciones</th></tr>
                </thead>
                <tbody>
                    <% equipos.forEach((eq, i) => { %>
                        <% const nJugadores = jugadores.filter(j => j.equipo === eq.capitan_username).length; %>
                        <tr>
                            <td style="color:#444;"><%= i+1 %></td>
                            <td style="font-weight:700; color:var(--primary);"><%= eq.capitan_username %></td>
                            <td><%= nJugadores %> jugadores</td>
                            <td>
                                <form action="/admin/eliminar-capitan" method="POST" style="display:inline;" onsubmit="return confirm('¿Eliminar a <%= eq.capitan_username %>?')">
                                    <input type="hidden" name="capitan_id" value="<%= eq.capitan_id %>">
                                    <button type="submit" class="btn btn-danger" style="padding:5px 10px; font-size:0.7rem;">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>

    <!-- ══ TAB: EQUIPOS ══ -->
    <div id="tab-equipos" class="tab-content">

        <!-- ── Sección: Paneles por equipo ── -->
        <div class="section" style="margin-bottom:20px;">
            <div class="section-title"><i class="fas fa-users"></i> Gestión de equipos (<%= equipos.length %>)</div>

            <% if (equipos.length === 0) { %>
            <p style="color:#555; text-align:center; padding:20px;">No hay equipos registrados.</p>
            <% } %>

            <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(320px,1fr)); gap:14px; margin-top:12px;">
            <% equipos.forEach(eq => {
                const miembros = jugadores.filter(j => j.equipo === eq.capitan_username);
            %>
            <div style="background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.08); border-radius:12px; padding:14px;">

                <!-- Cabecera equipo -->
                <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:10px;">
                    <div>
                        <div style="font-size:1rem; font-weight:700; color:var(--primary);">
                            <%= eq.nombre_equipo || eq.capitan_username %>
                        </div>
                        <div style="font-size:0.75rem; color:#666; margin-top:2px;">
                            👤 Cap: <span style="color:#ccc;"><%= eq.capitan_username %></span>
                            <% if (eq.capitan2_username) { %>
                            &nbsp;·&nbsp; 👑 2º: <span style="color:#a066ff;"><%= eq.capitan2_username %></span>
                            <% } %>
                        </div>
                    </div>
                    <div style="font-size:0.75rem; color:#555;"><%= miembros.length %> jugadores</div>
                </div>

                <!-- Asignar 2º capitán -->
                <details style="margin-bottom:8px;">
                    <summary style="font-size:0.75rem; color:#888; cursor:pointer; padding:4px 0; user-select:none;">
                        👑 Asignar / cambiar 2º capitán
                    </summary>
                    <form action="/admin/asignar-capitan2" method="POST" style="margin-top:6px; display:flex; flex-direction:column; gap:5px;">
                        <input type="hidden" name="equipo_id" value="<%= eq.id %>">
                        <input type="text" name="discord_id" placeholder="Discord ID" style="background:#111;border:1px solid #333;color:#fff;padding:5px 8px;border-radius:6px;font-size:0.75rem;" value="<%= eq.capitan2_id || '' %>">
                        <input type="text" name="username" placeholder="Username" style="background:#111;border:1px solid #333;color:#fff;padding:5px 8px;border-radius:6px;font-size:0.75rem;" value="<%= eq.capitan2_username || '' %>">
                        <div style="display:flex; gap:5px;">
                            <button type="submit" class="btn btn-accent" style="flex:1; padding:5px; font-size:0.72rem;">
                                <i class="fas fa-save"></i> Guardar
                            </button>
                            <button type="submit" name="discord_id" value="" class="btn btn-ghost" style="padding:5px 10px; font-size:0.72rem;" onclick="this.form.querySelector('[name=username]').value=''; this.form.querySelector('[name=discord_id]').value='';" title="Quitar 2º cap">
                                <i class="fas fa-times"></i>
                            </button>
                        </div>
                    </form>
                </details>

                <!-- Lista de jugadores -->
                <div style="max-height:180px; overflow-y:auto; margin-bottom:8px;">
                    <% if (miembros.length === 0) { %>
                    <div style="color:#444; font-size:0.75rem; text-align:center; padding:8px 0;">Sin jugadores fichados</div>
                    <% } %>
                    <% miembros.forEach(j => { %>
                    <div style="display:flex; align-items:center; justify-content:space-between; padding:4px 0; border-bottom:1px solid rgba(255,255,255,0.04);">
                        <div>
                            <span style="font-size:0.8rem; color:#ddd;"><%= j.nombre %></span>
                            <span style="font-size:0.7rem; color:#555; margin-left:5px;"><%= j.posicion %></span>
                        </div>
                        <form action="/admin/liberar-jugador" method="POST" style="display:inline;" onsubmit="return confirm('¿Liberar a <%= j.nombre %>?')">
                            <input type="hidden" name="discord_id" value="<%= j.discord_id %>">
                            <input type="hidden" name="redirect_to" value="/admin#tab-equipos">
                            <button type="submit" class="btn btn-ghost" style="padding:2px 7px; font-size:0.65rem; color:#ff4d4d; border-color:rgba(255,77,77,0.3);" title="Liberar jugador">
                                <i class="fas fa-user-minus"></i>
                            </button>
                        </form>
                    </div>
                    <% }) %>
                </div>

                <!-- Añadir jugador libre a este equipo -->
                <details>
                    <summary style="font-size:0.75rem; color:#888; cursor:pointer; padding:4px 0; user-select:none;">
                        ➕ Añadir jugador libre
                    </summary>
                    <form action="/admin/mover-jugador-equipo" method="POST" style="margin-top:6px; display:flex; gap:5px;">
                        <input type="hidden" name="equipo" value="<%= eq.capitan_username %>">
                        <select name="discord_id" style="flex:1; background:#111; border:1px solid #333; color:#fff; padding:5px 8px; border-radius:6px; font-size:0.75rem;">
                            <option value="">— Jugador libre —</option>
                            <% jugadores.filter(j => !j.equipo).forEach(j => { %>
                            <option value="<%= j.discord_id %>"><%= j.nombre %> (<%= j.posicion %>)</option>
                            <% }) %>
                        </select>
                        <button type="submit" class="btn btn-primary" style="padding:5px 10px; font-size:0.72rem;" title="Añadir al equipo">
                            <i class="fas fa-plus"></i>
                        </button>
                    </form>
                </details>
            </div>
            <% }) %>
            </div>
        </div>

        <!-- ── Sección: Mover jugador entre equipos ── -->
        <div class="controls-grid two" style="margin-bottom:20px;">
            <div class="section">
                <div class="section-title"><i class="fas fa-exchange-alt"></i> Mover jugador a equipo</div>
                <form action="/admin/mover-jugador-equipo" method="POST">
                    <div class="form-group" style="margin-bottom:10px;">
                        <label class="form-label">Jugador</label>
                        <select name="discord_id" style="width:100%; background:#111; border:1px solid #333; color:#fff; padding:8px; border-radius:6px;">
                            <option value="">— Seleccionar jugador —</option>
                            <% jugadores.forEach(j => { %>
                            <option value="<%= j.discord_id %>"><%= j.nombre %> (<%= j.posicion %>)<%= j.equipo ? ' · ' + j.equipo : ' · libre' %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="form-group" style="margin-bottom:14px;">
                        <label class="form-label">Destino</label>
                        <select name="equipo" style="width:100%; background:#111; border:1px solid #333; color:#fff; padding:8px; border-radius:6px;">
                            <option value="">— Liberar (sin equipo) —</option>
                            <% equipos.forEach(e => { %>
                            <option value="<%= e.capitan_username %>"><%= e.nombre_equipo || e.capitan_username %></option>
                            <% }) %>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-primary" style="width:100%;">
                        <i class="fas fa-exchange-alt"></i> Mover
                    </button>
                </form>
            </div>

            <!-- ── Sección: Control de roles Discord ── -->
            <div class="section">
                <div class="section-title"><i class="fab fa-discord"></i> Roles Discord</div>
                <p style="color:#666; font-size:0.78rem; margin-bottom:14px; line-height:1.5;">
                    Da o quita el rol de capitán en Discord directamente desde aquí sin necesidad de ir al servidor.
                </p>
                <form action="/admin/dar-rol-capitan" method="POST" style="margin-bottom:12px;">
                    <div class="form-group" style="margin-bottom:8px;">
                        <label class="form-label" style="color:var(--primary);">✅ Dar rol capitán</label>
                        <div style="display:flex; gap:6px;">
                            <input type="text" name="discord_id" placeholder="Discord ID" required style="flex:1; background:#111; border:1px solid #333; color:#fff; padding:8px; border-radius:6px; font-size:0.82rem;">
                            <button type="submit" class="btn btn-primary" style="padding:8px 14px;">
                                <i class="fas fa-plus"></i>
                            </button>
                        </div>
                    </div>
                </form>
                <form action="/admin/quitar-rol-capitan" method="POST">
                    <div class="form-group" style="margin-bottom:8px;">
                        <label class="form-label" style="color:var(--danger);">🚫 Quitar rol capitán</label>
                        <div style="display:flex; gap:6px;">
                            <input type="text" name="discord_id" placeholder="Discord ID" required style="flex:1; background:#111; border:1px solid #333; color:#fff; padding:8px; border-radius:6px; font-size:0.82rem;">
                            <button type="submit" class="btn btn-danger" style="padding:8px 14px;">
                                <i class="fas fa-minus"></i>
                            </button>
                        </div>
                    </div>
                </form>

                <!-- Lista de capitanes con sus Discord IDs -->
                <div style="margin-top:16px; border-top:1px solid var(--border); padding-top:12px;">
                    <div style="font-size:0.78rem; color:#666; margin-bottom:8px; font-weight:600; letter-spacing:1px; text-transform:uppercase;">IDs de capitanes</div>
                    <% equipos.forEach(eq => { %>
                    <div style="display:flex; justify-content:space-between; align-items:center; padding:4px 0; border-bottom:1px solid rgba(255,255,255,0.03); font-size:0.78rem;">
                        <span style="color:var(--primary); font-weight:600;"><%= eq.capitan_username %></span>
                        <span style="color:#444; font-family:monospace; font-size:0.7rem;"><%= eq.capitan_id %></span>
                    </div>
                    <% }) %>
                </div>
            </div>
        </div>

    </div>

    <!-- ══ TAB: PARTIDOS ══ -->
    <div id="tab-partidos" class="tab-content">
        <div class="controls-grid three" style="margin-bottom:20px;">
            <!-- Crear enfrentamiento -->
            <div class="section">
                <div class="section-title"><i class="fas fa-plus"></i> Crear enfrentamiento</div>
                <form action="/admin/crear-match" method="POST">
                    <div class="form-group" style="margin-bottom:10px;">
                        <label class="form-label">Equipo local</label>
                        <select name="equipo1" style="width:100%;">
                            <% equipos.forEach(e => { %>
                                <option value="<%= e.capitan_username %>"><%= e.capitan_username %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="form-group" style="margin-bottom:10px;">
                        <label class="form-label">Equipo visitante</label>
                        <select name="equipo2" style="width:100%;">
                            <% equipos.forEach(e => { %>
                                <option value="<%= e.capitan_username %>"><%= e.capitan_username %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="form-group" style="margin-bottom:14px;">
                        <label class="form-label">Jornada</label>
                        <input type="number" name="jornada" value="<%= jornadaActual %>" min="1" style="width:100%;">
                    </div>
                    <button type="submit" class="btn btn-primary" style="width:100%;">
                        <i class="fas fa-plus"></i> Crear
                    </button>
                </form>
            </div>

            <!-- Cargar resultado -->
            <div class="section">
                <div class="section-title"><i class="fas fa-flag-checkered"></i> Cargar resultado</div>
                <form action="/admin/resultado-match" method="POST">
                    <div class="form-group" style="margin-bottom:10px;">
                        <label class="form-label">Partido</label>
                        <select name="match_id" style="width:100%;">
                            <% matches.filter(m => m.estado !== 'finalizado').forEach(m => { %>
                                <option value="<%= m.id %>">J<%= m.jornada %> — <%= m.equipo1 %> vs <%= m.equipo2 %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="form-row" style="margin-bottom:14px;">
                        <div class="form-group" style="flex:1;">
                            <label class="form-label">Goles local</label>
                            <input type="number" name="goles1" min="0" placeholder="0" style="width:100%;">
                        </div>
                        <div style="align-self:flex-end;padding-bottom:10px;color:#444;font-weight:700;">—</div>
                        <div class="form-group" style="flex:1;">
                            <label class="form-label">Goles visitante</label>
                            <input type="number" name="goles2" min="0" placeholder="0" style="width:100%;">
                        </div>
                    </div>
                    <button type="submit" class="btn btn-accent" style="width:100%;">
                        <i class="fas fa-check"></i> Registrar resultado
                    </button>
                </form>
            </div>

            <!-- Modificar resultado ya registrado -->
            <div class="section" style="border-left:3px solid #ffcc00;">
                <div class="section-title"><i class="fas fa-edit" style="color:#ffcc00;"></i> Modificar resultado</div>
                <form action="/admin/modificar-resultado" method="POST">
                    <div class="form-group" style="margin-bottom:10px;">
                        <label class="form-label">Partido finalizado</label>
                        <select name="match_id" style="width:100%;">
                            <% matches.filter(m => m.estado === 'finalizado').forEach(m => { %>
                                <option value="<%= m.id %>">J<%= m.jornada %> — <%= m.equipo1 %> <%= m.goles1 %>-<%= m.goles2 %> <%= m.equipo2 %></option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="form-row" style="margin-bottom:14px;">
                        <div class="form-group" style="flex:1;">
                            <label class="form-label">Goles local</label>
                            <input type="number" name="goles1" min="0" placeholder="0" style="width:100%;">
                        </div>
                        <div style="align-self:flex-end;padding-bottom:10px;color:#444;font-weight:700;">—</div>
                        <div class="form-group" style="flex:1;">
                            <label class="form-label">Goles visitante</label>
                            <input type="number" name="goles2" min="0" placeholder="0" style="width:100%;">
                        </div>
                    </div>
                    <p style="color:#555; font-size:0.75rem; margin-bottom:10px;">Revierte la clasificación anterior y aplica el nuevo resultado.</p>
                    <button type="submit" class="btn btn-warning" style="width:100%;" onclick="return confirm('¿Modificar este resultado? Se recalculará la clasificación.')">
                        <i class="fas fa-edit"></i> Modificar resultado
                    </button>
                </form>
            </div>

            <!-- Recalcular clasificación -->
            <div class="section" style="border-left:3px solid #00ffcc;">
                <div class="section-title"><i class="fas fa-sync-alt" style="color:#00ffcc;"></i> Recalcular clasificación</div>
                <p style="color:#888; font-size:0.8rem; margin-bottom:12px;">Resetea todos los contadores y los recalcula desde cero a partir de los partidos finalizados. Úsalo si los puntos están desfasados.</p>
                <form action="/admin/recalcular-clasificacion" method="POST">
                    <button type="submit" class="btn" style="width:100%; background:#00ffcc; color:#000; font-weight:700;" onclick="return confirm('¿Recalcular toda la clasificación desde cero?')">
                        <i class="fas fa-sync-alt"></i> Recalcular clasificación
                    </button>
                </form>
            </div>
        </div>

        <!-- Lista de partidos -->
        <div class="section">
            <div class="section-title"><i class="fas fa-calendar"></i> Todos los partidos</div>
            <% if (matches.length > 0) { %>
                <table>
                    <thead>
                        <tr><th>J</th><th>Local</th><th>Resultado</th><th>Visitante</th><th>Estado</th></tr>
                    </thead>
                    <tbody>
                        <% matches.forEach(m => { %>
                            <tr>
                                <td style="color:#444;">J<%= m.jornada %></td>
                                <td style="font-weight:600;"><%= m.equipo1 %></td>
                                <td style="text-align:center; font-weight:900; font-size:1.1rem; color:var(--primary);">
                                    <%= m.goles1 !== null ? `${m.goles1} - ${m.goles2}` : '— vs —' %>
                                </td>
                                <td style="font-weight:600;"><%= m.equipo2 %></td>
                                <td><span class="estado-badge estado-<%= m.estado %>"><%= m.estado %></span></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            <% } else { %>
                <p style="color:#333; font-size:0.9rem;">No hay partidos creados aún.</p>
            <% } %>
        </div>
    </div>

    <!-- ══ TAB: SISTEMA ══ -->
    <div id="tab-sistema" class="tab-content">

        <!-- Pre-inscripciones siguiente draft -->
        <div class="section" style="margin-bottom:20px; border-left:4px solid #a066ff;">
            <div class="section-title"><i class="fas fa-list-alt" style="color:#a066ff;"></i> Pre-inscripciones — Siguiente draft</div>
            <p style="color:#666; font-size:0.82rem; line-height:1.6; margin-bottom:16px;">
                Permite que la gente se apunte al <strong style="color:#ccc;">siguiente draft</strong> mientras el actual está en curso.
                Al hacer <strong>Limpiar todo</strong>, los pre-inscritos pasarán automáticamente como jugadores del nuevo draft.
                Estado actual: <strong style="color:<%= preinscripcionAbierta ? '#00ffcc' : '#ff4d4d' %>">
                    <%= preinscripcionAbierta ? '🟢 ABIERTAS' : '🔴 CERRADAS' %>
                </strong>
                <% if (totalPreinscritos > 0) { %>
                · <strong style="color:#a066ff;"><%= totalPreinscritos %> pre-inscritos</strong>
                <% } %>
            </p>
            <div style="display:flex;gap:10px;flex-wrap:wrap;">
                <% if (!preinscripcionAbierta) { %>
                <form action="/admin/abrir-preinscripcion" method="POST">
                    <button type="submit" class="btn" style="background:#a066ff;color:#fff;font-weight:700;">
                        <i class="fas fa-door-open"></i> Abrir pre-inscripciones
                    </button>
                </form>
                <% } else { %>
                <form action="/admin/cerrar-preinscripcion" method="POST"
                      onsubmit="return confirm('¿Cerrar las pre-inscripciones? Los jugadores ya apuntados se conservan.')">
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-door-closed"></i> Cerrar pre-inscripciones
                    </button>
                </form>
                <% } %>
            </div>
        </div>

        <!-- Corrección de jornada -->
        <div class="section" style="margin-bottom:20px; border-left:4px solid #ff8800;">
            <div class="section-title"><i class="fas fa-exclamation-triangle" style="color:#ff8800;"></i> Corrección de jornada</div>
            <p style="color:#666; font-size:0.82rem; line-height:1.6; margin-bottom:16px;">
                Usa esto si se generó una jornada incorrecta (ej: se generó la J3 cuando debía ser la J2).
                <strong style="color:#ff8800;">Paso 1:</strong> borra los partidos de la jornada mal generada.
                <strong style="color:#ff8800;">Paso 2:</strong> ajusta la jornada actual al valor correcto.
                Luego usa <strong>⚡ Forzar avance jornada</strong> en Discord para regenerar.
            </p>
            <div class="controls-grid two" style="gap:16px;">
                <div>
                    <div class="form-label" style="margin-bottom:8px;">Ajustar jornada actual</div>
                    <form action="/admin/ajustar-jornada" method="POST"
                          onsubmit="return confirm('¿Cambiar la jornada actual a ' + this.jornada_actual.value + '? Solo cambia el puntero, no borra ni crea partidos.')">
                        <div style="display:flex;gap:8px;align-items:center;">
                            <input type="number" name="jornada_actual" min="0" placeholder="Ej: 1"
                                   value="<%= jornadaActual %>"
                                   style="width:90px; padding:8px; background:#111; border:1px solid #333; color:#fff; border-radius:6px; font-size:0.95rem;">
                            <button type="submit" class="btn" style="background:#ff8800;color:#000;font-weight:700;white-space:nowrap;">
                                <i class="fas fa-pencil-alt"></i> Cambiar
                            </button>
                        </div>
                        <p style="color:#555; font-size:0.75rem; margin-top:6px;">Jornada actual en DB: <strong style="color:#888;"><%= jornadaActual %></strong></p>
                    </form>
                </div>
                <div>
                    <div class="form-label" style="margin-bottom:8px; color:#ff4d4d;">Borrar partidos de una jornada</div>
                    <form action="/admin/borrar-jornada" method="POST"
                          onsubmit="return confirm('¿Borrar TODOS los partidos de la jornada ' + this.jornada.value + '? Esta acción no se puede deshacer.')">
                        <div style="display:flex;gap:8px;align-items:center;">
                            <input type="number" name="jornada" min="1" placeholder="Ej: 3"
                                   style="width:90px; padding:8px; background:#111; border:1px solid #333; color:#fff; border-radius:6px; font-size:0.95rem;">
                            <button type="submit" class="btn btn-danger" style="white-space:nowrap;">
                                <i class="fas fa-trash-alt"></i> Borrar jornada
                            </button>
                        </div>
                        <p style="color:#555; font-size:0.75rem; margin-top:6px;">Borra los partidos de esa jornada de la DB (no borra los canales de Discord).</p>
                    </form>
                </div>
            </div>
        </div>

        <!-- Cierre manual de torneo -->
        <div class="section" style="margin-bottom:20px; border-left:4px solid var(--primary);">
            <div class="section-title"><i class="fas fa-flag-checkered"></i> Cierre de torneo</div>
            <div class="controls-grid">
                <div style="display:flex;flex-direction:column;gap:10px;">
                    <p style="color:#555; font-size:0.82rem; line-height:1.6;">
                        El sistema detecta automáticamente cuando todos los partidos
                        están finalizados y cierra el torneo.<br>
                        Si quieres cerrarlo manualmente antes: guarda el historial,
                        anuncia el campeón en Discord y limpia los canales.
                    </p>
                    <form action="/admin/cerrar-torneo" method="POST"
                          onsubmit="return confirm('¿Cerrar el torneo ahora? Se guardará el historial, se anunciará el campeón y se limpiarán los canales.')">
                        <button type="submit" class="btn btn-primary" style="width:100%;">
                            <i class="fas fa-flag-checkered"></i> CERRAR TORNEO Y GUARDAR HISTORIAL
                        </button>
                    </form>
                </div>
                <div style="background:rgba(0,255,204,0.03); border:1px solid rgba(0,255,204,0.1); border-radius:12px; padding:16px;">
                    <div class="form-label" style="margin-bottom:10px; color:var(--primary);">Cierre automático</div>
                    <div style="font-size:0.8rem; color:#555; line-height:1.7;">
                        El cron comprueba cada <strong style="color:#888;">5 minutos</strong>
                        si todos los partidos están finalizados.<br>
                        Si lo están: guarda historial → anuncia campeón → limpia Discord → resetea stats.
                    </div>
                </div>
            </div>
        </div>

        <!-- Historial de torneos -->
        <div class="section" style="margin-bottom:20px;">
            <div class="section-title"><i class="fas fa-history"></i> Historial de torneos</div>
            <% if (historial && historial.length > 0) { %>
                <div style="overflow-x:auto; margin-bottom:16px;">
                    <table>
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Fecha</th>
                                <th>Equipos</th>
                                <th>Formato</th>
                                <th>🥇 Campeón</th>
                                <th>🥈 Subcampeón</th>
                                <% if (esSuperAdmin) { %><th>Acciones</th><% } %>
                            </tr>
                        </thead>
                        <tbody>
                            <% historial.forEach((t, i) => { %>
                                <tr>
                                    <td style="color:#444;"><%= historial.length - i %></td>
                                    <td style="color:#555; font-size:0.8rem;">
                                        <%= new Date(t.fecha_fin).toLocaleDateString('es-ES', {day:'2-digit',month:'2-digit',year:'numeric'}) %>
                                    </td>
                                    <td style="text-align:center;"><%= t.n_equipos %></td>
                                    <td style="font-size:0.8rem; color:#666;"><%= t.formato %></td>
                                    <td style="font-weight:700; color:var(--primary);"><%= t.campeon %></td>
                                    <td style="color:#888;"><%= t.subcampeon %></td>
                                    <% if (esSuperAdmin) { %>
                                    <td>
                                        <form action="/admin/ganadores/borrar" method="POST"
                                              onsubmit="return confirm('¿Eliminar esta entrada del historial?')" style="margin:0;">
                                            <input type="hidden" name="id" value="<%= t.id %>">
                                            <button type="submit" class="btn btn-danger" style="padding:4px 10px; font-size:0.72rem;">
                                                <i class="fas fa-trash-alt"></i>
                                            </button>
                                        </form>
                                    </td>
                                    <% } %>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            <% } else { %>
                <p style="color:#333; font-size:0.85rem; margin-bottom:16px;">No hay torneos anteriores registrados.</p>
            <% } %>

            <% if (esSuperAdmin) { %>
            <!-- Añadir entrada manualmente -->
            <div style="background:rgba(0,255,204,0.03); border:1px solid rgba(0,255,204,0.1); border-radius:12px; padding:16px;">
                <div class="form-label" style="margin-bottom:12px; color:var(--primary);">Añadir entrada manualmente</div>
                <form action="/admin/ganadores/añadir" method="POST">
                    <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:10px;">
                        <div>
                            <label style="font-size:0.7rem; color:#555; display:block; margin-bottom:4px;">Campeón</label>
                            <input type="text" name="campeon" class="form-input" placeholder="Nombre del campeón" required>
                        </div>
                        <div>
                            <label style="font-size:0.7rem; color:#555; display:block; margin-bottom:4px;">Subcampeón</label>
                            <input type="text" name="subcampeon" class="form-input" placeholder="Nombre del subcampeón">
                        </div>
                        <div>
                            <label style="font-size:0.7rem; color:#555; display:block; margin-bottom:4px;">Nº equipos</label>
                            <input type="number" name="n_equipos" class="form-input" placeholder="8" min="2" max="32">
                        </div>
                        <div>
                            <label style="font-size:0.7rem; color:#555; display:block; margin-bottom:4px;">Formato</label>
                            <input type="text" name="formato" class="form-input" placeholder="Liga / 2 Grupos + Final">
                        </div>
                        <div>
                            <label style="font-size:0.7rem; color:#555; display:block; margin-bottom:4px;">Fecha inicio (opcional)</label>
                            <input type="date" name="fecha_inicio" class="form-input">
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary" style="width:100%;">
                        <i class="fas fa-plus"></i> AÑADIR AL HISTORIAL
                    </button>
                </form>
            </div>
            <% } %>
        </div>

        <!-- Exportar Excel -->
        <div class="section">
            <div class="section-title"><i class="fas fa-file-excel" style="color:#1d6f42;"></i> Exportar lista</div>
            <a href="/admin/exportar-excel" class="btn btn-accent" style="display:inline-flex;align-items:center;gap:8px;text-decoration:none;">
                <i class="fas fa-download"></i> Descargar Excel con todos los jugadores
            </a>
            <p style="color:#555; font-size:0.75rem; margin-top:8px;">Exporta nombre Discord, ID EA FC, posición, teléfono y equipo de todos los inscritos.</p>
        </div>

        <!-- Zona de peligro -->
        <div class="section danger">
            <div class="section-title"><i class="fas fa-exclamation-triangle" style="color:var(--danger);"></i>
                <span style="color:var(--danger);">Zona de peligro</span>
            </div>
            <div class="controls-grid">
                <form action="/admin/borrar-todos-jugadores" method="POST"
                      onsubmit="return confirm('⚠️ ¿Borrar TODOS los jugadores inscritos? Esta acción no se puede deshacer.')">
                    <button type="submit" class="btn btn-danger" style="width:100%;">
                        <i class="fas fa-users-slash"></i> BORRAR TODOS LOS JUGADORES
                    </button>
                    <p style="color:#333; font-size:0.75rem; margin-top:8px;">Elimina todos los jugadores inscritos. No toca equipos ni picks.</p>
                </form>
                <form action="/admin/reset-draft" method="POST" onsubmit="return confirm('⚠️ ESTO BORRARÁ TODO EL DRAFT. ¿Continuar?')">
                    <button type="submit" class="btn btn-danger" style="width:100%;">
                        <i class="fas fa-sync-alt"></i> RESETEAR DRAFT COMPLETO
                    </button>
                    <p style="color:#333; font-size:0.75rem; margin-top:8px;">Borra todos los equipos, picks y reinicia el draft.</p>
                </form>
                <form action="/admin/limpiar-todo" method="POST"
                      onsubmit="return confirm('⚠️ ESTO BORRARÁ TODO: jugadores, equipos, picks, partidos, clasificación, draft Y canales de Discord. ¿Continuar?')">
                    <button type="submit" class="btn btn-danger" style="width:100%; background:rgba(255,50,50,0.8);">
                        <i class="fas fa-radiation"></i> LIMPIAR TODO (WEB + DISCORD)
                    </button>
                    <p style="color:#333; font-size:0.75rem; margin-top:8px;">Nueva temporada completa: borra jugadores, equipos, picks, partidos, clasificación Y limpia todos los canales de Discord.</p>
                </form>
                <div style="color:#333; font-size:0.85rem; line-height:1.7; padding:10px;">
                    <strong style="color:#555;">Info del sistema</strong><br>
                    DB: SQLite (WAL)<br>
                    Ronda actual: <%= rondaActual %><br>
                    Jornada actual: <%= jornadaActual %><br>
                    Tiempo de turno: <%= tiempoTurno %>s
                </div>
            </div>
        </div>
    </div>

</div>

    <!-- ══ TAB: ADMINS ══ -->
    <% if (esSuperAdmin) { %>
    <div id="tab-admins" class="tab-content">

        <div class="section" style="margin-bottom:20px; border-left:4px solid var(--accent);">
            <div class="section-title"><i class="fas fa-user-shield" style="color:var(--accent);"></i> <span style="color:var(--accent);">Añadir admin secundario</span></div>
            <p style="color:#555; font-size:0.82rem; line-height:1.6; margin-bottom:16px;">
                Los admins secundarios tienen acceso al panel pero <strong style="color:#888;">no pueden gestionar otros admins</strong> ni tienen acceso a esta pestaña.<br>
