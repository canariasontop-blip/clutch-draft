# ── DISCORD OAUTH2 ──────────────────────────────────────
# Obtén estas credenciales en: https://discord.com/developers/applications
DISCORD_CLIENT_ID=TU_CLIENT_ID_AQUI
DISCORD_CLIENT_SECRET=TU_CLIENT_SECRET_AQUI
DISCORD_CALLBACK_URL=http://localhost:3000/auth/callback

# ── BOT DE DISCORD ───────────────────────────────────────
# Token del bot (sección "Bot" en el portal de desarrolladores)
DISCORD_TOKEN=TU_BOT_TOKEN_AQUI

# ── ADMIN ────────────────────────────────────────────────
# Tu Discord ID (clic derecho en tu perfil > "Copiar ID de usuario")
ADMIN_ID=TU_DISCORD_ID_AQUI

# ── SESIÓN ───────────────────────────────────────────────
# Cualquier string largo y aleatorio (lo puedes generar en: https://randomkeygen.com/)
SESSION_SECRET=cambia-esto-por-algo-aleatorio-y-largo

# ── SERVIDOR ─────────────────────────────────────────────
PORT=3000

# ── URL DE LA WEB (para que el bot avise al servidor) ────
# En local: http://localhost:3000
# En Railway: https://tu-app.up.railway.app
WEB_URL=http://localhost:3000
